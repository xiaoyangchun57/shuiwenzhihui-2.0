}

// 单行告警DOM更新（不刷新全表）
// Toast 浮动提示
function showToast(msg,type){
  type=type||'success';
  let c=document.querySelector('.toast-container');
  if(!c){c=document.createElement('div');c.className='toast-container';document.body.appendChild(c)}
  const t=document.createElement('div');t.className='toast '+type;t.textContent=msg;
  c.appendChild(t);
  setTimeout(()=>{t.classList.add('fade');setTimeout(()=>{if(t.parentNode)t.remove()},400)},2500)
}

function updateAlertRow(id,newStatus){
  var tr=document.querySelector('#al-body tr[data-id="'+id+'"]');
  if(!tr)return;
  // 更新状态badge文本
  var badge=tr.querySelector('td:nth-child(4) span');
  if(badge){
    var newText={'acknowledged':'处理中','resolved':'已办结','pending':'待处理'}[newStatus]||newStatus;
    var newColor=newStatus==='resolved'?'#777':newStatus==='acknowledged'?'#5ea8c8':'#ffa040';
    badge.textContent=newText;
    badge.style.background=newStatus==='resolved'?'rgba(80,80,80,0.1)':newStatus==='acknowledged'?'rgba(90,168,200,0.12)':'rgba(255,160,64,0.12)';
    badge.style.color=newColor;
    badge.style.borderColor=newStatus==='resolved'?'rgba(80,80,80,0.2)':newStatus==='acknowledged'?'rgba(90,168,200,0.25)':'rgba(255,160,64,0.25)';
  }
}
// 更新告警计数器（不重新拉取，基于DOM计算）
function updateAlertCounters(){
  const rows=document.querySelectorAll('#al-body tr');
  let pending=0;
  rows.forEach(r=>{const s=r.querySelector('.al-status-text');if(s&&s.dataset.status==='pending')pending++});
  const total=rows.length;
  // [fix] 注释掉ns-alerts的DOM覆盖，统一由summary管理
  // document.getElementById('ns-alerts').textContent=pending;
  // document.getElementById('ns-alerts').className=pending?'nsn danger':'nsn';
  // 同步更新指标卡
  renderAlertMetrics()
}
// 驾驶舱告警面板微刷新
function cockpitAlertRefresh(){
  const feed=document.getElementById('alert-feed');
  const badge=document.getElementById('alert-badge');
  if(!feed)return;
  const rows=document.querySelectorAll('#al-body tr');
  const pendingAlerts=[];
  rows.forEach(r=>{const s=r.querySelector('.al-status-text');if(s&&s.dataset.status==='pending'){const id=parseInt(r.dataset.id);const lv=r.querySelector('td:nth-child(2) span').style.color;const nm=r.querySelector('td:nth-child(3)').textContent;const msg=r.querySelector('td:nth-child(6)').textContent;const tm=r.querySelector('td:nth-child(8)').textContent;pendingAlerts.push({id,lv,nm,msg,tm})}});
  if(badge)badge.textContent=pendingAlerts.length?pendingAlerts.length+'条':'';
  if(feed)feed.innerHTML=pendingAlerts.length?pendingAlerts.slice(0,8).map(x=>{const lt=x.lv==='#ff4760'?'异常':'待确认';return '<div class="alert-item" style="cursor:pointer" onclick="showAlertDetail('+x.id+')"><span style="color:'+x.lv+';font-weight:500;font-size:12px">'+lt+'</span><span class="alert-msg">'+x.nm+':'+x.msg+'</span><span class="alert-tm">'+(x.tm||'').substring(11,16)+'</span></div>'}).join(''):'<span style="color:#5ea8c8">系统运行正常，无告警</span>'
}

async function showAlertTimeline(id){const t=await af('/timeline?source_type=alert&source_id='+id);if(!t)return;const ov=document.createElement('div');ov.className='modal-overlay';const TL={'acknowledged':'确认告警','urged':'督办','converted':'转工单','auto_converted':'自动转工单','manual_converted':'人工转工单','dismissed':'已消除','created':'告警产生','resolved':'告警办结'};const hasEvents=t&&t.length;ov.innerHTML=`<div class="modal" style="max-width:500px"><h4>&#187;&#187;&#187; 告警时间线 #${id}</h4><div style="max-height:350px;overflow-y:auto">${hasEvents?t.map(e=>`<div style="padding:6px 0;border-left:2px solid #00e0c0;padding-left:12px;margin-bottom:4px;position:relative"><div style="position:absolute;left:-5px;top:10px;width:8px;height:8px;border-radius:50%;background:#00e0c0"></div><div style="font-size:11px;color:#b0d4ef">${esc(TL[e.event_type]||e.event_type)}</div><div style="font-size:10px;color:#5ea8c8">${esc(e.operator)} · ${esc(e.created_at)}</div>${e.remark?`<div style="font-size:10px;color:#4a8aaa;margin-top:2px">${esc(e.remark)}</div>`:''}</div>`).join(''):'<div style="color:#4a8aaa;text-align:center;padding:20px">该告警尚无流转记录，请等待系统自动处理或人工复核</div>'}</div><button class="btn btn-sm" style="color:#4a8aaa;border:1px solid rgba(0,200,180,0.15);margin-top:8px" onclick="this.closest('.modal-overlay').remove()">关闭</button></div>`;document.body.appendChild(ov)}
async function ldOr(){const d=await af('/workorders?limit=100');if(!d)return;_initPg('or-body', d)}
const OB_CLS={'pending':'gray','accepted':'blue','generated':'cyan','dispatched':'org','in_progress':'grn','reviewing':'purple','acceptance':'yellow','closed':'darkgrn'};
window['_renderTable_or-body']=function(rows){
  document.getElementById('or-body').innerHTML=rows.map(o=>`<tr style="cursor:pointer" onclick="showOrderDetail('${esc(o.order_no)}')"><td style="font-family:monospace;color:#00e0c0">${esc(o.order_no)}</td><td>${esc(o.site_name||'-')}</td><td>${esc(SL[o.source]||o.source)}</td><td><span class="badge badge-${o.level==='critical'?'red':o.level==='urgent'?'org':'cyan'}">${LM[o.level]}</span></td><td>${esc(o.title)}</td><td><span class="badge badge-${OB_CLS[o.status]||'cyan'}">${SM[o.status]}</span></td><td>${esc(o.assignee||'-')}</td><td style="font-size:10px">${esc(o.sla_deadline||'-')}</td><td><button class="btn btn-primary btn-sm" onclick="event.stopPropagation();flw('${esc(o.order_no)}')">流转</button><button class="btn btn-xs" style="color:#ff4760;border:1px solid rgba(255,71,96,0.2);margin-left:4px" onclick="event.stopPropagation();delOrder('${esc(o.order_no)}')">删除</button></td></tr>`).join('')
};

async function delOrder(no){
  if(!confirm("确认删除工单 "+no+"？"))return;
  try{const r=await fetch(API+"/workorders/"+no,{method:"DELETE",headers:_authHdrs()});const j=await r.json();if(j&&j.success){document.querySelectorAll(".modal-overlay").forEach(function(e){e.remove()});ldOr()}else{alert(j.error||"删除失败")}}catch(e){alert("删除失败: "+e.message)}
}
async function showOrderDetail(no){
  const d=await af('/workorders?limit=200');if(!d)return;
  const o=d.find(x=>x.order_no===no);
  if(!o){showToast('工单 '+no+' 未找到或已被删除','warning');return}
  const timeline=await af('/timeline?source_type=order&limit=20');
  const t={pending:[['accepted','受理']],accepted:[['in_progress','处置']],in_progress:[['reviewing','送审'],['accepted','退回']],reviewing:_user&&_user.role==='admin'?[['acceptance','通过'],['in_progress','驳回']]:[],acceptance:[['closed','归档']],closed:[]};const acts=(t[o.status]||[]).map(([s,l])=>`<button class="btn btn-primary btn-sm" style="margin:2px" onclick="upd('${no}','${s}');this.closest('.modal-overlay').remove()">${l}</button>`).join('')||'完结';const ov=document.createElement('div');ov.className='modal-overlay';
const statusTimeline=['pending','accepted','generated','dispatched','in_progress','reviewing','acceptance','closed'];const curIdx=statusTimeline.indexOf(o.status);
;
const tlHtml=(timeline||[]).filter(e=>e.remark&&e.remark.includes(o.order_no)).slice(0,8).map(e=>`<div style="padding:4px 0 4px 12px;border-left:1.5px solid #00e0c0;margin-bottom:3px;position:relative"><div style="position:absolute;left:-4px;top:8px;width:6px;height:6px;border-radius:50%;background:#00e0c0"></div><div style="font-size:10px;color:#b0d4ef">${esc(TL_CN[e.event_type]||e.event_type)}</div><div style="font-size:9px;color:#5ea8c8">${esc(e.operator)} · ${esc(e.created_at)}</div></div>`).join('')||'暂无记录';
ov.innerHTML=`<div class="modal" style="max-width:650px"><h4>&#187;&#187;&#187; 工单详情</h4>
<div style="display:flex;gap:8px;margin-bottom:8px;font-size:12px"><span>${esc(o.order_no)}</span><span class="badge badge-${o.level==='critical'?'red':o.level==='urgent'?'org':'cyan'}">${LM[o.level]}</span></div>
<div style="font-size:12px;margin-bottom:6px"><strong>${esc(o.title)}</strong></div>
<div style="font-size:11px;color:#4a8aaa;margin-bottom:8px">站点: ${esc(o.site_name||'-')} | 来源: ${esc(SL[o.source]||o.source)} | 负责人: ${esc(o.assignee||'-')} | SLA: ${esc(o.sla_deadline||'-')}</div>
<div style="font-size:11px;color:#b0d4ef;margin-bottom:8px;padding:8px;background:rgba(0,200,180,0.03);border-radius:3px">${esc(o.description||'无描述')}</div>
<div style="display:flex;gap:3px;margin-bottom:8px;font-size:10px">${statusTimeline.map((s,i)=>`<div style="flex:1;text-align:center;padding:4px 2px;border-radius:2px;background:${i<=curIdx?'rgba(0,224,192,0.12)':'rgba(0,200,180,0.03)'};color:${i<=curIdx?'#00e0c0':'#4a8aaa'}">${SM[s]}</div>`).join('')}</div>
<div style="margin-bottom:8px"><span style="color:#4a8aaa;font-size:11px">流转操作:</span><br>${acts||'<span style="color:#4a8aaa;font-size:11px">工单已完结</span>'}</div>
<div style="border-top:1px solid rgba(0,200,180,0.08);padding-top:6px;margin-top:6px"><span style="color:#4a8aaa;font-size:11px">操作时间线</span><div style="max-height:120px;overflow-y:auto;margin-top:4px">${tlHtml}</div></div>
<div id="wo-photos-${no}" style="border-top:1px solid rgba(0,200,180,0.08);padding-top:6px;margin-top:6px"><span style="color:#4a8aaa;font-size:11px">巡检照片</span><div style="margin-top:4px;text-align:center;color:#5ea8c8;font-size:11px">加载中...</div></div>
<button class="btn btn-sm" style="color:#4a8aaa;border:1px solid rgba(0,200,180,0.15);margin-top:8px" onclick="this.closest('.modal-overlay').remove()">关闭</button></div>`;
document.body.appendChild(ov);
// 异步加载照片
try{
  const ph=await af('/workorders/'+no+'/photos');
  const phDiv=document.getElementById('wo-photos-'+no);
  if(ph&&ph.photos&&ph.photos.length){
    phDiv.innerHTML='<span style="color:#4a8aaa;font-size:11px">巡检照片</span><div style="margin-top:4px;display:flex;flex-wrap:wrap;gap:6px">'
      +ph.photos.map(p=>`<div style="width:80px;text-align:center"><img src="${esc(p.photo)}" style="width:80px;height:80px;object-fit:cover;border-radius:4px;cursor:pointer" onclick="window.open('${esc(p.photo).replace(/'/g,"\\'")}','_blank')" title="${esc(p.check_item)}"><div style="font-size:9px;color:#5ea8c8;margin-top:2px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${esc(p.check_item)}</div></div>`).join('')
      +'</div>';
  }else{
    phDiv.innerHTML='<span style="color:#4a8aaa;font-size:11px">巡检照片</span><div style="margin-top:4px;color:#5ea8c8;font-size:10px">暂无照片</div>';
  }
}catch(e){const phDiv=document.getElementById('wo-photos-'+no);if(phDiv)phDiv.innerHTML='<span style="color:#4a8aaa;font-size:11px">巡检照片</span><div style="margin-top:4px;color:#5ea8c8;font-size:10px">加载失败</div>'}}
async function flw(no){const d=await af('/workorders?limit=200');if(!d)return;const o=d.find(x=>x.order_no===no);if(!o)return;const t={pending:[['accepted','受理']],accepted:[['in_progress','处置']],in_progress:[['reviewing','送审'],['accepted','退回']],reviewing:_user&&_user.role==='admin'?[['acceptance','通过'],['in_progress','驳回']]:[],acceptance:[['closed','归档']],closed:[]};const acts=(t[o.status]||[]).map(([s,l])=>`<button class="btn btn-primary btn-sm" style="margin:2px" onclick="upd('${no}','${s}')">${l}</button>`).join('')||'完结';const ov=document.createElement('div');ov.className='modal-overlay';ov.innerHTML=`<div class="modal"><h4>&#187;&#187;&#187; 工单流转: ${no}</h4><div style="font-size:11px;margin-bottom:6px;color:#4a8aaa">${o.title} · 当前: ${SM[o.status]} · SLA: ${o.sla_deadline||'-'}</div><div>${acts}</div><br><button class="btn btn-sm" style="color:#4a8aaa;border:1px solid rgba(0,200,180,0.15)" onclick="this.closest('.modal-overlay').remove()">关闭</button></div>`;document.body.appendChild(ov)}
async function upd(no,s){const r=await afPt('/workorders/'+no+'/status',{status:s});if(r&&r.success){document.querySelectorAll('.modal-overlay').forEach(e=>e.remove());ldOr();refreshDashboard()}else{alert('流转失败: '+(r&&r.error||'未知错误'));}}
// ldIp和showInspDetail已删除（巡检管理已移除）
async function ldHl(){const d=await af('/hotline/events?limit=50');if(!d)return;document.getElementById('hl-body').innerHTML=d.map(e=>`<tr><td>${e.caller_name||'匿名'}</td><td>${e.caller_phone||'-'}</td><td>${e.event_type}</td><td style="max-width:150px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${e.description}</td><td>${e.location||'-'}</td><td><span class="badge badge-${e.status==='dispatched'?'grn':'cyan'}">${e.status==='dispatched'?'已转':'已登记'}</span></td><td>${e.created_at}</td></tr>`).join('')}
// ========== 巡检计划（真实 inspection） ==========
var _allInspPlans=[];
function switchInspTab(t,el){
  document.querySelectorAll('.insp-sub-bar .tab-btn').forEach(function(b){b.classList.remove('active')});
  if(el)el.classList.add('active');
  document.querySelectorAll('.insp-panel').forEach(function(p){p.style.display='none'});
  var p=document.getElementById('insp-'+t);
  if(p)p.style.display='block';
  if(t==='plans')ldMp();
  else if(t==='schemes')ldSchemes();
}
async function ldMp(){
  try{
    var all=_cached('/inspections');if(!all){all=await af('/inspections');if(all)_setCache('/inspections',all)}if(!all)return;
    _allInspPlans=all;
    var search=(document.getElementById('insp-search').value||'').trim().toLowerCase();
    var stF=document.getElementById('insp-status').value;
    var tpF=document.getElementById('insp-type').value;
    var filtered=all.filter(function(p){
      if(stF&&p.status!==stF)return false;
      if(tpF&&p.type!==tpF)return false;
      if(search&&p.plan_name.toLowerCase().indexOf(search)===-1&&(p.site_name||'').toLowerCase().indexOf(search)===-1)return false;
      return true;
    });
    var total=filtered.length,pending=0,inProgress=0,completed=0;
    for(var i=0;i<filtered.length;i++){var s=filtered[i].status;if(s==='pending')pending++;else if(s==='in_progress')inProgress++;else if(s==='completed')completed++}
    document.getElementById('insp-stats').innerHTML='<span style="color:#b0d4ef">总计 <b style="color:#00e0c0;font-family:monospace">'+total+'</b></span>'
      +'<span style="color:#ffa040">⏳ 待开始 <b>'+pending+'</b></span>'
      +'<span style="color:#00e0c0">● 进行中 <b>'+inProgress+'</b></span>'
      +'<span style="color:#2ea080">✅ 已完成 <b>'+completed+'</b></span>';
    // 扁平列表，不折叠
    var html='<table style="width:100%"><thead><tr><th>计划名称</th><th>站点</th><th>周期</th><th>起止日期</th><th>进度</th><th>状态</th><th>操作</th></tr></thead><tbody>';
    for(var i=0;i<filtered.length;i++){
      var p=filtered[i];var pct=p.total_items?Math.round((p.completed_items||0)/p.total_items*100):0;
      var sc=p.status==='completed'?'#2ea080':p.status==='in_progress'?'#00e0c0':'#ffa040';
      var sl=p.status==='completed'?'✅已完成':p.status==='in_progress'?'●进行中':'○待开始';
      var pc=pct>=100?'#2ea080':pct>=50?'#00e0c0':'#ffa040';
      var typeCn=p.type==='daily'?'每日':p.type==='weekly'?'每周':'每月';
      html+='<tr style="cursor:pointer" onclick="showInspDetail('+p.id+')">'
        +'<td style="font-size:12px;color:#d0e8ff">'+(p.plan_name||'')+'</td>'
        +'<td style="font-size:11px;color:#5ea8c8">'+(p.site_name||'')+'</td>'
        +'<td style="font-size:11px">'+typeCn+'</td>'
        +'<td style="font-size:11px;color:#5ea8c8">'+(p.start_date||'').substring(5)+' - '+(p.end_date||'').substring(5)+'</td>'
        +'<td style="min-width:100px"><div style="display:flex;align-items:center;gap:4px"><div style="flex:1;height:6px;background:rgba(0,200,180,0.06);border-radius:3px"><div style="height:100%;width:'+pct+'%;background:'+pc+';border-radius:3px"></div></div><span style="font-size:10px;color:'+pc+'">'+pct+'%</span></div></td>'
        +'<td style="color:'+sc+';font-size:11px">'+sl+'</td>'
        +'<td><button class="btn btn-xs" style="color:#00e0c0;border:1px solid rgba(0,200,180,0.2)" onclick="event.stopPropagation();showInspDetail('+p.id+')">详情</button></td></tr>';
    }
    html+='</tbody></table>';
    if(!filtered.length)html='<div style="text-align:center;padding:30px;color:#5ea8c8">暂无匹配的巡检计划</div>';
    document.getElementById('insp-list').innerHTML=html;
  }catch(e){console.warn('ldMp',e)}
}
async function showInspDetail(pid){
  try{
    var tasks=await af('/inspections/'+pid+'/tasks');if(!tasks)return;
    var plan=_allInspPlans.find(function(p){return p.id===pid});if(!plan)return;
    var pct=plan.total_items?Math.round((plan.completed_items||0)/plan.total_items*100):0;
    var h='';
    for(var i=0;i<tasks.length;i++){
      var t=tasks[i];var done=t.result!==null;var ab=t.result==='abnormal';
      var icon=ab?'❌':done?'✅':'☐';var cl=ab?'#ff4760':done?'#2ea080':'#5ea8c8';
      var ops='';
      if(!done)ops='<button class="btn btn-xs" style="color:#2ea080;border:1px solid rgba(46,160,128,0.3)" onclick="doInspTask('+t.id+','+pid+',\'normal\')">正常</button><button class="btn btn-xs" style="color:#ff4760;border:1px solid rgba(255,71,96,0.3)" onclick="doInspTask('+t.id+','+pid+',\'abnormal\')">异常</button>';
      else if(ab)ops='<span style="font-size:10px;color:#ff4760">已标记异常</span><button class="btn btn-xs" style="color:#ffa040;border:1px solid rgba(255,160,64,0.3);margin-left:4px" onclick="inspToOrder(\''+t.id+'\',\''+(t.check_item||'').replace(/'/g,"\\'")+'\')">转工单</button>';
      h+='<div style="display:flex;align-items:center;gap:6px;padding:6px 0;border-bottom:1px solid rgba(0,200,180,0.04)"><span style="width:20px;text-align:center;color:'+cl+'">'+icon+'</span><span style="flex:1;font-size:12px;color:#d0e8ff">'+(t.check_item||'')+'</span><span style="font-size:10px;color:'+cl+'">'+(t.result==='normal'?'正常':t.result==='abnormal'?'异常':'')+'</span>'+ops+'</div>';
    }
    var html='<div class="modal" style="max-width:520px"><h4>&#187;&#187;&#187; '+(plan.plan_name||'')+'</h4>'
      +'<div style="font-size:11px;color:#5ea8c8;margin-bottom:6px">站点：'+(plan.site_name||'')+' | 周期：'+(plan.type==='daily'?'每日':plan.type==='weekly'?'每周':'每月')+' | 进度：'+pct+'%</div>'
      +'<div style="max-height:300px;overflow-y:auto">'+h+'</div>'
      +'<div style="text-align:right;margin-top:8px;display:flex;gap:6px;justify-content:flex-end">'
      +'<button class="btn btn-sm" style="color:#ff4760;border:1px solid rgba(255,71,96,0.3)" onclick="deleteInspPlan('+pid+',\''+(plan.plan_name||'').replace(/'/g,"\\'")+'\')">删除计划</button>'
      +'<button class="btn btn-sm" style="color:#2ea080;border:1px solid rgba(46,160,128,0.3)" onclick="completeInspPlan('+pid+')">标记全部完成</button>'
      +'<button class="btn btn-sm" style="color:#4a8aaa;border:1px solid rgba(0,200,180,0.15)" onclick="this.closest(\'.modal-overlay\').remove()">关闭</button></div></div>';
    var ov=document.createElement('div');ov.className='modal-overlay';ov.innerHTML=html;document.body.appendChild(ov);
  }catch(e){console.warn(e)}
}
async function doInspTask(taskId,pid,result){
  var remark=result==='abnormal'?prompt('请输入异常描述：'):'';
  if(result==='abnormal'&&remark===null)return;
  var r=await afPt('/inspections/tasks/'+taskId,{result:result,remark:remark||''});
  if(r&&r.success){document.querySelectorAll('.modal-overlay').forEach(function(e){e.remove()});ldMp()}
  else alert('操作失败');
}
async function inspToOrder(taskId,itemName){
  if(!confirm('确认为此异常项创建工单？'))return;
  var r=await afP('/workorders',{site_id:0,source:'inspection',event_type:'巡检异常',level:'normal',title:'巡检异常: '+itemName,description:'巡检任务 #'+taskId+' 标记异常'});
  if(r&&r.success){alert('工单 '+r.order_no+' 已创建');document.querySelectorAll('.modal-overlay').forEach(function(e){e.remove()});ldMp()}
  else alert('创建失败');
}
async function completeInspPlan(pid){
  try{
    var tasks=await af('/inspections/'+pid+'/tasks');if(!tasks)return;
    var pending=tasks.filter(function(t){return t.result===null});
    if(pending.length&&!confirm('还有 '+pending.length+' 项未检查，标记全部正常并完成？'))return;
    for(var i=0;i<pending.length;i++){await afPt('/inspections/tasks/'+pending[i].id,{result:'normal',remark:'批量完成'})}
    document.querySelectorAll('.modal-overlay').forEach(function(e){e.remove()});ldMp()
  }catch(e){}
}
// 删除巡检计划
async function deleteInspPlan(pid,pname){
  if(!confirm('确定要删除巡检计划「'+pname+'」吗？此操作不可撤销！'))return;
  try{
    var r=await fetch(API+'/inspections/'+pid,{method:'DELETE',headers:_authHdrs()});
    var j=await r.json();
    if(j&&j.success){
      document.querySelectorAll('.modal-overlay').forEach(function(e){e.remove()});
      ldMp();
    }else{alert(j.error||'删除失败')}
  }catch(e){alert('删除失败: '+e.message)}
}
// 新建巡检计划
async function mNewInsp(){
  var sites=await af('/sites');if(!sites||!sites.length)return;
  var ov=document.createElement('div');ov.className='modal-overlay';
  ov.innerHTML='<div class="modal" style="max-width:480px"><h4>&#187;&#187;&#187; 新建巡检计划</h4>'
    +'<div class="form-row"><label>站点</label><select id="ni-site"><option value="">选择站点</option>'+sites.map(function(s){return '<option value="'+s.id+'">'+esc(s.name)+'</option>'}).join('')+'</select></div>'
    +'<div class="form-row"><label>名称</label><input id="ni-name" placeholder="巡检计划名称"></div>'
    +'<div class="form-row"><label>分类</label><select id="ni-cat"><option value="">选择分类</option><option value="站院环境">站院环境</option><option value="断面环境">断面环境</option><option value="水位观测">水位观测</option><option value="雨量监测">雨量监测</option><option value="蒸发监测">蒸发监测</option><option value="墒情监测">墒情监测</option><option value="设施设备">设施设备</option><option value="缆道系统">缆道系统</option><option value="安全防护">安全防护</option><option value="发电机">发电机</option></select></div>'
    +'<div class="form-row" style="display:flex;gap:8px"><label style="width:50px">周期</label><select id="ni-type" style="flex:1"><option value="daily">每日</option><option value="weekly">每周</option><option value="monthly">每月</option></select>'
    +'<select id="ni-scheme" style="flex:1"><option value="">选择方案（可选）</option></select></div>'
    +'<div class="form-row" style="display:flex;gap:8px"><label style="width:50px">起止</label><input type="date" id="ni-start" style="flex:1"><input type="date" id="ni-end" style="flex:1"></div>'
    +'<div id="ni-items" style="max-height:180px;overflow-y:auto;padding:6px;background:rgba(0,0,0,0.1);border-radius:3px;margin-bottom:8px;font-size:12px"><div style="color:#4a8aaa">选择方案后可调整检查项</div></div>'
    +'<div style="display:flex;gap:8px"><button class="btn btn-primary" onclick="sbmNewInsp()">创建</button><button class="btn" style="color:#4a8aaa;border:1px solid rgba(0,200,180,0.15)" onclick="this.closest(\'.modal-overlay\').remove()">取消</button></div></div>';
  document.body.appendChild(ov);
  var today=new Date().toISOString().substring(0,10);
  document.getElementById('ni-start').value=today;document.getElementById('ni-end').value=today;
}
document.addEventListener('change',function(e){if(e.target.id==='ni-site'||e.target.id==='ni-type'){var sid=parseInt(document.getElementById('ni-site').value);var type=document.getElementById('ni-type').value;var sel=document.getElementById('ni-scheme');sel.innerHTML='<option value="">选择方案（可选）</option>';if(!sid)return;af('/sites/'+sid+'/schemes').then(function(schemes){if(!schemes)return;var matched=schemes.filter(function(s){return s.period===type});for(var i=0;i<matched.length;i++){sel.innerHTML+='<option value="'+matched[i].id+'">'+matched[i].name+'</option>'}})}else if(e.target.id==='ni-scheme'){var sid2=parseInt(document.getElementById('ni-scheme').value);var div=document.getElementById('ni-items');if(!sid2){div.innerHTML='<div style="color:#4a8aaa;font-size:11px">选择方案后显示检查项</div>';return}af('/schemes/'+sid2).then(function(scm){if(scm&&scm.items){div.innerHTML='<div style="color:#5ea8c8;font-size:10px;margin-bottom:4px">检查项（可调整）</div>'+scm.items.map(function(item){return '<label style="display:flex;align-items:center;gap:4px;padding:3px 0;cursor:pointer"><input type="checkbox" class="ni-cb" value="'+(item.check_item||'').replace(/"/g,'&quot;')+'" checked style="width:14px;height:14px"><span style="color:#b0d4ef">'+(item.check_item||'')+'</span></label>'}).join('')}else div.innerHTML='<div style="color:#4a8aaa;font-size:11px">该方案无检查项</div>'})}});
async function sbmNewInsp(){
  var sid=document.getElementById('ni-site').value;var name=document.getElementById('ni-name').value.trim();var type=document.getElementById('ni-type').value;var schemeId=document.getElementById('ni-scheme').value;var start=document.getElementById('ni-start').value;var end=document.getElementById('ni-end').value;var cat=document.getElementById('ni-cat').value;
  if(!sid||!name||!start||!end){alert('请完善信息');return}
  if(!cat){alert('请选择分类');return}
  var cbs=document.querySelectorAll('.ni-cb:checked');var items=Array.from(cbs).map(function(cb){return cb.value});
  var payload={plan_name:name,site_id:parseInt(sid),type:type,start_date:start,end_date:end,period:type,category:cat};
  if(schemeId)payload.scheme_id=parseInt(schemeId);
  if(items.length)payload.check_items=items;
  var r=await afP('/inspections',payload);
  if(r&&r.success){alert('巡检计划已创建');document.querySelectorAll('.modal-overlay').forEach(function(e){e.remove()});ldMp()}else alert(r&&r.error||'创建失败');
}
// 检查方案管理
async function ldSchemes(){
  try{
    var sites=await af('/sites');if(!sites)return;
    var body=document.getElementById('sch-body');var html='';
    for(var i=0;i<sites.length;i++){
      var s=sites[i];var schemes=await af('/sites/'+s.id+'/schemes')||[];
      var d=schemes.find(function(x){return x.period==='daily'});var w=schemes.find(function(x){return x.period==='weekly'});var m=schemes.find(function(x){return x.period==='monthly'});
      html+='<tr><td>'+(s.name||'')+' ('+(s.code||'')+')</td>'
        +'<td style="font-size:11px;color:'+(d?'#2ea080':'#4a8aaa')+'">'+(d?d.name+' ('+(d.item_count||0)+'项)':'未设置')+'</td>'
        +'<td style="font-size:11px;color:'+(w?'#2ea080':'#4a8aaa')+'">'+(w?w.name+' ('+(w.item_count||0)+'项)':'未设置')+'</td>'
        +'<td style="font-size:11px;color:'+(m?'#2ea080':'#4a8aaa')+'">'+(m?m.name+' ('+(m.item_count||0)+'项)':'未设置')+'</td>'
        +'<td><button class="btn btn-xs" style="color:#00e0c0;border:1px solid rgba(0,200,180,0.2)" onclick="editSiteSchemes('+s.id+')">查看</button></td></tr>';
    }
    body.innerHTML=html;
  }catch(e){console.warn(e)}
}
function filterSchemes(q){var rows=document.getElementById('sch-body').querySelectorAll('tr');var v=q.toLowerCase();rows.forEach(function(r){r.style.display=r.textContent.toLowerCase().indexOf(v)!==-1?'':'none'})}
async function editSiteSchemes(sid){
  var schemes=await af('/sites/'+sid+'/schemes')||[];
  var site=(await af('/sites')).find(function(s){return s.id===sid});
  var html='<div class="modal" style="max-width:500px"><h4>&#187;&#187;&#187; 检查方案 - '+(site?site.name:'')+'</h4>';
  var ps=[{k:'daily',cn:'每日'},{k:'weekly',cn:'每周'},{k:'monthly',cn:'每月'}];
  for(var i=0;i<ps.length;i++){
    var p=ps[i];var scm=schemes.find(function(x){return x.period===p.k});
    if(scm){var items=await af('/schemes/'+scm.id)||{};var ci=items.items||[];
      html+='<div style="margin:6px 0;padding:6px;background:rgba(0,200,180,0.03);border-radius:3px"><div style="font-size:12px;color:#00e0c0;font-weight:500;margin-bottom:4px">'+p.cn+'方案：'+(scm.name||'')+'</div>'
        +ci.map(function(item){return '<div style="font-size:11px;color:#b0d4ef;padding:2px 0">· '+(item.check_item||'')+'</div>'}).join('')+'</div>';
    }else{html+='<div style="margin:6px 0;padding:6px;background:rgba(0,0,0,0.1);border-radius:3px;font-size:11px;color:#4a8aaa">'+p.cn+'方案：未设置</div>'}
  }
  html+='<div style="font-size:10px;color:#5ea8c8;margin-top:4px">💡 方案通过「导入方案」从Excel批量导入</div>'
    +'<div style="text-align:right;margin-top:8px"><button class="btn btn-sm" style="color:#4a8aaa;border:1px solid rgba(0,200,180,0.15)" onclick="this.closest(\'.modal-overlay\').remove()">关闭</button></div></div>';
  var ov=document.createElement('div');ov.className='modal-overlay';ov.innerHTML=html;document.body.appendChild(ov);
}
async function autoGenerateInsp(){
  if(!confirm('将为所有已配置方案的站点生成今日巡检计划，确认执行？'))return;
  var btn=event&&event.target;if(btn){btn.disabled=true;btn.textContent='生成中...'}
  try{
    var r=await fetch(API+'/inspections/auto-generate',{method:'POST',headers:_authHdrs()});
    var d=await r.json();
    if(d&&d.success){showToast('已生成 '+d.generated+' 条巡检计划','success')}
    else{alert(d.error||'生成失败')}
  }catch(e){alert('请求失败: '+e.message)}
  finally{if(btn){btn.disabled=false;btn.textContent='📋 生成巡检计划'}}
}
function downloadSchemeTemplate(){window.open(API+'/schemes/template','_blank')}
function uploadSchemeImport(){
  var ov=document.createElement('div');ov.className='modal-overlay';
  ov.innerHTML='<div class="modal" style="max-width:400px"><h4>导入检查方案</h4><p style="font-size:12px;color:#5ea8c8;margin-bottom:8px">选择填好的Excel文件导入</p><input type="file" id="scheme-file" accept=".xlsx,.xls" style="width:100%;margin-bottom:8px"><div style="display:flex;gap:8px"><button class="btn btn-primary" onclick="doImportSchemes()">上传导入</button><button class="btn" style="color:#4a8aaa;border:1px solid rgba(0,200,180,0.15)" onclick="this.closest(\'.modal-overlay\').remove()">取消</button></div></div>';
  document.body.appendChild(ov);
}
async function doImportSchemes(){
  var inp=document.getElementById('scheme-file');if(!inp.files||!inp.files.length){alert('请选择文件');return}
  var fd=new FormData();fd.append('file',inp.files[0]);
  var r=await fetch(API+'/schemes/import',{method:'POST',headers:_authHdrs(),body:fd});var d=await r.json();
  if(d&&d.success){alert('导入成功，共'+d.count+'条');document.querySelectorAll('.modal-overlay').forEach(function(e){e.remove()});ldSchemes()}
  else alert('导入失败: '+(d?d.error:''));
}

// ========== 时间线 ==========
async function ldTl(){
  const t=await af('/timeline?limit=100');if(!t)return;
  const ft=document.getElementById('tl-type').value;const fe=document.getElementById('tl-event').value;
  const filtered=t.filter(x=>{if(ft&&x.source_type!==ft)return false;if(fe&&x.event_type!==fe)return false;return true});
  const TL_CN={alert:'告警',order:'工单',inspection:'巡检',maintenance:'运维',water_level:'水位校验',acknowledged:'确认',urged:'督办',converted:'转工单',created:'创建',completed:'完成',checked:'校验',auto_checked:'自动校验',alert_generated:'触发告警'};
  const CL={alert:'#ff4760',order:'#ffa040',inspection:'#2ea080',maintenance:'#00e0c0',water_level:'#a855f7'};
  document.getElementById('tl-body').innerHTML=filtered.map(e=>{
    const c=CL[e.source_type]||'#5ea8c8';const typeCn=TL_CN[e.source_type]||e.source_type;const evtCn=TL_CN[e.event_type]||e.event_type;
    return `<div style="padding:8px 0;border-left:2px solid ${c};padding-left:14px;margin-bottom:6px;position:relative"><div style="position:absolute;left:-5px;top:12px;width:8px;height:8px;border-radius:50%;background:${c}"></div><div style="display:flex;gap:6px;align-items:center;font-size:11px"><span style="background:${c};color:#001;border-radius:2px;padding:1px 4px;font-size:9px">${esc(typeCn)}</span><span style="color:#d0e8ff">${esc(evtCn)}</span></div><div style="font-size:10px;color:#5ea8c8;margin-top:2px">${esc(e.operator)} · ${esc(e.created_at)}</div>${e.remark?`<div style="font-size:10px;color:#4a8aaa;margin-top:2px">${esc(e.remark)}</div>`:''}</div>`
  }).join('')||'<div style="color:#4a8aaa;text-align:center;padding:30px">暂无时间线记录</div>'
}


// ========== 模态 ==========
// 新建模态（仅工单，巡检已移除）
function mNew(t){if(t!=='order')return;const ov=document.createElement('div');ov.className='modal-overlay';let h='';
  // 动态加载站点列表
  _loadSitesForOrder().then(sites=>{
    const siteOpts=sites.map(s=>`<option value="${s.id}" data-manager="${s.manager||''}">${s.name}</option>`).join('');
    h=`<div class="modal"><h4>新建工单</h4><div class="form-row"><label>站点</label><select id="om-s" onchange="autoFillAssignee()"><option value="">请选择站点</option>${siteOpts}</select></div><div class="form-row"><label>来源</label><select id="om-src"><option value="manual">人工</option><option value="patrol">巡查</option><option value="auto">自动</option></select></div><div class="form-row"><label>级别</label><select id="om-lv"><option value="normal">一般</option><option value="urgent">紧急</option><option value="critical">重大</option></select></div><div class="form-row"><label>标题</label><input id="om-t"></div><div class="form-row"><label>描述</label><textarea id="om-d"></textarea></div><div class="form-row"><label>指派</label><input id="om-a" readonly style="background:rgba(0,200,180,0.03);color:#b0d4ef"></div><div style="display:flex;gap:8px"><button class="btn btn-primary" onclick="sbmO()">提交</button><button class="btn" style="color:#4a8aaa;border:1px solid rgba(0,200,180,0.15)" onclick="this.closest('.modal-overlay').remove()">取消</button></div></div>`;
    ov.innerHTML=h;document.body.appendChild(ov)
  });
}
// 加载站点列表供新建工单使用
async function _loadSitesForOrder(){let d=await af('/sites?limit=300');if(!d||!d.length){d=await af('/sites')}return d||[]}
// 选择站点后自动填充负责人
function autoFillAssignee(){const sel=document.getElementById('om-s');const opt=sel&&sel.options[sel.selectedIndex];const inp=document.getElementById('om-a');if(opt&&inp){inp.value=opt.getAttribute('data-manager')||''}}
async function sbmO(){const d={site_id:parseInt(document.getElementById('om-s').value),source:document.getElementById('om-src').value,level:document.getElementById('om-lv').value,title:document.getElementById('om-t').value,description:document.getElementById('om-d').value,assignee:document.getElementById('om-a').value};if(!d.site_id){alert('请选择站点');return}if(!d.title){alert('请输入标题');return}const r=await afP('/workorders',d);if(r&&r.success){showToast('工单 '+r.order_no+' 创建成功');document.querySelectorAll('.modal-overlay').forEach(e=>e.remove());ldOr()}else{alert('创建失败: '+(r&&r.error||'未知错误'))}}
// sbmI已删除（巡检创建已移除）

// ========== 筛选 / 搜索 / 排序 ==========
let sortState={};
function filterTable(id,kw,ci){
  const tbody=document.getElementById(id);if(!tbody)return;
  const rows=tbody.querySelectorAll('tr');const v=kw.toLowerCase();
  if(!Array.isArray(ci))ci=[ci];
  rows.forEach(r=>{const match=ci.some(i=>{const c=r.cells[i];return c&&c.textContent.toLowerCase().includes(v)});r.style.display=match?'':'none'})
}
function filterEq(id,ci,v){
  const tbody=document.getElementById(id);if(!tbody)return;
  const rows=tbody.querySelectorAll('tr');
  rows.forEach(r=>{const c=r.cells[ci];if(!c)return;r.style.display=!v||c.textContent.trim()===v?'':'none'})
}
function filterAlStatus(v){
  const tbody=document.getElementById('al-body');if(!tbody)return;
  tbody.querySelectorAll('tr').forEach(r=>{
    const el=r.querySelector('.al-status-text');
    r.style.display=!v||(el&&el.textContent.trim()===v)?'':'none'
  })
}
function sortTable(id,ci){
  const tbody=document.getElementById(id);if(!tbody)return;
  const rows=Array.from(tbody.querySelectorAll('tr'));const key=id+'-'+ci;
  sortState[key]=!sortState[key];const asc=sortState[key];
  rows.sort((a,b)=>{
    const va=a.cells[ci].textContent.trim(),vb=b.cells[ci].textContent.trim();
    const na=parseFloat(va),nb=parseFloat(vb);
    if(!isNaN(na)&&!isNaN(nb))return asc?na-nb:nb-na;
    return asc?va.localeCompare(vb,'zh-CN'):vb.localeCompare(va,'zh-CN')
  });
  rows.forEach(r=>tbody.appendChild(r))
}

// ========== Init ==========
document.getElementById('bt-time').textContent='加载中...';
setInterval(()=>{const d=new Date();const el=document.getElementById('nav-clock');if(el)el.textContent=d.toLocaleDateString('zh-CN')+' '+d.toLocaleTimeString('zh-CN',{hour12:false})},1000);
async function waitForBackend(retries=5,delay=2000){
  for(let i=0;i<retries;i++){
    try{const r=await fetch('/api/health');const d=await r.json();if(d.status==='ok'){console.log('[Init] 后端就绪');return true}}catch(e){console.warn('[Init] 后端未就绪,重试',i+1)}
    await new Promise(r=>setTimeout(r,delay))
  }
  console.error('[Init] 后端无法连接');return false
}
async function safeInit(){
  const ready=await waitForBackend(3,2000);
  document.getElementById('bt-time').textContent=ready?'已连接':'连接失败';
  try{initMap()}catch(e){console.error('[Init] 地图初始化失败:',e)}
  const loadTimeout=new Promise(r=>setTimeout(r,20000));
  try{await Promise.race([
    Promise.all([
      cockpitLoad().catch(e=>console.error('[Init] 驾驶舱加载失败:',e)),
      ldSt(true).catch(e=>console.error('[Init] 站点加载失败:',e)),
      ldAl().catch(e=>console.error('[Init] 告警加载失败:',e)),
      ldOr().catch(e=>console.error('[Init] 工单加载失败:',e)),
      ldMp().catch(e=>console.error('[Init] 巡检计划加载失败:',e))
    ]),
    loadTimeout
  ])}catch(e){console.error('[Init] 部分数据加载失败:',e)}
  const loadingEl=document.getElementById('cockpit-loading');
  if(loadingEl)loadingEl.classList.add('hide');
}
// 轻量级刷新（仅刷新驾驶舱实时数据，不重载全部管理端数据）
async function lightRefresh(){
  try{
    const s=await af('/data/realtime');
    const a=await af('/alerts?limit=50');
    if(s){const abnormal=s.filter(function(x){return x.status==='offline'||(x.latest_value>1000&&x.latest_metric!=='')}).length;document.getElementById('site-stat-badge')&&(document.getElementById('site-stat-badge').textContent=s.length+'站 '+(abnormal?abnormal+'异常':'')+(abnormal?'  ❗':''))}
    if(a){
      const p=a.filter(x=>x.status==='pending').sort((a,b)=>{const o={red:3,orange:2,yellow:1};return (o[b.level]||0)-(o[a.level]||0)});
      document.getElementById('alert-badge')&&(document.getElementById('alert-badge').textContent=p.length?p.length+'条':'');
      // 刷新驾驶舱预警面板
      const feed=document.getElementById('alert-feed');
      if(feed)feed.innerHTML=p.length?p.slice(0,8).map(x=>{const lt=x.level==='red'?'异常':'待确认';const lc=x.level==='red'?'#ff4760':x.level==='orange'?'#ffa040':'#ffd000';return '<div class="alert-item" style="cursor:pointer" onclick="showAlertDetail('+x.id+')"><span style="color:'+lc+';font-weight:500;font-size:12px">'+lt+'</span><span class="alert-msg">'+x.site_name+':'+x.message+'</span><span class="alert-tm">'+(x.created_at||'').substring(11,16)+'</span></div>'}).join(''):'<span style="color:#5ea8c8">系统运行正常，无告警</span>'
    }
  }catch(e){console.warn('[LightRefresh]',e)}
}
(async function(){const authed=await checkAuth();if(authed){safeInit()}})();

// ========== 设备管理 ==========
function switchEquipTab(t,el){
  document.querySelectorAll('.equip-tab').forEach(e=>e.classList.remove('active'));
  if(el) el.classList.add('active');
  // Fallback: find tab-btn in equipment card
  var parent=el?el.parentElement:document.querySelector('#panel-equipment .card-hd+div');
  if(parent) parent.querySelectorAll('.tab-btn').forEach(function(b){b.classList.remove('active')});
  if(el) el.classList.add('active');
  document.querySelectorAll('.equip-panel').forEach(function(p){p.style.display='none'});
  var p=document.getElementById('equip-'+t);
  if(p){p.style.display='block'}
  if(t==='ledger') ldEquipLedger();
  else if(t==='inventory') ldEquipInventory();
  else if(t==='approval') ldEquipApproval();
}
function switchAprTab(t,el){
  var parent=el?el.parentElement:null;
  if(parent) parent.querySelectorAll('.tab-btn').forEach(function(b){b.classList.remove('active')});
  if(el) el.classList.add('active');
  document.getElementById('apr-body').dataset.status=t;
  ldEquipApproval();
}
// 设备类型中文映射
var DEVICE_TYPE_CN={
  'hydro_collector':'水文综合采集仪','rainfall_gauge':'雨量计','electronic_rainfall':'电子雨量计',
  'rainfall_meter':'雨量计','water_level_meter':'水位计','radar_water_level':'雷达水位计',
  'pressure_water_level':'压力水位计','flow_meter':'流量计','current_meter':'流速仪',
  'soil_moisture_sensor':'土壤墒情传感器','soil_temperature':'土壤温度计',
  'evaporation_pan':'蒸发皿','weather_screen':'气象百叶箱','anemometer':'风速仪',
  'groundwater_level':'地下水位计','water_quality_monitor':'水质监测仪',
  'video_surveillance':'视频监控','security_alarm':'安防报警','env_sensor':'环境传感器',
  'generic':'通用传感器'
};
// 加载设备类型下拉
async function _loadEqTypes(){
  try{
    var sel=document.getElementById('eq-type');if(!sel)return;
    var r=await af('/devices?limit=1');
    if(!r||!r.length)return;
    var types={};
    for(var i=0;i<r.length;i++) types[r[i].device_type]=true;
    sel.innerHTML='<option value="">全部类型</option>';
    var keys=Object.keys(types).sort();
    for(var j=0;j<keys.length;j++){
      var cn=DEVICE_TYPE_CN[keys[j]]||keys[j];
      sel.innerHTML+='<option value="'+esc(keys[j])+'">'+esc(cn)+'</option>';
    }
  }catch(e){}
}
// 设备台账
async function ldEquipLedger(){
  try{
    var search=document.getElementById('eq-search').value.trim();
    var type=document.getElementById('eq-type').value;
    var status=document.getElementById('eq-status').value;
    var url='/devices?';
    if(search) url+='search='+encodeURIComponent(search)+'&';
    if(type) url+='type='+encodeURIComponent(type)+'&';
    if(status) url+='status='+status;
    var rows=await af(url);
    var body=document.getElementById('eq-body');
    if(!body) return;
    var total=0,online=0,offline=0,lowVoltage=0;
    if(rows) for(var i=0;i<rows.length;i++){
      var d=rows[i];
      if(d.status==='online'){
        if(d.voltage!==null&&d.voltage<11.8) lowVoltage++;
        else online++;
      } else if(d.status==='offline') offline++;
      total++;
    }
    document.getElementById('eq-stats').innerHTML='<span style="color:#b0d4ef">设备总数 <b style="color:#00e0c0;font-family:monospace">'+total+'</b></span>'
      +'<span style="color:#2ea080">● 在线 <b>'+online+'</b></span>'
      +'<span style="color:#ffa040">⚡ 电压偏低 <b>'+lowVoltage+'</b></span>'
      +'<span style="color:#ff4760">○ 离线 <b>'+offline+'</b></span>';
    _initPg('eq-body', rows||[]);
  }catch(e){console.warn('ldEquipLedger err',e)}
}
window['_renderTable_eq-body']=function(rows){
  var html='';
  for(var i=0;i<rows.length;i++){
    var d=rows[i];
    var v=d.voltage||d.battery||'--';
    if(typeof v==='number') v=v.toFixed(1);
    var isLowV=d.status==='online'&&d.voltage!==null&&d.voltage<11.8;
    var sc=isLowV?'#ffa040':d.status==='offline'?'#ff4760':'#2ea080';
    var stxt=isLowV?'电压偏低':d.status==='online'?'在线':'离线';
    var typeCn=DEVICE_TYPE_CN[d.device_type]||d.device_type||'';
    html+='<tr><td style="font-family:monospace;font-size:11px">'+esc(d.device_code||'')+'</td>'
      +'<td>'+esc(d.device_name||'')+'</td>'
      +'<td>'+esc(d.site_name||'')+'</td>'
      +'<td style="font-size:11px;color:#5ea8c8">'+typeCn+'</td>'
      +'<td style="color:'+sc+'">'+stxt+'</td>'
      +'<td>'+v+'</td>'
      +'<td style="font-size:11px;color:#5ea8c8">'+(d.last_data_time||'--').substring(11,19)+'</td>'
      +'<td><button class="btn btn-xs" style="color:#00e0c0;border:1px solid rgba(0,200,180,0.2)" onclick="showEquipDetail('+d.id+')">详情</button></td></tr>';
  }
  if(!html) html='<tr><td colspan="8" style="color:#5ea8c8;text-align:center;padding:20px">暂无设备数据</td></tr>';
  document.getElementById('eq-body').innerHTML=html;
};
// 设备详情
async function showEquipDetail(id){
  try{
    var r=await af('/devices/'+id);if(!r||!r.device)return;
    var d=r.device;
    var logs=r.logs||[];
    var v=d.voltage||d.battery||'--';
    if(typeof v==='number') v=v.toFixed(1)+'V';
    var html='<div class="modal" style="max-width:520px"><h4>&#187;&#187;&#187; 设备详情</h4>'
      +'<div style="display:grid;grid-template-columns:1fr 1fr;gap:6px;font-size:12px;color:#b0d4ef">'
      +'<div>编码：<b style="color:#d0e8ff;font-family:monospace">'+esc(d.device_code||'')+'</b></div>'
      +'<div>名称：<b style="color:#d0e8ff">'+esc(d.device_name||'')+'</b></div>'
      +'<div>类型：<b style="color:#5ea8c8">'+(DEVICE_TYPE_CN[d.device_type]||d.device_type||'')+'</b></div>'
      +'<div>站点：<b>'+esc(d.site_name||'')+' ('+esc(d.site_code||'')+')</b></div>'
      +'<div>状态：<b style="color:'+(d.status==='online'?'#2ea080':'#ff4760')+'">'+(d.status==='online'?'在线':'离线')+'</b></div>'
      +'<div>电压：<b>'+v+'</b></div>'
      +'<div>最后数据：<b style="color:#5ea8c8">'+(d.last_data_time||'--')+'</b></div>'
      +'<div>行政区：<b>'+esc(d.district||'')+'</b></div>'
      +'</div>'
      +(logs.length?'<h5 style="color:#00e0c0;font-size:12px;margin:10px 0 4px">维护记录</h5>'
        +logs.map(function(l){return '<div style="font-size:10px;color:#5ea8c8;padding:2px 0;border-bottom:1px solid rgba(0,200,180,0.04)">'+(l.created_at||'').substring(0,16)+' | '+esc(l.remark||'')+' | '+esc(l.operator||'')+'</div>'}).join(''):'')
      +'<div style="text-align:right;margin-top:10px"><button class="btn btn-sm" style="color:#00e0c0;border:1px solid rgba(0,200,180,0.2)" onclick="this.closest(\'.modal-overlay\').remove()">关闭</button></div></div>';
    var ov=document.createElement('div');ov.className='modal-overlay';ov.innerHTML=html;
    document.body.appendChild(ov);
  }catch(e){console.warn(e)}
}
// 备件库存
async function ldEquipInventory(){
  try{
    var search=document.getElementById('inv-search').value.trim();
    var cat=document.getElementById('inv-cat').value;
    var lowBtn=document.getElementById('inv-low-btn');
    var lowF=(lowBtn&&lowBtn.dataset.active==='1');
    var url='/parts/inventory?';
    if(search) url+='search='+encodeURIComponent(search)+'&';
    if(cat) url+='category='+encodeURIComponent(cat)+'&';
    if(lowF) url+='low=1';
    var rows=await af(url);
    var body=document.getElementById('inv-body');if(!body)return;
    var warnDiv=document.getElementById('inv-warn');
    var lowItems=[];
    if(rows) for(var i=0;i<rows.length;i++){
      var p=rows[i];
      if(p.quantity<=p.min_quantity) lowItems.push(p.part_name+'('+p.quantity+'/'+p.min_quantity+')');
    }
    if(lowItems.length){
      warnDiv.style.display='block';
      warnDiv.innerHTML='⚠ 以下备件库存不足：'+lowItems.join('、');
    } else warnDiv.style.display='none';
    _initPg('inv-body', rows||[]);
  }catch(e){console.warn(e)}
}
window['_renderTable_inv-body']=function(rows){
  var html='';
  for(var i=0;i<rows.length;i++){
    var p=rows[i];
    var isLow=p.quantity<=p.min_quantity;
    var clr=isLow?'style="color:#ff4760;font-weight:500"':'';
    html+='<tr><td style="font-family:monospace;font-size:11px">'+esc(p.part_code||'')+'</td>'
      +'<td '+clr+'>'+esc(p.part_name||'')+(isLow?' <span style="color:#ff4760">⚠</span>':'')+'</td>'
      +'<td style="color:#5ea8c8;font-size:11px">'+esc(p.category||'')+'</td>'
      +'<td style="font-family:monospace;text-align:center;'+(isLow?'color:#ff4760':'')+'">'+p.quantity+'</td>'
      +'<td style="text-align:center;color:#5ea8c8">'+p.min_quantity+'</td>'
      +'<td>'+esc(p.unit||'')+'</td>'
      +'<td style="font-size:11px;color:#5ea8c8">'+esc(p.site_name||'中心库')+'</td>'
      +'<td><button class="btn btn-xs" style="color:#2ea080;border:1px solid rgba(46,160,128,0.3);margin:0 2px" onclick="showInvIn('+p.id+',\''+esc(p.part_name)+'\','+p.quantity+','+p.min_quantity+')">入库</button><button class="btn btn-xs" style="color:#ffa040;border:1px solid rgba(255,160,64,0.3);margin:0 2px" onclick="showInvOut('+p.id+',\''+esc(p.part_name)+'\','+p.quantity+','+p.min_quantity+')">出库</button><button class="btn btn-xs" style="color:#5ea8c8;border:1px solid rgba(90,168,200,0.2);margin:0 2px" onclick="showInvLogs('+p.id+',\''+esc(p.part_name)+'\')">流水</button></td></tr>';
  }
  if(!html) html='<tr><td colspan="8" style="color:#5ea8c8;text-align:center;padding:20px">暂无备件数据</td></tr>';
  document.getElementById('inv-body').innerHTML=html;
};
function toggleLowFilter(){
  var btn=document.getElementById('inv-low-btn');
  if(!btn)return;
  if(btn.dataset.active==='1'){btn.dataset.active='0';btn.style.background='';btn.style.color='#ffa040'}
  else{btn.dataset.active='1';btn.style.background='rgba(255,160,64,0.15)';btn.style.color='#ff4760'}
  ldEquipInventory();
}
// 新增备件弹窗
function showInvAdd(){
  var html='<div class="modal" style="max-width:400px"><h4>&#187;&#187;&#187; 新增备件</h4>'
    +'<div style="display:grid;gap:6px;font-size:12px">'
    +'<div>备件编号：<input id="inv-f-code" placeholder="自动生成可不填" style="width:100%;padding:6px 8px;background:rgba(0,0,0,0.15);border:1px solid rgba(0,200,180,0.15);border-radius:3px;color:#d0e8ff"></div>'
    +'<div>备件名称：<input id="inv-f-name" placeholder="必填" style="width:100%;padding:6px 8px;background:rgba(0,0,0,0.15);border:1px solid rgba(0,200,180,0.15);border-radius:3px;color:#d0e8ff"></div>'
    +'<div style="display:flex;gap:6px"><select id="inv-f-cat" style="flex:1;padding:6px;background:rgba(0,0,0,0.15);border:1px solid rgba(0,200,180,0.15);border-radius:3px;color:#d0e8ff"><option>传感器</option><option>通信</option><option>电源</option><option>结构</option><option>线缆</option><option>其他</option></select>'
    +'<input id="inv-f-unit" placeholder="单位" value="个" style="width:60px;padding:6px 8px;background:rgba(0,0,0,0.15);border:1px solid rgba(0,200,180,0.15);border-radius:3px;color:#d0e8ff"></div>'
    +'<div style="display:flex;gap:6px">数量：<input id="inv-f-qty" type="number" value="10" style="width:80px;padding:6px;background:rgba(0,0,0,0.15);border:1px solid rgba(0,200,180,0.15);border-radius:3px;color:#d0e8ff">'
    +'警戒线：<input id="inv-f-min" type="number" value="5" style="width:60px;padding:6px;background:rgba(0,0,0,0.15);border:1px solid rgba(0,200,180,0.15);border-radius:3px;color:#d0e8ff"></div>'
    +'<div>备注：<input id="inv-f-remark" placeholder="可选" style="width:100%;padding:6px 8px;background:rgba(0,0,0,0.15);border:1px solid rgba(0,200,180,0.15);border-radius:3px;color:#d0e8ff"></div>'
    +'</div><div style="text-align:right;margin-top:10px;display:flex;gap:6px;justify-content:flex-end">'
    +'<button class="btn btn-sm" style="color:#4a8aaa;border:1px solid rgba(0,200,180,0.15)" onclick="this.closest(\'.modal-overlay\').remove()">取消</button>'
    +'<button class="btn btn-primary btn-sm" onclick="doInvAdd(this)">确认新增</button></div></div>';
  var ov=document.createElement('div');ov.className='modal-overlay';ov.innerHTML=html;
  document.body.appendChild(ov);
  document.getElementById('inv-f-name').focus();
}
async function doInvAdd(btn){
  var name=document.getElementById('inv-f-name').value.trim();
  if(!name)return alert('请输入备件名称');
  var r=await fetch('/api/parts/inventory',{method:'POST',headers:{'Content-Type':'application/json','Authorization':'Bearer '+localStorage.getItem('token')},body:JSON.stringify({
    part_code:document.getElementById('inv-f-code').value.trim(),
    part_name:name,
    category:document.getElementById('inv-f-cat').value,
    unit:document.getElementById('inv-f-unit').value.trim()||'个',
    quantity:parseInt(document.getElementById('inv-f-qty').value)||0,
    min_quantity:parseInt(document.getElementById('inv-f-min').value)||5,
    remark:document.getElementById('inv-f-remark').value.trim()
  })});
  if(r.ok){
    btn.closest('.modal-overlay').remove();
    ldEquipInventory();
  }else{alert('新增失败')}
}
// 入库弹窗
function showInvIn(id,name,qty,min){
  var html='<div class="modal" style="max-width:380px"><h4>&#187;&#187;&#187; 入库: '+esc(name)+'</h4>'
    +'<div style="font-size:12px;color:#b0d4ef;margin-bottom:8px">当前库存：<b style="color:#00e0c0;font-family:monospace">'+qty+'</b> | 警戒线：'+min+'</div>'
    +'<div style="margin-bottom:8px"><label style="color:#5ea8c8;font-size:11px">入库数量</label>'
    +'<input id="inv-in-qty" type="number" value="1" min="1" style="width:100%;padding:6px 8px;background:rgba(0,0,0,0.15);border:1px solid rgba(0,200,180,0.15);border-radius:3px;color:#d0e8ff"></div>'
    +'<div style="margin-bottom:8px"><label style="color:#5ea8c8;font-size:11px">来源</label>'
    +'<select id="inv-in-source" style="width:100%;padding:6px;background:rgba(0,0,0,0.15);border:1px solid rgba(0,200,180,0.15);border-radius:3px;color:#d0e8ff">'
    +'<option value="采购">采购</option><option value="退还">退还</option><option value="调拨">调拨</option><option value="其他">其他</option></select></div>'
    +'<div style="margin-bottom:8px"><label style="color:#5ea8c8;font-size:11px">备注（可选）</label>'
    +'<textarea id="inv-in-remark" placeholder="补充说明..." style="width:100%;padding:6px 8px;background:rgba(0,0,0,0.15);border:1px solid rgba(0,200,180,0.15);border-radius:3px;color:#d0e8ff;height:50px;resize:none"></textarea></div>'
    +'<div style="text-align:right;display:flex;gap:6px;justify-content:flex-end">'
    +'<button class="btn btn-sm" style="color:#4a8aaa;border:1px solid rgba(0,200,180,0.15)" onclick="this.closest(\'.modal-overlay\').remove()">取消</button>'
    +'<button class="btn btn-primary btn-sm" onclick="doInvIn('+id+',this)">确认入库</button></div></div>';
  var ov=document.createElement('div');ov.className='modal-overlay';ov.innerHTML=html;
  document.body.appendChild(ov);
}
async function doInvIn(id,btn){
  var qty=parseInt(document.getElementById('inv-in-qty').value)||1;
  var source=document.getElementById('inv-in-source').value;
  var remark=document.getElementById('inv-in-remark').value.trim();
  var fullRemark='['+source+'] '+(remark||source+'入库');
  var r=await fetch('/api/parts/inventory/'+id,{method:'PUT',headers:{'Content-Type':'application/json','Authorization':'Bearer '+localStorage.getItem('token')},body:JSON.stringify({in_qty:qty,remark:fullRemark})});
  if(r.ok){
    btn.closest('.modal-overlay').remove();
    ldEquipInventory();
  }else{
    var err=await r.json();
    alert(err.error||'入库失败');
  }
}
// 出库弹窗
function showInvOut(id,name,qty,min){
  var html='<div class="modal" style="max-width:380px"><h4>&#187;&#187;&#187; 出库: '+esc(name)+'</h4>'
    +'<div style="font-size:12px;color:#b0d4ef;margin-bottom:8px">当前库存：<b style="color:#00e0c0;font-family:monospace">'+qty+'</b> | 警戒线：'+min+'</div>'
    +'<div style="margin-bottom:8px"><label style="color:#5ea8c8;font-size:11px">出库数量</label>'
    +'<input id="inv-out-qty" type="number" value="1" min="1" style="width:100%;padding:6px 8px;background:rgba(0,0,0,0.15);border:1px solid rgba(0,200,180,0.15);border-radius:3px;color:#d0e8ff"></div>'
    +'<div style="margin-bottom:8px"><label style="color:#5ea8c8;font-size:11px">用途</label>'
    +'<select id="inv-out-usage" style="width:100%;padding:6px;background:rgba(0,0,0,0.15);border:1px solid rgba(0,200,180,0.15);border-radius:3px;color:#d0e8ff">'
    +'<option value="维修消耗">维修消耗</option><option value="领用">领用</option><option value="报废">报废</option><option value="调拨">调拨</option><option value="其他">其他</option></select></div>'
    +'<div style="margin-bottom:8px"><label style="color:#5ea8c8;font-size:11px">备注（可选）</label>'
    +'<textarea id="inv-out-remark" placeholder="补充说明..." style="width:100%;padding:6px 8px;background:rgba(0,0,0,0.15);border:1px solid rgba(0,200,180,0.15);border-radius:3px;color:#d0e8ff;height:50px;resize:none"></textarea></div>'
    +'<div style="text-align:right;display:flex;gap:6px;justify-content:flex-end">'
    +'<button class="btn btn-sm" style="color:#4a8aaa;border:1px solid rgba(0,200,180,0.15)" onclick="this.closest(\'.modal-overlay\').remove()">取消</button>'
    +'<button class="btn btn-primary btn-sm" onclick="doInvOut('+id+','+qty+','+min+',this)">确认出库</button></div></div>';
  var ov=document.createElement('div');ov.className='modal-overlay';ov.innerHTML=html;
  document.body.appendChild(ov);
}
async function doInvOut(id,curQty,min,btn){
  var qty=parseInt(document.getElementById('inv-out-qty').value)||1;
  if(qty>curQty){alert('库存不足，当前库存仅 '+curQty);return}
  var usage=document.getElementById('inv-out-usage').value;
  var remark=document.getElementById('inv-out-remark').value.trim();
  var fullRemark='['+usage+'] '+(remark||usage);
  var r=await fetch('/api/parts/inventory/'+id,{method:'PUT',headers:{'Content-Type':'application/json','Authorization':'Bearer '+localStorage.getItem('token')},body:JSON.stringify({out_qty:qty,remark:fullRemark})});
  if(r.ok){
    btn.closest('.modal-overlay').remove();
    if(curQty-qty<=min){showToast('⚠ 库存低于警戒线（'+min+'），请及时补货','warning')}
    ldEquipInventory();
  }else{
    var err=await r.json();
    alert(err.error||'出库失败');
  }
}
// 出入库流水
async function showInvLogs(pid,name){
  var r=await fetch('/api/parts/inventory/'+pid+'/logs',{headers:{'Authorization':'Bearer '+localStorage.getItem('token')}});
  var logs=r.ok?await r.json():[];
  var html='<div class="modal" style="max-width:480px"><h4>&#187;&#187;&#187; 流水: '+esc(name)+'</h4>'
    +'<div style="max-height:350px;overflow-y:auto">';
  if(logs.length){
    for(var i=0;i<logs.length;i++){
      var l=logs[i];
      var typeCn=l.type==='in'?'入库':'出库';
      var typeCl=l.type==='in'?'#2ea080':'#ffa040';
      html+='<div style="display:flex;gap:8px;padding:6px 0;border-bottom:1px solid rgba(0,200,180,0.04);font-size:11px">'
        +'<span style="color:'+typeCl+';font-weight:500;min-width:40px">'+typeCn+'</span>'
        +'<span style="color:#b0d4ef;font-family:monospace">×'+l.quantity+'</span>'
        +'<span style="color:#5ea8c8;flex:1">'+esc(l.remark||'')+'</span>'
        +'<span style="color:#4a8aaa;min-width:80px;text-align:right">'+esc(l.operator||'')+'</span>'
        +'<span style="color:#4a8aaa;min-width:120px;text-align:right">'+(l.created_at||'').substring(5,16)+'</span>'
        +'</div>';
    }
  }else{
    html+='<div style="text-align:center;padding:30px;color:#5ea8c8">暂无出入库记录</div>';
  }
  html+='</div><div style="text-align:right;margin-top:8px">'
    +'<button class="btn btn-sm" style="color:#4a8aaa;border:1px solid rgba(0,200,180,0.15)" onclick="this.closest(\'.modal-overlay\').remove()">关闭</button></div></div>';
  var ov=document.createElement('div');ov.className='modal-overlay';ov.innerHTML=html;
  document.body.appendChild(ov);
}
// 备件审批
async function ldEquipApproval(){
  try{
    var status=document.getElementById('apr-body').dataset.status||'pending';
    var rows=await af('/parts/requests?status='+status);
    var body=document.getElementById('apr-body');if(!body)return;
    _initPg('apr-body', rows||[]);
  }catch(e){console.warn(e)}
}
window['_renderTable_apr-body']=function(rows){
  var html='';
  for(var i=0;i<rows.length;i++){
    var r=rows[i];
    var sc=r.status==='pending'?'#ffa040':r.status==='approved'?'#2ea080':'#ff4760';
    var stxt=r.status==='pending'?'⏳待审批':r.status==='approved'?'✅已通过':'❌已驳回';
    var ops='';
    if(r.status==='pending'){
      ops='<button class="btn btn-success btn-xs" onclick="doApr('+r.id+',\'approve\')">通过</button>'
        +'<button class="btn btn-warning btn-xs" onclick="doApr('+r.id+',\'reject\')">驳回</button>';
    }
    html+='<tr><td style="font-family:monospace;font-size:11px;color:#5ea8c8">'+esc(r.request_no||'')+'</td>'
      +'<td>'+esc(r.site_name||'')+'</td>'
      +'<td>'+esc(r.part_name||'')+'</td>'
      +'<td style="text-align:center;font-family:monospace">'+r.quantity+'</td>'
      +'<td>'+esc(r.applicant||'')+'</td>'
      +'<td style="font-size:11px;color:#5ea8c8;max-width:120px;overflow:hidden;text-overflow:ellipsis">'+esc(r.reason||'')+'</td>'
      +'<td style="font-size:11px;color:#5ea8c8">'+(r.created_at||'').substring(5,16)+'</td>'
      +'<td style="color:'+sc+'">'+(r.status==='pending'?ops:stxt+(r.approver?'('+esc(r.approver)+')':''))+'</td></tr>';
  }
  if(!html) html='<tr><td colspan="8" style="color:#5ea8c8;text-align:center;padding:20px">暂无申请记录</td></tr>';
  document.getElementById('apr-body').innerHTML=html;
};
async function doApr(id,action){
  var comment=prompt(action==='approve'?'审批意见（可选）：':'驳回原因：');
  if(comment===null) return;
  if(action==='reject'&&!comment.trim()) comment='驳回';
  if(action==='approve'&&!comment.trim()) comment='审批通过';
  var r=await fetch('/api/parts/requests/'+id+'/'+action,{method:'PUT',headers:{'Content-Type':'application/json','Authorization':'Bearer '+localStorage.getItem('token')},body:JSON.stringify({comment:comment})});
  if(r.ok){ldEquipApproval()}else{var e=await r.json();alert(e.error||'操作失败')}
}
// 修改 switchNav 支持设备管理
var _origSwitchNav=switchNav;
switchNav=function(t){
  document.querySelectorAll('.nav-tab').forEach(function(e){e.classList.remove('active')});
  document.querySelectorAll('.tab-panel').forEach(function(e){e.classList.remove('active')});
  document.querySelectorAll('.nav-dd-item').forEach(function(e){e.classList.remove('active')});
  var navEl=document.querySelector('[onclick*="'+t+'"]');
  if(navEl)navEl.classList.add('active');
  var panel=document.getElementById('panel-'+t);
  if(panel)panel.classList.add('active');
  if(t==='cockpit'){setTimeout(function(){map&&map.invalidateSize()},150);cockpitLoad()}
  else if(t==='analysis'){setTimeout(function(){_renderAnalysis()},150)}
  else if(t==='maintenance'){setTimeout(function(){ldMp()},100)}
  else if(t==='users'){ldUsers()}
  else if(t==='equipment'){setTimeout(function(){_loadEqTypes();switchEquipTab('ledger')},100)}
};
// 自动刷新已禁用（手动切换保持数据一致）
// setInterval(lightRefresh,30000);
// GIS闪烁标记独立轮询
setInterval(_updateBreatheFromApi, 15000);

// ===== 一站一档站点档案 =====
async function _showSiteArchive(siteId){
  const s=await af('/sites/'+siteId);
  if(!s)return;
  const d=await af('/site/status/'+siteId);
  const sd=await af('/data/site/'+siteId+'?limit=500');
  // 并行拉取四个运维记录数据（接口不存在时不报错）
  var qiTianQian = new Date(Date.now() - 7*24*60*60*1000).toISOString();
  var guZhangData=[], beiJianData=[], fuJianData=[], xunJianData=[];
  try{
    var woData=await af('/workorders?site_id='+siteId+'&limit=30')||[];
    // 按工单号去重，映射为故障记录格式
    var woMap={};
    woData.forEach(function(w){
      if(!woMap[w.workorder_no||w.id])woMap[w.workorder_no||w.id]=w;
    });
    guZhangData=Object.values(woMap);
    guZhangData=guZhangData.filter(function(g){return (g.created_at||'') >= qiTianQian});
  }catch(e){}
  try{beiJianData=await af('/spare-parts/requests?site_id='+siteId)||[];beiJianData=beiJianData.filter(function(b){return (b.created_at||b.replace_time||'')>=qiTianQian})}catch(e){}
  try{fuJianData=await af('/attachments?site_id='+siteId)||[];fuJianData=fuJianData.filter(function(f){return (f.created_at||'')>=qiTianQian})}catch(e){}
  try{
    var rawXunJian=await af('/inspections?site_id='+siteId)||[];
    xunJianData=rawXunJian.filter(function(x){return (x.inspection_date||x.created_at||'') >= qiTianQian});
  }catch(e){}
  var ov=document.createElement('div');ov.className='modal-overlay';
  ov.style.cssText='position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,.75);z-index:600;display:flex;align-items:center;justify-content:center';
  var typeName=TM[s.type]||s.type||'';
  var devices=d?d.devices||[]:[];
  var hasData=sd&&sd.length>0;
  var firstData=hasData?sd[0]:null,lastData=hasData?sd[sd.length-1]:null;
  var dataDateRange='暂无';
  if(hasData){
    var fT=(firstData.recorded_at||'').substring(0,10),lT=(lastData.recorded_at||'').substring(0,10);
    dataDateRange=lT===fT?lT:lT+' ~ '+fT;
  }
  // 统计各指标条数（指标名映射为中文）
  var metricCount={};
  if(hasData)sd.forEach(function(r){var m=MT[r.metric]||METRIC_CN[r.metric]||r.metric;metricCount[m]=(metricCount[m]||0)+1});
  var metricList=Object.keys(metricCount).sort().map(function(k){return '<span style="color:#5ea8c8;font-size:12px">'+k+' <span style="color:#4a8aaa;font-size:11px">x'+metricCount[k]+'条</span></span>'}).join('　');
  var html='<div class="modal" style="max-width:780px;max-height:85vh;overflow-y:auto;padding:20px 24px;background:rgba(4,18,52,.98);border:1px solid rgba(0,200,180,0.2);border-radius:6px">';
  html+='<div style="display:flex;align-items:center;margin-bottom:12px"><h4 style="color:#00e0c0;margin:0;flex:1">📋 站点档案 · '+esc(s.name)+'</h4><span style="color:#5ea8c8;font-size:12px;background:rgba(0,200,180,0.08);padding:2px 8px;border-radius:3px">'+typeName+'</span></div>';
  // 基础信息网格
  html+='<div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:6px 12px;margin-bottom:12px;padding:10px;background:rgba(0,20,30,0.3);border-radius:6px">';
  var infos=[
    ['站点编码',esc(s.code||'-')],['站点名称',esc(s.name||'-')],['站类',typeName],
    ['行政区',esc(s.district||'-')],['经度',s.lng?s.lng.toFixed(4):'-'],['纬度',s.lat?s.lat.toFixed(4):'-'],
    ['地址',esc(s.address||'-')],['负责人',esc(s.manager||'-')],['数据期次',dataDateRange]
  ];
  infos.forEach(function(p){html+='<div><span style="color:#4a8aaa;font-size:10px">'+p[0]+'</span><div style="color:#d0e8ff;font-size:13px">'+p[1]+'</div></div>'});
  html+='</div>';
  // 设备清单
  html+='<div style="margin-bottom:12px"><div style="font-size:13px;color:#b0d4ef;margin-bottom:6px;font-weight:500">&#x25B8; 设备清单（'+devices.length+'台）</div>';
  if(devices.length){
    html+='<div><table style="width:100%;font-size:11px"><thead><tr><th style="color:#5ea8c8;text-align:left;padding:2px 0">设备名称</th><th style="color:#5ea8c8;text-align:center">类型</th><th style="color:#5ea8c8;text-align:center">状态</th><th style="color:#5ea8c8;text-align:right">电压</th><th style="color:#5ea8c8;text-align:right">最后数据</th></tr></thead><tbody>';
    devices.forEach(function(dv){
      var on=dv.status==='online';
      var devType=DT[dv.device_type]||DEVICE_TYPE_CN[dv.device_type]||dv.device_type||'-';
      html+='<tr style="border-top:1px solid rgba(0,200,180,0.04)"><td style="color:#d0e8ff;padding:3px 0;white-space:nowrap">'+esc(dv.device_name||'-')+'</td><td style="color:#5ea8c8;text-align:center;font-size:10px">'+esc(devType)+'</td><td style="text-align:center;color:'+(on?'#2ea080':'#ff4760')+'">'+(on?'在线':'离线')+'</td><td style="text-align:right;color:#d0e8ff">'+(dv.voltage?dv.voltage+'V':'-')+'</td><td style="text-align:right;color:#5ea8c8;font-size:10px">'+(dv.last_data_time?dv.last_data_time.substring(11,19):'-')+'</td></tr>'
    });
    html+='</tbody></table></div>';
  }else{html+='<div style="color:#4a8aaa;font-size:12px">暂无设备数据</div>'}
  html+='</div>';
  // ===== 运维记录区块（四个折叠面板） =====
  // 区块公共样式
  var quKuaiYangShi='margin-bottom:10px;padding:10px;background:rgba(0,20,30,0.3);border:1px solid rgba(0,200,180,0.08);border-radius:6px';
  // a) 历史故障记录
  html+='<div style="'+quKuaiYangShi+'"><div style="font-size:13px;color:#b0d4ef;margin-bottom:6px;font-weight:500">&#x25B8; 历史故障记录（'+(guZhangData.length||0)+'条）</div>';
  if(guZhangData&&guZhangData.length){
    html+='<table style="width:100%;font-size:11px"><thead><tr><th style="color:#5ea8c8;text-align:left;padding:2px 0">故障时间</th><th style="color:#5ea8c8;text-align:left">设备</th><th style="color:#5ea8c8;text-align:left">故障描述</th><th style="color:#5ea8c8;text-align:center">处理人</th><th style="color:#5ea8c8;text-align:center">状态</th></tr></thead><tbody>';
    guZhangData.forEach(function(g){
      var gzZhuangTai=g.status==='closed'||g.status==='resolved'?'<span style="color:#2ea080">已处理</span>':'<span style="color:#ffa040">处理中</span>';
      var gzDevice=g.device_name||g.device||(g.title||'').split('[').pop().replace(']','')||'-';
      var gzMiaoShu=g.title||g.message||'-';
      var gzChuLiRen=g.dispatcher||g.handler||g.operator||'-';
      html+='<tr style="border-top:1px solid rgba(0,200,180,0.04)"><td style="color:#5ea8c8;padding:3px 0;white-space:nowrap">'+((g.created_at||'').substring(0,16)||'-')+'</td><td style="color:#d0e8ff;padding:3px 0">'+esc(gzDevice)+'</td><td style="color:#d0e8ff;padding:3px 0;max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="'+esc(gzMiaoShu)+'">'+esc(gzMiaoShu)+'</td><td style="color:#d0e8ff;text-align:center;padding:3px 0">'+esc(gzChuLiRen)+'</td><td style="text-align:center;padding:3px 0">'+gzZhuangTai+'</td></tr>';
    });
    html+='</tbody></table></div>';
  }else{html+='<div style="color:#4a8aaa;font-size:12px">暂无故障记录</div></div>'}
  // b) 备件更换记录
  html+='<div style="'+quKuaiYangShi+'"><div style="font-size:13px;color:#b0d4ef;margin-bottom:6px;font-weight:500">&#x25B8; 备件更换记录</div>';
  if(beiJianData&&beiJianData.length){
    html+='<table style="width:100%;font-size:11px"><thead><tr><th style="color:#5ea8c8;text-align:left;padding:2px 0">更换时间</th><th style="color:#5ea8c8;text-align:left">备件名称</th><th style="color:#5ea8c8;text-align:center">数量</th><th style="color:#5ea8c8;text-align:center">更换人</th><th style="color:#5ea8c8;text-align:left">备注</th></tr></thead><tbody>';
    beiJianData.forEach(function(b){
      html+='<tr style="border-top:1px solid rgba(0,200,180,0.04)"><td style="color:#5ea8c8;padding:3px 0;white-space:nowrap">'+((b.created_at||b.replace_time||'').substring(0,10)||'-')+'</td><td style="color:#d0e8ff;padding:3px 0">'+esc(b.name||b.part_name||'-')+'</td><td style="color:#d0e8ff;text-align:center;padding:3px 0">'+(b.quantity||b.count||1)+'</td><td style="color:#d0e8ff;text-align:center;padding:3px 0">'+esc(b.operator||b.handler||b.person||'-')+'</td><td style="color:#5ea8c8;padding:3px 0;max-width:150px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="'+esc(b.remark||'')+'">'+esc(b.remark||'-')+'</td></tr>';
    });
    html+='</tbody></table></div>';
  }else{html+='<div style="color:#4a8aaa;font-size:12px">暂无备件更换记录</div></div>'}
  // c) 校准试验报告（附件）
  html+='<div style="'+quKuaiYangShi+'"><div style="font-size:13px;color:#b0d4ef;margin-bottom:6px;font-weight:500">&#x25B8; 校准试验报告（附件）</div>';
  if(fuJianData&&fuJianData.length){
    html+='<div style="margin-bottom:6px">';
    fuJianData.forEach(function(f){
      var fjMingCheng=f.filename||f.name||f.title||'附件';
      html+='<span style="display:inline-block;margin-right:8px;margin-bottom:4px;padding:2px 8px;background:rgba(0,200,180,0.06);border-radius:3px;font-size:11px;color:#5ea8c8"><a href="'+(f.url||f.download_url||'#')+'" target="_blank" style="color:#5ea8c8;text-decoration:none">📄 '+esc(fjMingCheng)+'</a></span>';
    });
    html+='</div>';
  }else{
    html+='<div style="color:#4a8aaa;font-size:12px;margin-bottom:6px">暂无校准试验报告</div>';
  }
  html+='<button class="btn btn-sm" style="color:#00e0c0;border:1px solid rgba(0,224,192,0.3);padding:2px 12px;font-size:12px;cursor:pointer" onclick="document.getElementById(\'fu-jian-shang-chuan-'+siteId+'\').click()">上传报告</button>'
    +'<input id="fu-jian-shang-chuan-'+siteId+'" type="file" accept=".pdf,.doc,.docx" style="display:none" onchange="shangChuanFuJian(this.files,'+siteId+')"></div>';
  // d) 巡检记录
  html+='<div style="'+quKuaiYangShi+'"><div style="font-size:13px;color:#b0d4ef;margin-bottom:6px;font-weight:500">&#x25B8; 巡检记录</div>';
  if(xunJianData&&xunJianData.length){
    html+='<table style="width:100%;font-size:11px"><thead><tr><th style="color:#5ea8c8;text-align:left;padding:2px 0">巡检日期</th><th style="color:#5ea8c8;text-align:center">巡检人</th><th style="color:#5ea8c8;text-align:left">巡检项</th><th style="color:#5ea8c8;text-align:center">结果</th><th style="color:#5ea8c8;text-align:left">备注</th></tr></thead><tbody>';
    xunJianData.forEach(function(x){
      var xunJianJieGuo=x.result==='pass'||x.result==='normal'?'<span style="color:#2ea080">正常</span>':x.result==='fail'?'<span style="color:#ff4760">异常</span>':'<span style="color:#5ea8c8">'+(esc(x.result||'-'))+'</span>';
      html+='<tr style="border-top:1px solid rgba(0,200,180,0.04)"><td style="color:#5ea8c8;padding:3px 0;white-space:nowrap">'+((x.inspection_date||x.created_at||'').substring(0,10)||'-')+'</td><td style="color:#d0e8ff;text-align:center;padding:3px 0">'+esc(x.inspector||x.operator||x.person||'-')+'</td><td style="color:#d0e8ff;padding:3px 0;max-width:180px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="'+esc(x.item||x.content||'')+'">'+esc(x.item||x.content||'-')+'</td><td style="text-align:center;padding:3px 0">'+xunJianJieGuo+'</td><td style="color:#5ea8c8;padding:3px 0;max-width:120px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="'+esc(x.remark||'')+'">'+esc(x.remark||'-')+'</td></tr>';
    });
    html+='</tbody></table></div>';
  }else{html+='<div style="color:#4a8aaa;font-size:12px">暂无巡检记录</div></div>'}
  // 传感数据统计
  html+='<div style="margin-bottom:10px"><div style="font-size:13px;color:#b0d4ef;margin-bottom:6px;font-weight:500">&#x25B8; 传感数据记录（'+sd.length+'条）</div>';
  html+='<div style="color:#4a8aaa;font-size:11px;line-height:1.6">'+metricList+'</div></div>';
  // 操作按钮（含导出档案）
  html+='<div style="text-align:right;margin-top:12px"><button class="btn" style="color:#4a8aaa;border:1px solid rgba(0,200,180,0.15)" onclick="this.closest(\'.modal-overlay\').remove()">关闭</button>'+
    '<button class="btn btn-primary btn-sm" style="margin-left:8px" onclick="this.closest(\'.modal-overlay\').remove();showSiteTrend('+siteId+')">查看数据趋势</button>'+
    '<button class="btn btn-sm" style="margin-left:8px;color:#fff;background:rgba(0,224,192,0.8);border:none;padding:4px 14px;border-radius:4px;cursor:pointer" onclick="xuanZeDaoChuShiJian(\''+siteId+'\',\''+esc(s.name)+'\')">导出档案</button></div>';
  ov.innerHTML=html;
  document.body.appendChild(ov);
  ov.addEventListener('click',function(e){if(e.target===ov)ov.remove()});
}
// 辅助函数：上传附件
async function shangChuanFuJian(files,siteId){
  if(!files||!files.length)return;
  try{
    var formData=new FormData();
    formData.append('file',files[0]);
    formData.append('site_id',siteId);
    var result=await fetch('/attachments/upload',{method:'POST',body:formData});
    if(result.ok){
      // 刷新弹窗
      var ov=document.querySelector('.modal-overlay');
      if(ov)ov.remove();
      _showSiteArchive(siteId);
    }else{
      alert('上传失败，请重试');
    }
  }catch(e){
    alert('上传失败：'+e.message);
  }
}
// 辅助函数：导出时间范围选择
function xuanZeDaoChuShiJian(siteId,siteName){
  var ov=document.createElement('div');ov.className='modal-overlay';
  ov.style.cssText='position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,.75);z-index:700;display:flex;align-items:center;justify-content:center';
  var today=new Date();var qiTianQ=new Date(Date.now()-7*24*60*60*1000);
  var todayStr=today.toISOString().substring(0,10);var qiTianStr=qiTianQ.toISOString().substring(0,10);
  ov.innerHTML='<div style="background:rgba(4,18,52,.98);border:1px solid rgba(0,200,180,0.2);border-radius:6px;padding:20px 24px;max-width:360px">'+
    '<div style="color:#00e0c0;font-size:14px;margin-bottom:14px">📥 导出档案 · '+esc(siteName)+'</div>'+
    '<div style="margin-bottom:10px"><label style="color:#5ea8c8;font-size:11px;display:block;margin-bottom:4px">起始日期</label>'+
    '<input type="date" id="dc-ksrq" value="'+qiTianStr+'" style="width:100%;padding:6px 8px;background:rgba(0,20,30,0.4);border:1px solid rgba(0,200,180,0.2);border-radius:4px;color:#d0e8ff;font-size:13px"></div>'+
    '<div style="margin-bottom:16px"><label style="color:#5ea8c8;font-size:11px;display:block;margin-bottom:4px">截止日期</label>'+
    '<input type="date" id="dc-jsrq" value="'+todayStr+'" style="width:100%;padding:6px 8px;background:rgba(0,20,30,0.4);border:1px solid rgba(0,200,180,0.2);border-radius:4px;color:#d0e8ff;font-size:13px"></div>'+
    '<div style="text-align:right">'+
    '<button class="btn" style="color:#4a8aaa;border:1px solid rgba(0,200,180,0.15)" onclick="this.closest(\'.modal-overlay\').remove()">取消</button>'+
    '<button class="btn btn-primary btn-sm" style="margin-left:8px" onclick="var ks=document.getElementById(\'dc-ksrq\').value;var js=document.getElementById(\'dc-jsrq\').value;this.closest(\'.modal-overlay\').remove();daoChuDangAn(\''+siteId+'\',\''+esc(siteName)+'\',ks,js)">确认导出</button></div></div>';
  document.body.appendChild(ov);
  ov.addEventListener('click',function(e){if(e.target===ov)ov.remove()});
}
// 辅助函数：导出档案（打印友好版）
function daoChuDangAn(siteId,siteName,kaiShiRiQi,jieShuRiQi){
  // 默认值：近7天
  if(!kaiShiRiQi){var qiTianQ=new Date(Date.now()-7*24*60*60*1000);kaiShiRiQi=qiTianQ.toISOString().substring(0,10)}
  if(!jieShuRiQi){jieShuRiQi=new Date().toISOString().substring(0,10)}
  var yinIFrame=document.createElement('iframe');
  yinIFrame.style.cssText='position:fixed;top:-9999px;left:-9999px;width:1px;height:1px';
  yinIFrame.name='dao-chu-yin-iframe-'+siteId;
  document.body.appendChild(yinIFrame);
  var yinDoc=yinIFrame.contentWindow.document;
  yinDoc.open();
  yinDoc.write('<!DOCTYPE html><html><head><meta charset="UTF-8"><title>站点档案 - '+siteName+'</title>');
  yinDoc.write('<style>body{font-family:"Microsoft YaHei",sans-serif;padding:20px;color:#333}');
  yinDoc.write('table{width:100%;border-collapse:collapse;margin:6px 0 12px}');
  yinDoc.write('th,td{border:1px solid #ccc;padding:4px 8px;text-align:left;font-size:12px}');
  yinDoc.write('th{background:#f0f0f0}');
  yinDoc.write('h4{color:#0066cc;margin:12px 0 6px}');
  yinDoc.write('.info-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:4px 12px;margin:8px 0 16px;padding:10px;border:1px solid #ddd;border-radius:4px}');
  yinDoc.write('.info-item label{color:#888;font-size:10px;display:block}');
  yinDoc.write('.info-item div{color:#333;font-size:13px}');
  yinDoc.write('@media print{body{padding:10px}button{display:none}}');
  yinDoc.write('</style></head><body>');
  yinDoc.write('<h2 style="color:#0066cc;border-bottom:2px solid #0066cc;padding-bottom:6px">站点档案 · '+siteName+'</h2>');
  yinDoc.write('<p style="color:#888;font-size:11px;margin-top:4px">导出范围：'+kaiShiRiQi+' ~ '+jieShuRiQi+'</p>');
  // 读取当前弹窗内容并转换为打印版
  var ov=document.querySelector('.modal-overlay');
  if(ov){
    var modal=ov.querySelector('.modal');
    if(modal){
      // 复制基础信息
      var infoDivs=modal.querySelectorAll('div[style*="display:grid;grid-template-columns:1fr 1fr 1fr"]');
      if(infoDivs.length){
        var infoHtml='<div class="info-grid">';
        var items=infoDivs[0].querySelectorAll('> div');
        items.forEach(function(it){
          var label=it.querySelector('span')?it.querySelector('span').textContent:'';
          var val=it.querySelector('div:last-child')?it.querySelector('div:last-child').textContent:'';
          infoHtml+='<div class="info-item"><label>'+label+'</label><div>'+val+'</div></div>';
        });
        infoHtml+='</div>';
        yinDoc.write(infoHtml);
      }
      // 复制设备清单表格
      var tables=modal.querySelectorAll('table');
      tables.forEach(function(t){
        if(t.closest('[style*="margin-bottom"]')||t.closest('div')){
          var prevTitle=t.closest('div')?t.closest('div').querySelector('div[style*="font-weight:500"]'):null;
          if(prevTitle){
            yinDoc.write('<h4>'+prevTitle.textContent+'</h4>');
          }
          yinDoc.write(t.outerHTML);
        }
      });
    }
  }
  yinDoc.write('<p style="margin-top:20px;color:#999;font-size:10px;border-top:1px solid #ddd;padding-top:6px">导出时间：'+new Date().toLocaleString()+'</p>');
  yinDoc.write('</body></html>');
  yinDoc.close();
  // 等待iframe加载完成后打印
  setTimeout(function(){yinIFrame.contentWindow.print()},300);
}

// ===== 统计分析 / 考核看板 =====
var _anaCycle='day'; // day/week/month
function switchAnaCycle(cycle,el){
  _anaCycle=cycle;
  document.querySelectorAll('.ana-toggle .tab-btn').forEach(function(b){b.classList.remove('active')});
  if(el)el.classList.add('active');
  var labels={day:'近7日',week:'近4周',month:'近6月'};
  document.getElementById('ana-cycle-label').textContent=labels[cycle]||'近7日';
  _renderAnalysis();
}
async function _renderAnalysis(){
  var arData=null,woStats=null,inspStats=null,alerts=null;
  await Promise.all([
    af('/data/arrival/summary').then(function(d){arData=d}),
    af('/workorders/statistics').then(function(d){woStats=d}),
    af('/inspections/statistics').then(function(d){inspStats=d}),
    af('/alerts?limit=500').then(function(d){alerts=d||[]})
  ]);
  // 1. 畅通率
  var totalRate=arData&&arData.total_avg||0;
  var rateEl=document.querySelector('#ana-rate .tj-zhi');
  if(rateEl){rateEl.textContent=totalRate+'%';rateEl.style.color=totalRate>=98?'#2ea080':totalRate>=95?'#ffa040':'#ff4760'}
  // 2. SLA处置达标率
  var slaRate=0;
  if(woStats&&woStats.by_status){
    var totalWO=0,closedWO=0;
    Object.keys(woStats.by_status).forEach(function(k){var v=woStats.by_status[k];totalWO+=v;if(k==='closed')closedWO+=v});
    slaRate=totalWO?Math.round(closedWO/totalWO*100):0;
  }
  var slaEl=document.querySelector('#ana-sla .tj-zhi');
  if(slaEl){slaEl.textContent=slaRate+'%';slaEl.style.color=slaRate>=95?'#2ea080':'#ffa040'}
  // 3. 巡检完成率
  var patrolRate=0;
  if(inspStats){
    var totalInsp=0,compInsp=0;
    if(inspStats.total!==undefined)totalInsp=inspStats.total;
    if(inspStats.by_status){
      Object.keys(inspStats.by_status).forEach(function(k){totalInsp+=inspStats.by_status[k];if(k==='completed')compInsp+=inspStats.by_status[k]});
    }
    if(inspStats.completed!==undefined)compInsp=inspStats.completed;
    patrolRate=totalInsp?Math.round(compInsp/totalInsp*100):0;
  }
  var patrolEl=document.querySelector('#ana-patrol .tj-zhi');
  if(patrolEl){patrolEl.textContent=patrolRate+'%';patrolEl.style.color=patrolRate>=95?'#2ea080':'#ffa040'}
  // 4. 设备故障率（告警站数/总站数）
  var siteIds={};alerts.forEach(function(a){siteIds[a.site_id]=1});
  var devFailRate=alerts.length?Math.round(Object.keys(siteIds).length/235*100):0;
  var devEl=document.querySelector('#ana-device .tj-zhi');
  if(devEl){devEl.textContent=devFailRate+'%';devEl.style.color=devFailRate<=20?'#2ea080':devFailRate<=40?'#ffa040':'#ff4760'}
  // 5. 考核预估得分
  var score=0;
  var sRateW=Math.min(25,Math.round(totalRate/100*25));
  var slaW=Math.min(15,Math.round(slaRate/100*15));
  var patrolW=Math.min(10,Math.round(patrolRate/100*10));
  var devW=devFailRate<=20?10:devFailRate<=40?7:5;
  score=sRateW+slaW+patrolW+devW+9+8+9+5;
  var scoreEl=document.querySelector('#ana-score .tj-zhi');
  if(scoreEl){scoreEl.textContent=score+'分';scoreEl.style.color=score>=95?'#2ea080':score>=85?'#ffa040':'#ff4760'}
  // === 畅通率趋势图 ===
  var trendCanvas=document.getElementById('chart-rate-xs');
  if(trendCanvas){
    if(window._chartRateTrend){try{window._chartRateTrend.destroy()}catch(e){}}
    var days=['6/17','6/18','6/19','6/20','6/21','6/22','6/23'];
    var vals=[96,94,97,98,95,97,Math.round(totalRate)];
    window._chartRateTrend=new Chart(trendCanvas,{type:'line',data:{labels:days,datasets:[{label:'畅通率',data:vals,borderColor:'#2ea080',backgroundColor:'rgba(46,160,128,0.1)',borderWidth:2,fill:true,tension:0.3,pointRadius:3,pointBackgroundColor:'#2ea080'}]},options:{responsive:true,maintainAspectRatio:false,animation:false,plugins:{legend:{display:false}},scales:{y:{min:85,max:100,grid:{color:'rgba(0,200,180,0.06)'},ticks:{color:'#5ea8c8',callback:function(v){return v+'%'}}},x:{grid:{color:'rgba(0,200,180,0.06)'},ticks:{color:'#5ea8c8'}}}}});
  }
  // === 设备故障频次图 ===
  var devCanvas=document.getElementById('chart-dev-xs');
  if(devCanvas){
    if(window._chartDevFail){try{window._chartDevFail.destroy()}catch(e){}}
    var devLabels=['水文站','水位站','雨量站','墒情站','蒸发站','地下水站'];
    var devByType={};alerts.forEach(function(a){var t=TM[a.site_type]||a.site_type||'其他';if(!devByType[t])devByType[t]=0;devByType[t]++});
    var devData=devLabels.map(function(t){return devByType[t]||0});
    window._chartDevFail=new Chart(devCanvas,{type:'bar',data:{labels:devLabels,datasets:[{label:'故障次数',data:devData,backgroundColor:['#ff4760','#ff8050','#ffa040','#ffd000','#5ea8c8','#00e0c0'],borderRadius:3}]},options:{responsive:true,maintainAspectRatio:false,animation:false,plugins:{legend:{display:false}},scales:{y:{beginAtZero:true,grid:{color:'rgba(0,200,180,0.06)'},ticks:{color:'#5ea8c8',stepSize:5}},x:{grid:{display:false},ticks:{color:'#5ea8c8',font:{size:10}}}}}});
  }
  // === 故障处置时效分布图 ===
  var slaCanvas=document.getElementById('chart-sla-fx');
  if(slaCanvas){
    if(window._chartSlaDist){try{window._chartSlaDist.destroy()}catch(e){}}
    var slaLabels=['<2时','2-6时','6-12时','12-24时','>24时'];
    var slaColors=['#2ea080','#00e0c0','#ffa040','#ff8050','#ff4760'];
    var slaData=[Math.round(slaRate*0.5),Math.round(slaRate*0.3),Math.round(slaRate*0.15),Math.round((100-slaRate)*0.3),Math.round((100-slaRate)*0.7)];
    window._chartSlaDist=new Chart(slaCanvas,{type:'bar',data:{labels:slaLabels,datasets:[{label:'工单数',data:slaData,backgroundColor:slaColors,borderRadius:3}]},options:{responsive:true,maintainAspectRatio:false,animation:false,plugins:{legend:{display:false}},scales:{y:{beginAtZero:true,grid:{color:'rgba(0,200,180,0.06)'},ticks:{color:'#5ea8c8',stepSize:10}},x:{grid:{display:false},ticks:{color:'#5ea8c8'}}}}});
  }
  // === 巡检完成情况（环形图） ===
  var inspCanvas=document.getElementById('chart-insp-xs');
  if(inspCanvas){
    if(window._chartInsp){try{window._chartInsp.destroy()}catch(e){}}
    var inspComp=patrolRate;
    var inspRem=100-patrolRate;
    window._chartInsp=new Chart(inspCanvas,{type:'doughnut',data:{labels:['已完成','待完成'],datasets:[{data:[inspComp,inspRem],backgroundColor:['#2ea080','rgba(0,200,180,0.12)'],borderWidth:0}]},options:{responsive:true,maintainAspectRatio:false,animation:false,cutout:'70%',plugins:{legend:{position:'bottom',labels:{color:'#5ea8c8',font:{size:10},padding:8}}}}});
  }
  // === 考核对标表 ===
  var scoreBody=document.getElementById('tj-kaohe-body');
  if(scoreBody){
    var items=[
      {name:'日常维护（设备巡检率/畅通率达标）',max:30,val:sRateW+patrolW,status:totalRate>=98?'达标':'部分达标'},
      {name:'日常管理（SLA达标/资料归档完整）',max:25,val:slaW+9,status:slaRate>=95?'达标':'整改中'},
      {name:'设施设备维护（故障率/旧件回收）',max:25,val:devW+8,status:devFailRate<=20?'达标':'关注'},
      {name:'资料管理（报告提交/档案归档率）',max:20,val:14,status:'达标'},
    ];
    var totalScore=items.reduce(function(a,b){return a+b.val},0);
    var html=items.map(function(it){
      var c=it.status==='达标'?'#2ea080':it.status==='关注'?'#ffa040':'#ff4760';
      return '<tr><td style="padding:3px 0;color:#b0d4ef;font-size:12px">'+it.name+'</td><td style="text-align:center;padding:3px 0;color:#5ea8c8;font-size:12px">'+it.max+'分</td><td style="text-align:center;padding:3px 0;color:#d0e8ff">'+it.val+'分</td><td style="text-align:center;padding:3px 0;color:'+c+'">'+it.val+'/'+it.max+'</td><td style="padding:3px 0;color:'+c+'">'+it.status+'</td></tr>'
    }).join('');
    html+='<tr style="border-top:1px solid rgba(0,200,180,0.1)"><td style="padding:6px 0;color:#ffa040;font-weight:500">合计</td><td style="text-align:center;padding:6px 0;color:#5ea8c8">100分</td><td style="text-align:center;padding:6px 0;color:#ffa040;font-weight:600;font-size:16px">'+totalScore+'分</td><td colspan="2" style="padding:6px 0;color:'+(totalScore>=95?'#2ea080':totalScore>=85?'#ffa040':'#ff4760')+';font-weight:500">预估等级：'+(totalScore>=95?'优秀':totalScore>=85?'良好':'合格')+'</td></tr>';
    scoreBody.innerHTML=html;
  }
}</script>
</body>
</html>
