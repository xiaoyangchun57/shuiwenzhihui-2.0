    if(r&&r.success){showToast('告警已消除');document.querySelectorAll('.modal-overlay').forEach(e=>e.remove());ldAl();updateAlertCounters();refreshDashboard()}else{showToast('操作失败'+(r&&r.error?': '+r.error:''),'error')}
  }finally{_alBusy=false;if(btn){btn.disabled=false;btn.textContent='确认消除告警'}}
}
