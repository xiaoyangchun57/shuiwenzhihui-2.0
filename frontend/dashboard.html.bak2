<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>水利智慧运营平台</title>
<link rel="stylesheet" href="lib/leaflet.min.css" />
<script src="lib/leaflet.min.js"></script>
<script src="lib/chart.umd.min.js"></script>
<link rel="stylesheet" href="lib/MarkerCluster.css" />
<link rel="stylesheet" href="lib/MarkerCluster.Default.css" />
<script src="lib/leaflet.markercluster.min.js"></script>
<link rel="stylesheet" href="css/dashboard.css" />
<style>
/* 页面特定样式（较少使用，保留内联） */
</style>
</head>
<body>
<div id="app">
  <div class="viewport-frame"></div>

  <!-- 登录覆盖层（初始显示） -->
  <div class="login-overlay" id="login-overlay">
    <div class="login-card">
      <h2>水利智慧运营平台</h2>
      <div class="lc-sub">请登录系统</div>
      <div class="form-row"><label>用户名</label><input id="login-username" placeholder="请输入用户名" onkeydown="if(event.key==='Enter')doLogin()"></div>
      <div class="form-row"><label>密码</label><input id="login-password" type="password" placeholder="请输入密码" onkeydown="if(event.key==='Enter')doLogin()"></div>
      <div class="lc-err" id="login-err"></div>
      <button class="login-btn" id="login-btn" onclick="doLogin()">登 录</button>
      <div style="text-align:center;margin-top:16px;font-size:10px;color:#4a8aaa">请联系管理员获取账号信息</div>
    </div>
  </div>

  <!-- 导航栏 — 无图标、纯文字、发光效果 -->
  <div class="nav-bar">
    <div class="nav-title">水利智慧运营平台</div>
    <div class="nav-tabs">
      <div class="nav-tab active" onclick="switchNav('cockpit')">信息中心</div>
      <div class="nav-tab" onclick="switchNav('sites')">站点管理</div>
      <div class="nav-tab" onclick="switchNav('alerts')">预警中心</div>
      <div class="nav-tab" onclick="switchNav('workorders')">工单管理</div>
      <div class="nav-dropdown" id="nav-more">
        <div class="nav-tab nav-dd-trigger" onclick="toggleNavDD()">运维管理 ▾</div>
        <div class="nav-dd-menu" id="nav-dd-menu">
          <div class="nav-dd-item" onclick="switchNav('maintenance')">巡检计划</div>
          <div class="nav-dd-item" onclick="switchNavDD('equipment')">设备管理</div>
          <div class="nav-dd-item" onclick="switchNav('analysis')">统计分析</div>
          <div class="nav-dd-item" id="nav-dd-users" onclick="switchNav('users')" style="display:none">人员管理</div>
        </div>
      </div>
    </div>
    <div class="nav-stats">
      <div class="nav-stat"><span class="nsn" id="ns-sites">10</span><span class="nsl">站点</span></div>
      <div class="nav-stat"><span class="nsn danger" id="ns-alerts">0</span><span class="nsl">告警</span></div>
      <div class="nav-stat"><span class="nsn warn" id="ns-orders">0</span><span class="nsl">工单</span></div>
    </div>
    <div class="nav-clock" id="nav-clock"></div>
    <div class="nav-user" id="nav-user" style="display:none">
      <span class="nu-name" id="nu-name">--</span>
      <span class="nu-role" id="nu-role">--</span>
      <span class="nu-logout" onclick="doLogout()">退出登录</span>
    </div>
  </div>

  <!-- 内容区 -->
  <div class="content-area">
    <!-- 驾驶舱 -->
    <div class="tab-panel active" id="panel-cockpit">
      <div class="cockpit">
        <div id="map"></div>
    <div class="cockpit-loading" id="cockpit-loading"><div class="sp"></div><span style="margin-left:12px;color:#5ea8c8;font-size:14px">系统加载中...</span></div>
        <div class="map-toolbar">
          <button class="map-tool active" onclick="fitByType(null)">全部</button>
          <button class="map-tool" data-type="rainfall" onclick="fitByType('rainfall')">雨量站</button>
          <button class="map-tool" data-type="water_level" onclick="fitByType('water_level')">水位站</button>
          <button class="map-tool" data-type="hydrology" onclick="fitByType('hydrology')">水文站</button>
          <button class="map-tool" data-type="soil_moisture" onclick="fitByType('soil_moisture')">墒情站</button>
          <button class="map-tool" data-type="evaporation" onclick="fitByType('evaporation')">蒸发站</button>
          <button class="map-tool" data-type="groundwater" onclick="fitByType('groundwater')">地下水站</button>
          <button class="map-tool" data-type="station_yard" onclick="fitByType('station_yard')">站院</button>
          <span style="width:1px;height:16px;background:rgba(0,200,180,0.15);margin:0 4px"></span>
          <span class="map-tool map-search-btn" onclick="toggleSearch()" title="搜索站点"><span class="i i-sm"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg></span></span>
        </div>
        <div class="search-panel" id="search-panel">
          <div style="display:flex;gap:6px;align-items:center;padding:6px 8px;border-bottom:1px solid rgba(0,200,180,0.08)"><span style="color:#00e0c0">搜索站点</span><span style="font-size:10px;color:#5ea8c8">回车跳转</span><span style="margin-left:auto;cursor:pointer;color:#5ea8c8" class="i i-sm" onclick="toggleSearch()"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></span></div>
          <div style="padding:6px 8px"><input id="search-input" class="fi" style="width:100%" placeholder="输入站名或编号..." onkeydown="if(event.key==='Enter'){doSearch(document.getElementById('search-input').value)}" autofocus></div>
          <div id="search-results" style="max-height:200px;overflow-y:auto;font-size:12px;color:#b0d4ef"></div>
        </div>
        <!-- 左 -->
        <div class="panel-left" id="panel-left">
          <div class="pcard" style="flex:2"><div class="hd"><span class="arr">&#187;&#187;&#187;</span><span class="hd-title">站点实时监测</span><span class="hd-badge" id="site-stat-badge"></span></div><div class="bd" id="site-feed"></div></div>
          <div class="pcard" style="flex:1.5" id="pcard-datahealth"><div class="hd"><span class="arr">&#187;&#187;&#187;</span>数据畅通率 <span style="margin-left:auto;font-size:11px;color:#5ea8c8" id="dh-count"></span></div><div class="bd" id="dh-feed"></div></div>
        </div>
        <button class="toggle-btn btn-show-left" onclick="togglePane('left')">隐藏面板</button>
        <!-- 右 -->
        <div class="panel-right" id="panel-right">
          <div class="pcard" style="flex:1.3"><div class="hd"><span class="arr">&#187;&#187;&#187;</span><span style="color:#ff4760">●</span> 实时预警 <span id="alert-trend" style="font-size:10px;color:#5ea8c8;margin-left:6px"></span><span style="margin-left:auto;font-size:11px;color:#ffa040" id="alert-badge"></span></div><div class="bd" id="alert-feed"></div></div>
          <div class="pcard" style="flex:1" id="pcard-devicehealth"><div class="hd"><span class="arr">&#187;&#187;&#187;</span><span style="color:#2ea080">■</span> 设备健康看板 <span style="margin-left:auto;font-size:11px;color:#5ea8c8" id="dh-device-count"></span></div><div class="bd" id="dh-device-feed"></div></div>
          <div class="pcard" style="flex:1.2"><div class="hd"><span class="arr">&#187;&#187;&#187;</span>工单状态 <span id="wo-stat-badge" style="margin-left:auto;font-size:11px;color:#5ea8c8"></span></div><div class="bd"><div class="chart-mini" id="wo-body" style="cursor:pointer" onclick="switchNav('workorders')"><canvas id="chart-wo" style="width:100%;height:160px"></canvas></div></div></div>
        </div>
        <button class="toggle-btn btn-show-right" onclick="togglePane('right')">隐藏面板</button>
        <!-- 图例 -->
        <div class="legend-toggle" onclick="toggleLegend()" id="legend-btn">图例</div>
        <div class="legend-box" id="legend-box">
          <div class="legend-title">站点图例 <span style="float:right;cursor:pointer;color:#5ea8c8" class="i i-sm" onclick="toggleLegend()"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></span></div>
          <div id="legend-body"></div>
        </div>
      </div>
      <div class="bottom-bar">
        <span class="dot" id="bt-dot"></span><span id="bt-status">系统运行中</span><span>|</span><span>更新 <b style="color:#00e0c0" id="bt-time">--</b></span>
      </div>
    </div>

    <!-- 站点 -->
    <div class="tab-panel" id="panel-sites"><div class="mgmt"><div class="card"><div class="card-hd"><span class="arr">&#187;&#187;&#187;</span>站点列表</div><div class="card-body"><div class="filter-bar"><input class="fi" id="st-search" placeholder="搜索名称/编码..." oninput="dldSt()" style="max-width:180px"><select class="fi-s" id="st-flt-type" onchange="ldSt(true)"><option value="">全部类型</option><option value="雨量站">雨量站</option><option value="水位站">水位站</option><option value="水文站">水文站</option><option value="墒情站">墒情站</option><option value="蒸发站">蒸发站</option><option value="地下水站">地下水站</option><option value="站院">站院</option></select><select class="fi-s" id="st-flt-district" onchange="ldSt(true)"><option value="">全部区划</option></select><select class="fi-s" id="st-flt-manager" style="display:none" onchange="ldSt(true)"><option value="">全部负责人</option></select></div><table><thead><tr><th>编码</th><th>名称</th><th>行政区/地址</th><th>类型</th><th>状态</th><th>负责人</th><th style="width:10%;text-align:center">档案</th></tr></thead><tbody id="st-body"></tbody></table></div></div></div></div>
    <!-- 预警 -->
    <div class="tab-panel" id="panel-alerts"><div class="mgmt"><div class="card"><div class="card-hd"><span class="arr">&#187;&#187;&#187;</span>预警管理</div><div class="card-body"><div style="display:flex;gap:8px;padding:4px 0 0;align-items:stretch"><div class="al-metrics" id="al-metrics" style="display:flex;gap:8px;flex:1;flex-wrap:wrap;min-height:60px;align-content:flex-start"></div></div><div class="filter-bar"><input class="fi" placeholder="搜索站点/信息..." oninput="filterTable('al-body',this.value,0);filterTable('al-body',this.value,1)" style="flex:1"><select class="fi-s" id="al-flt-status" onchange="ldAl()"><option value="pending">待处理</option><option value="acknowledged">处理中</option><option value="resolved">已办结</option></select><select class="fi-s" id="al-flt-date" onchange="ldAl()"><option value="">全部时间</option><option value="today">今天</option><option value="week">本周</option><option value="month">本月</option></select><div class="batch-bar" id="al-batch" style="display:none;gap:6px"><span style="color:#5ea8c8;font-size:11px" id="al-sel-cnt">已选0项</span><button class="btn btn-success btn-xs" onclick="batchResolve()">批量办结</button><button class="btn btn-warning btn-xs" onclick="batchAl('urge')">批量督办</button><button class="btn btn-primary btn-xs" onclick="batchAl('convert')">批量转工单</button><button class="btn btn-xs" style="color:#4a8aaa;border:1px solid rgba(0,200,180,0.15)" onclick="clrAlSel()">取消选择</button></div></div><table style="table-layout:fixed"><thead><tr><th style="width:36px"><input type="checkbox" onchange="alSelAll(this.checked)" id="al-cb-all" style="width:16px;height:16px"></th><th style="width:150px">站点 <span style="font-weight:normal;color:#4a8aaa">级别</span></th><th>信息</th><th style="width:120px">状态</th><th style="width:100px;text-align:center">时间</th><th style="width:100px;text-align:center">操作</th></tr></thead><tbody id="al-body"></tbody></table></div></div></div></div>
    <!-- 工单 -->
    <div class="tab-panel" id="panel-workorders"><div class="mgmt"><div class="card"><div class="card-hd"><span class="arr">&#187;&#187;&#187;</span>工单管理</div><div class="card-body"><div class="filter-bar"><input class="fi" placeholder="搜索工单号/标题..." oninput="filterTable('or-body',this.value,0);filterTable('or-body',this.value,4)" style="flex:1"><select class="fi-s" onchange="filterEq('or-body',3,this.value)"><option value="">全部级别</option><option value="一般">一般</option><option value="紧急">紧急</option><option value="重大">重大</option></select><select class="fi-s" onchange="filterEq('or-body',5,this.value)"><option value="">全部状态</option><option value="待受理">待受理</option><option value="已受理">已受理</option><option value="已生成">已生成</option><option value="处置中">处置中</option><option value="已关闭">已关闭</option></select><button class="btn btn-primary btn-sm" onclick="mNew('order')" style="margin-left:auto">+新建</button></div><table><thead><tr><th onclick="sortTable('or-body',0)">工单号 <span class="srt">&#9650;&#9660;</span></th><th onclick="sortTable('or-body',1)">站点 <span class="srt">&#9650;&#9660;</span></th><th>来源</th><th onclick="sortTable('or-body',3)">级别 <span class="srt">&#9650;&#9660;</span></th><th>标题</th><th onclick="sortTable('or-body',5)">状态 <span class="srt">&#9650;&#9660;</span></th><th onclick="sortTable('or-body',6)">负责人 <span class="srt">&#9650;&#9660;</span></th><th onclick="sortTable('or-body',7)">SLA <span class="srt">&#9650;&#9660;</span></th><th>操作</th></tr></thead><tbody id="or-body"></tbody></table></div></div></div></div>
    <!-- 巡检计划（真实巡检 inspection_plans） -->
    <div class="tab-panel" id="panel-maintenance">
      <div class="mgmt"><div class="card">
        <div class="card-hd"><span class="arr">&#187;&#187;&#187;</span>巡检计划</div>
        <div class="card-body">
          <div class="insp-sub-bar" style="display:flex;align-items:center;border-bottom:1px solid rgba(0,200,180,0.08)">
            <div style="display:flex;gap:0;flex:1">
              <div class="tab-btn active" onclick="switchInspTab('plans',this)">巡检计划</div>
              <div class="tab-btn" onclick="switchInspTab('schemes',this)">检查方案</div>
              <div class="tab-btn" onclick="switchInspTab('standards',this)">巡检标准</div>
            </div>
            <button class="btn btn-primary btn-sm" onclick="mNewInsp()" style="flex-shrink:0;margin:4px 4px 4px 8px">+新建巡检计划</button>
          </div>
          <!-- 巡检计划 -->
          <div class="insp-panel" id="insp-plans">
            <div class="filter-bar">
              <input class="fi" id="insp-search" placeholder="搜索计划名称/站点..." oninput="dldMp()" style="flex:1">
              <select class="fi-s" id="insp-status" onchange="ldMp()"><option value="">全部状态</option><option value="pending">待开始</option><option value="in_progress">进行中</option><option value="completed">已完成</option></select>
              <select class="fi-s" id="insp-type" onchange="ldMp()"><option value="">全部周期</option><option value="daily">每日</option><option value="weekly">每周</option><option value="monthly">每月</option></select>
            </div>
            <div style="display:flex;gap:8px;padding:6px 12px;flex-wrap:wrap;font-size:11px" id="insp-stats"></div>
            <div id="insp-list" style="padding:0 12px 12px"></div>
          </div>
          <!-- 检查方案 -->
          <div class="insp-panel" id="insp-schemes" style="display:none">
            <div class="filter-bar">
              <input class="fi" placeholder="搜索站点..." oninput="filterSchemes(this.value)" style="flex:1">
              <button class="btn btn-primary btn-sm" onclick="uploadSchemeImport()">+导入方案</button>
              <button class="btn btn-sm" style="color:#ffa040;border:1px solid rgba(255,160,64,0.25)" onclick="autoGenerateInsp()">📋 生成巡检计划</button>
              <button class="btn btn-sm" style="color:#5ea8c8;border:1px solid rgba(0,200,180,0.15)" onclick="downloadSchemeTemplate()">下载模板</button>
            </div>
            <table><thead><tr><th>站点</th><th>日方案</th><th>周方案</th><th>月方案</th><th>操作</th></tr></thead><tbody id="sch-body"></tbody></table>
          </div>
          <!-- 巡检标准 -->
          <div class="insp-panel" id="insp-standards" style="display:none">
            <div style="padding:12px">
              <div style="font-size:12px;color:#4a8aaa;margin-bottom:10px">以下为智慧运维方案规定的各类站点巡检频次与作业标准，平台据此自动生成巡检计划并管控执行质量。</div>
              <table style="width:100%;font-size:12px;border-collapse:collapse">
                <thead><tr style="border-bottom:1px solid rgba(0,200,180,0.12)"><th style="text-align:left;color:#5ea8c8;padding:6px 0">站类</th><th style="text-align:center;color:#5ea8c8">数量</th><th style="text-align:center;color:#5ea8c8">巡检频次</th><th style="text-align:left;color:#5ea8c8">主要作业内容</th></tr></thead>
                <tbody>
                  <tr style="border-bottom:1px solid rgba(0,200,180,0.04)"><td style="padding:5px 0;color:#d0e8ff">驻测水文站</td><td style="text-align:center;color:#5ea8c8">11</td><td style="text-align:center;color:#00e0c0">每日</td><td style="color:#b0d4ef">每日水位校测、设备运行状态检查、数据传输核验</td></tr>
                  <tr style="border-bottom:1px solid rgba(0,200,180,0.04)"><td style="padding:5px 0;color:#d0e8ff">水位站（带视频）</td><td style="text-align:center;color:#5ea8c8">39</td><td style="text-align:center;color:#00e0c0">每日</td><td style="color:#b0d4ef">每日水位观测、水尺清洁、设备外观检查、数据比对</td></tr>
                  <tr style="border-bottom:1px solid rgba(0,200,180,0.04)"><td style="padding:5px 0;color:#d0e8ff">雨量站</td><td style="text-align:center;color:#5ea8c8">111</td><td style="text-align:center;color:#ffa040">每月1次</td><td style="color:#b0d4ef">每月全面巡检、每季度1次注水试验、设备清洁、数据核验</td></tr>
                  <tr style="border-bottom:1px solid rgba(0,200,180,0.04)"><td style="padding:5px 0;color:#d0e8ff">蒸发站</td><td style="text-align:center;color:#5ea8c8">7</td><td style="text-align:center;color:#ffa040">每月1次</td><td style="color:#b0d4ef">每月巡检、每半年渗漏检查、汛前注水试验、蒸发精度比对</td></tr>
                  <tr style="border-bottom:1px solid rgba(0,200,180,0.04)"><td style="padding:5px 0;color:#d0e8ff">墒情基本站</td><td style="text-align:center;color:#5ea8c8">33</td><td style="text-align:center;color:#5ea8c8">每季度1次</td><td style="color:#b0d4ef">每季度巡查、传感器校测、设备运行状态检查</td></tr>
                  <tr style="border-bottom:1px solid rgba(0,200,180,0.04)"><td style="padding:5px 0;color:#d0e8ff">地下水监测站</td><td style="text-align:center;color:#5ea8c8">21</td><td style="text-align:center;color:#5ea8c8">每月1次</td><td style="color:#b0d4ef">数据校测、设备状态检查、井口维护</td></tr>
                  <tr><td style="padding:5px 0;color:#d0e8ff">站院/观测场</td><td style="text-align:center;color:#5ea8c8">13</td><td style="text-align:center;color:#4a8aaa">按周/月</td><td style="color:#b0d4ef">环境卫生维护、设施设备检查、安全隐患排查</td></tr>
                </tbody>
              </table>
              <div style="margin-top:14px;padding:10px;background:rgba(0,20,30,0.3);border-radius:6px;border-left:3px solid #00e0c0">
                <div style="font-size:13px;color:#00e0c0;margin-bottom:6px;font-weight:500">作业管控要求</div>
                <div style="font-size:11px;color:#5ea8c8;line-height:1.8">
                  ✓ 巡检人员到达站点后GPS定位打卡，确保到岗到位<br>
                  ✓ 按标准化巡检清单逐项检查，漏项无法提交<br>
                  ✓ 巡检中发现故障可一键转工单，无缝衔接处置流程<br>
                  ✓ 支持现场拍照、录像上传，直观记录站点运维状态<br>
                  ✓ 管理人员可实时查看巡检进度、人员轨迹、到位率
                </div>
              </div>
            </div>
          </div>
        </div>
      </div></div>
    </div>
    <!-- 人员管理（管理员专用） -->
    <div class="tab-panel" id="panel-users"><div class="mgmt"><div class="card"><div class="card-hd"><span class="arr">&#187;&#187;&#187;</span>人员管理</div><div class="card-body">
    <div style="padding:4px 0">
      <table><thead><tr><th>用户名</th><th>姓名</th><th>角色</th><th>电话</th><th>分配站点数</th><th>状态</th><th>操作</th></tr></thead><tbody id="users-body"></tbody></table>
    </div></div></div></div></div>
    <!-- 设备管理 -->
    <div class="tab-panel" id="panel-equipment">
      <div class="mgmt"><div class="card">
        <div class="card-hd"><span class="arr">&#187;&#187;&#187;</span>设备管理</div>
        <div class="card-body">
          <div class="equip-tab-bar" style="display:flex;gap:0;border-bottom:1px solid rgba(0,200,180,0.08)">
            <div class="tab-btn active" onclick="switchEquipTab('ledger',this)">设备台账</div>
            <div class="tab-btn" onclick="switchEquipTab('inventory',this)">备件库存</div>
            <div class="tab-btn" onclick="switchEquipTab('approval',this)">备件审批</div>
          </div>
          <!-- 设备台账 -->
          <div class="equip-panel" id="equip-ledger" style="display:block">
            <div class="filter-bar"><input class="fi" id="eq-search" placeholder="搜索设备名称/编码/站点..." oninput="ldEquipLedger()" style="flex:1"><select class="fi-s" id="eq-type" onchange="ldEquipLedger()"><option value="">全部类型</option></select><select class="fi-s" id="eq-status" onchange="ldEquipLedger()"><option value="">全部状态</option><option value="normal">正常</option><option value="low_voltage">电压偏低</option><option value="offline">离线</option></select></div>
            <div style="display:flex;gap:8px;padding:6px 12px;flex-wrap:wrap;font-size:11px" id="eq-stats"></div>
            <table><thead><tr><th style="width:14%">设备编码</th><th style="width:16%">设备名称</th><th style="width:14%">所属站点</th><th style="width:12%">类型</th><th style="width:12%">状态</th><th style="width:8%">电压(V)</th><th style="width:12%">最后数据</th><th style="width:12%">操作</th></tr></thead><tbody id="eq-body"></tbody></table>
          </div>
          <!-- 备件库存 -->
          <div class="equip-panel" id="equip-inventory" style="display:none">
            <div class="filter-bar"><input class="fi" id="inv-search" placeholder="搜索备件名称/编码..." oninput="ldEquipInventory()" style="flex:1"><select class="fi-s" id="inv-cat" onchange="ldEquipInventory()"><option value="">全部分类</option><option value="传感器">传感器</option><option value="通信">通信</option><option value="电源">电源</option><option value="结构">结构</option><option value="线缆">线缆</option><option value="其他">其他</option></select><button class="btn btn-primary btn-sm" onclick="showInvAdd()">+新增备件</button><button class="btn btn-sm" style="color:#ffa040;border:1px solid rgba(255,160,64,0.2)" id="inv-low-btn" onclick="toggleLowFilter()">低库存 ⚠</button></div>
            <div id="inv-warn" style="display:none;padding:4px 12px;font-size:11px;color:#ffa040;background:rgba(255,160,64,0.06)"></div>
            <table><thead><tr><th style="width:13%">编码</th><th style="width:16%">名称</th><th style="width:11%">分类</th><th style="width:8%">库存</th><th style="width:9%">警戒线</th><th style="width:8%">单位</th><th style="width:15%">所属站点</th><th style="width:20%">操作</th></tr></thead><tbody id="inv-body"></tbody></table>
          </div>
          <!-- 备件审批 -->
          <div class="equip-panel" id="equip-approval" style="display:none">
            <div style="display:flex;gap:6px;padding:6px 0">
              <div class="tab-btn active" onclick="switchAprTab('pending',this)" style="font-size:11px;padding:4px 12px">待审批</div>
              <div class="tab-btn" onclick="switchAprTab('approved',this)" style="font-size:11px;padding:4px 12px">已通过</div>
              <div class="tab-btn" onclick="switchAprTab('rejected',this)" style="font-size:11px;padding:4px 12px">已驳回</div>
            </div>
            <table><thead><tr><th style="width:14%">申请编号</th><th style="width:13%">站点</th><th style="width:14%">备件名称</th><th style="width:8%">数量</th><th style="width:10%">申请人</th><th style="width:16%">原因</th><th style="width:13%">时间</th><th style="width:12%">操作</th></tr></thead><tbody id="apr-body"></tbody></table>
          </div>
        </div>
      </div></div>
    </div>
    <!-- 统计分析 -->
        <div class="tab-panel" id="panel-analysis">
      <div class="mgmt"><div class="card">
        <div class="card-hd"><span class="arr">&#187;&#187;&#187;</span>运维统计分析 · 考核对标</div>
        <div class="card-body" id="analysis-body">
          <!-- 统计周期切换 -->
          <div style="display:flex;align-items:center;gap:10px;margin-bottom:12px">
            <div class="ana-toggle" style="display:flex;background:rgba(0,20,30,0.4);border-radius:5px;overflow:hidden;flex-shrink:0">
              <span class="tab-btn active" id="ana-cycle-day" onclick="switchAnaCycle('day',this)" style="font-size:11px;padding:4px 10px">日</span>
              <span class="tab-btn" id="ana-cycle-week" onclick="switchAnaCycle('week',this)" style="font-size:11px;padding:4px 10px">周</span>
              <span class="tab-btn" id="ana-cycle-month" onclick="switchAnaCycle('month',this)" style="font-size:11px;padding:4px 10px">月</span>
            </div>
            <span style="font-size:12px;color:#4a8aaa">统计周期：<b style="color:#5ea8c8" id="ana-cycle-label">近7日</b></span>
          </div>
          <!-- 指标卡（5列） -->
          <div style="display:grid;grid-template-columns:repeat(5,1fr);gap:8px;margin-bottom:14px">
            <div class="tj-ka" id="ana-rate"><div class="tj-zhi" style="color:#2ea080">--</div><div class="tj-biao">数据畅通率</div><div class="tj-shuo">指标≥98%</div></div>
            <div class="tj-ka" id="ana-sla"><div class="tj-zhi" style="color:#ffa040">--</div><div class="tj-biao">SLA处置达标</div><div class="tj-shuo">目标≥95%</div></div>
            <div class="tj-ka" id="ana-patrol"><div class="tj-zhi" style="color:#00e0c0">--</div><div class="tj-biao">巡检完成率</div><div class="tj-shuo">目标100%</div></div>
            <div class="tj-ka" id="ana-device"><div class="tj-zhi" style="color:#ffa040">--</div><div class="tj-biao">设备故障率</div><div class="tj-shuo">按站型统计</div></div>
            <div class="tj-ka" id="ana-score"><div class="tj-zhi" style="color:#b0d4ef">--</div><div class="tj-biao">考核预估得分</div><div class="tj-shuo">百分制</div></div>
          </div>
          <!-- 图表行：畅通率趋势 + 设备故障频次 -->
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:10px">
            <div style="background:rgba(0,20,30,0.3);border-radius:8px;padding:10px;height:190px;display:flex;flex-direction:column"><div style="font-size:12px;color:#5ea8c8;margin-bottom:4px;flex-shrink:0">&#x25B8; 畅通率趋势</div><div style="flex:1;min-height:0;position:relative"><canvas id="chart-rate-xs" style="width:100%;height:100%;position:absolute"></canvas></div></div>
            <div style="background:rgba(0,20,30,0.3);border-radius:8px;padding:10px;height:190px;display:flex;flex-direction:column"><div style="font-size:12px;color:#5ea8c8;margin-bottom:4px;flex-shrink:0">&#x25B8; 设备故障频次（按站型）</div><div style="flex:1;min-height:0;position:relative"><canvas id="chart-dev-xs" style="width:100%;height:100%;position:absolute"></canvas></div></div>
          </div>
          <!-- 图表行：故障时效分布 + 巡检完成 -->
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:12px">
            <div style="background:rgba(0,20,30,0.3);border-radius:8px;padding:10px;height:150px;display:flex;flex-direction:column"><div style="font-size:12px;color:#5ea8c8;margin-bottom:4px;flex-shrink:0">&#x25B8; 故障处置时效分布</div><div style="flex:1;min-height:0;position:relative"><canvas id="chart-sla-fx" style="width:100%;height:100%;position:absolute"></canvas></div></div>
            <div style="background:rgba(0,20,30,0.3);border-radius:8px;padding:10px;height:150px;display:flex;flex-direction:column"><div style="font-size:12px;color:#5ea8c8;margin-bottom:4px;flex-shrink:0">&#x25B8; 巡检完成情况</div><div style="flex:1;min-height:0;position:relative"><canvas id="chart-insp-xs" style="width:100%;height:100%;position:absolute"></canvas></div></div>
          </div>
          <!-- 考核对标表 -->
          <div style="background:rgba(0,20,30,0.3);border-radius:8px;padding:12px"><div style="font-size:13px;color:#5ea8c8;margin-bottom:8px">&#x25B8; 考核指标对标（百分制）</div>
            <table style="width:100%;font-size:12px"><thead><tr><th style="text-align:left;color:#5ea8c8;padding-bottom:4px">考核项</th><th style="text-align:center;color:#5ea8c8">满分</th><th style="text-align:center;color:#5ea8c8">当前值</th><th style="text-align:center;color:#5ea8c8">预估得分</th><th style="text-align:left;color:#5ea8c8">状态</th></tr></thead>
            <tbody id="tj-kaohe-body"></tbody></table>
          </div>
        </div>
      </div></div>
    </div>

<script src="/shared/constants.js"></script>
<script src="/shared/utils.js"></script>
<script>
const API='/api';
// 指标中文名映射
const MT_CN={
  'water_level':'水位','flow':'流量','velocity':'流速','precipitation':'降雨量',
  'cumulative_rainfall':'累计雨量','soil_moisture':'土壤含水量','soil_temperature':'土壤温度',
  'evaporation':'蒸发量','temperature':'气温','wind_speed':'风速',
  'groundwater_level':'地下水位','water_quality':'水质','noise':'噪声',
  'data_spike':'数据突变','data_freeze':'数据冻结','data_gap':'数据缺失','device_status':'设备状态'
};
// 认证Token管理
let _token=localStorage.getItem('water_ops_token')||'';
let _user=null;
function _authHdrs(){const h={};if(_token)h['Authorization']='Bearer '+_token;return h}
// 带超时和认证头的 fetch 封装（默认30秒超时）
async function af(u,to=30000){try{const c=new AbortController();setTimeout(()=>c.abort(),to);const r=await fetch(API+u,{signal:c.signal,headers:_authHdrs()});if(r.status===401){_token='';localStorage.removeItem('water_ops_token');showLogin();return null}return await r.json()}catch(e){return null}}
async function afP(u,d){try{const c=new AbortController();setTimeout(()=>c.abort(),30000);const r=await fetch(API+u,{method:'POST',headers:Object.assign({'Content-Type':'application/json'},_authHdrs()),body:JSON.stringify(d),signal:c.signal});if(r.status===401){_token='';localStorage.removeItem('water_ops_token');showLogin();return null}return await r.json()}catch(e){return null}}
async function afPt(u,d){try{const c=new AbortController();setTimeout(()=>c.abort(),30000);const r=await fetch(API+u,{method:'PUT',headers:Object.assign({'Content-Type':'application/json'},_authHdrs()),body:JSON.stringify(d),signal:c.signal});if(r.status===401){_token='';localStorage.removeItem('water_ops_token');showLogin();return null}return await r.json()}catch(e){return null}}
// 全局缓存
var _summaryData = null;

// 统一的dashboard数据源——所有面板都调用此函数
async function refreshDashboard(){
  try{
    var d=await af('/dashboard/summary');
    if(d) _summaryData=d;
    return d;
  }catch(e){return _summaryData}
}

// ===== SVG Icons =====
const ICONS={
  search:'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>',
  alert:'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>',
  check:'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>',
  x:'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>',
  upload:'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>',
  download:'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>',
  clock:'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>',
  paperclip:'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21.44 11.05l-9.19 9.19a6 6 0 01-8.49-8.49l9.19-9.19a4 4 0 015.66 5.66l-9.2 9.19a2 2 0 01-2.83-2.83l8.49-8.48"/></svg>',
};
let charts={},map,markerCluster;
// 管理端分页状态
let _ldSt_page=0;
const _ldSt_PAGE_SIZE=20;
let _ldSt_fullData=[];
// 通用分页状态
var _pgState={};
const _PG_SIZE=20;
// 通用分页渲染
function _renderPagination(bodyId,data,page){
  var total=data.length,totalPages=Math.ceil(total/_PG_SIZE)||1;
  var navId=bodyId+'-pg';
  var navEl=document.getElementById(navId);
  if(!navEl){
    navEl=document.createElement('div');navEl.id=navId;
    navEl.style.cssText='display:flex;align-items:center;justify-content:center;gap:8px;padding:10px 0 6px;font-size:13px';
    var container=document.getElementById(bodyId).closest('.card-body')||document.getElementById(bodyId).parentElement;
    container.appendChild(navEl);
  }
  var navHtml='';
  if(totalPages>1){
    navHtml+='<span style="cursor:'+(page>0?'pointer':'default')+';color:'+(page>0?'#5ea8c8':'#4a8aaa')+';padding:2px 6px" onclick="if('+page+'>0){_pgState[\''+bodyId+'\'].page=0;_rePg(\''+bodyId+'\')}">&#9664;&#9664;</span>';
    navHtml+='<span style="cursor:'+(page>0?'pointer':'default')+';color:'+(page>0?'#5ea8c8':'#4a8aaa')+';padding:2px 6px" onclick="if('+page+'>0){_pgState[\''+bodyId+'\'].page--;_rePg(\''+bodyId+'\')}">&#9664;</span>';
    var pStart=Math.max(0,page-2),pEnd=Math.min(totalPages-1,page+2);
    if(pEnd-pStart<4){if(pStart===0)pEnd=Math.min(totalPages-1,pStart+4);else pStart=Math.max(0,pEnd-4)}
    for(var pi=pStart;pi<=pEnd;pi++){
      var active=pi===page;
      navHtml+='<span style="cursor:pointer;padding:2px 10px;border-radius:3px;background:'+(active?'rgba(0,224,192,0.2)':'transparent')+';color:'+(active?'#00e0c0':'#5ea8c8')+';font-weight:'+(active?'500':'normal')+'" onclick="_pgState[\''+bodyId+'\'].page='+pi+';_rePg(\''+bodyId+'\')">'+(pi+1)+'</span>';
    }
    navHtml+='<span style="cursor:'+(page<totalPages-1?'pointer':'default')+';color:'+(page<totalPages-1?'#5ea8c8':'#4a8aaa')+';padding:2px 6px" onclick="if('+page+'<'+(totalPages-1)+'){_pgState[\''+bodyId+'\'].page++;_rePg(\''+bodyId+'\')}">&#9654;</span>';
    navHtml+='<span style="cursor:'+(page<totalPages-1?'pointer':'default')+';color:'+(page<totalPages-1?'#5ea8c8':'#4a8aaa')+';padding:2px 6px" onclick="if('+page+'<'+(totalPages-1)+'){_pgState[\''+bodyId+'\'].page='+(totalPages-1)+';_rePg(\''+bodyId+'\')}">&#9654;&#9654;</span>';
  }
  navHtml+='<span style="color:#4a8aaa;font-size:13px;margin-left:12px;white-space:nowrap">共 <b style="color:#5ea8c8;font-size:14px">'+total+'</b> 条</span>';
  navEl.innerHTML=navHtml;
  navEl.style.display=total>_PG_SIZE?'flex':'none';
}
// 通用分页回调：slice数据并重新渲染表格
function _rePg(bodyId){
  var st=_pgState[bodyId];
  if(!st)return;
  var start=st.page*_PG_SIZE,end=Math.min(start+_PG_SIZE,st.data.length);
  var rows=st.data.slice(start,end);
  if(window['_renderTable_'+bodyId])window['_renderTable_'+bodyId](rows,st.data,st.page);
  _renderPagination(bodyId,st.data,st.page);
}
// 通用分页初始化：保存全量数据，切第一页
function _initPg(bodyId,fullData){
  _pgState[bodyId]={page:0,data:fullData};
  _rePg(bodyId);
}

// ========== 登录系统 ==========
function showLogin(){
  document.getElementById('login-overlay').style.display='flex';
  document.getElementById('login-err').style.display='none';
}
function hideLogin(){
  document.getElementById('login-overlay').style.display='none';
}
async function doLogin(){
  const u=document.getElementById('login-username').value.trim();
  const p=document.getElementById('login-password').value.trim();
  if(!u||!p){document.getElementById('login-err').textContent='请输入用户名和密码';document.getElementById('login-err').style.display='block';return}
  document.getElementById('login-btn').disabled=true;document.getElementById('login-btn').textContent='登录中...';
  try{
    const r=await fetch(API+'/auth/login',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({username:u,password:p})});
    const d=await r.json();
    if(d.success){
      _token=d.token;_user=d.user;
      localStorage.setItem('water_ops_token',_token);
      hideLogin();
      document.getElementById('login-err').style.display='none';
      // 显示用户信息
      document.getElementById('nav-user').style.display='flex';
      document.getElementById('nu-name').textContent=d.user.real_name;
      document.getElementById('nu-role').textContent=d.user.role==='admin'?'管理员':'运维员';
      // 管理员显示人员管理
      if(d.user.role==='admin')document.getElementById('nav-dd-users').style.display='block';
      // 重新加载所有数据
      safeInit();
    }else{
      document.getElementById('login-err').textContent=d.error||'登录失败';
      document.getElementById('login-err').style.display='block';
    }
  }catch(e){document.getElementById('login-err').textContent='网络错误';document.getElementById('login-err').style.display='block'}
  document.getElementById('login-btn').disabled=false;document.getElementById('login-btn').textContent='登 录';
}
function doLogout(){
  _token='';_user=null;
  localStorage.removeItem('water_ops_token');
  showLogin();
  document.getElementById('nav-user').style.display='none';
  document.getElementById('nav-dd-users').style.display='none';
}
// 检查已有token
async function checkAuth(){
  if(!_token){showLogin();return false}
  try{
    const r=await fetch(API+'/auth/me',{headers:Object.assign({'Content-Type':'application/json'},_authHdrs())});
    if(!r.ok){_token='';localStorage.removeItem('water_ops_token');showLogin();return false}
    const d=await r.json();
    if(d.success){_user=d.user;hideLogin();document.getElementById('nav-user').style.display='flex';document.getElementById('nu-name').textContent=d.user.real_name;document.getElementById('nu-role').textContent=d.user.role==='admin'?'管理员':'运维员';if(d.user.role==='admin')document.getElementById('nav-dd-users').style.display='block';return true}
    _token='';localStorage.removeItem('water_ops_token');showLogin();return false
  }catch(e){return false}
}

// ========== 人员管理面板 ==========
async function ldUsers(){
  const d=await af('/users');if(!d)return;
  _initPg('users-body', d)}
window['_renderTable_users-body']=function(rows){
  document.getElementById('users-body').innerHTML=rows.map(u=>`<tr><td>${esc(u.username)}</td><td>${esc(u.real_name)}</td><td>${u.role==='admin'?'管理员':'运维员'}</td><td>${esc(u.phone||'-')}</td><td>${u.sites_count||0}</td><td><span class="badge badge-${u.status==='active'?'grn':'org'}">${u.status==='active'?'正常':'禁用'}</span></td><td><button class="btn btn-primary btn-xs" onclick="showUserSites(${u.id},${JSON.stringify(u.real_name)})">分配站点</button><button class="btn btn-warning btn-xs" onclick="resetUserPw(${u.id},${JSON.stringify(u.real_name)})">重置密码</button></td></tr>`).join('')
};
async function showUserSites(uid,uname){
  const r=await af('/users/'+uid+'/sites');if(!r)return;
  const all=await af('/sites');if(!all)return;
  const assigned=new Set(r.site_ids||[]);
  const ov=document.createElement('div');ov.className='modal-overlay';
  let html='<div class="modal" style="max-width:800px;max-height:500px"><h4>&#187;&#187;&#187; 站点分配: '+esc(uname)+'</h4><div style="margin-bottom:6px"><input class="fi" placeholder="搜索站点..." oninput="filterUserSites(this.value)" style="width:250px"><button class="btn btn-primary btn-sm" onclick="doSaveUserSites('+uid+')" style="margin-left:8px">保存分配</button></div><div id="us-sites-list" style="max-height:350px;overflow-y:auto;display:flex;flex-wrap:wrap;gap:2px">';
  for(var i=0;i<all.length;i++){var s=all[i];html+='<label style="width:170px;padding:3px 6px;font-size:11px;cursor:pointer;display:flex;align-items:center;gap:4px;border-radius:2px;background:'+(assigned.has(s.id)?'rgba(0,200,180,0.08)':'transparent')+'"><input type="checkbox" class="us-cb" value="'+s.id+'" '+(assigned.has(s.id)?'checked':'')+'>'+esc(s.name)+'</label>'}
  html+='</div><br><button class="btn btn-sm" style="color:#4a8aaa;border:1px solid rgba(0,200,180,0.15)" onclick="this.closest(\'.modal-overlay\').remove()">关闭</button></div>';
  ov.innerHTML=html;document.body.appendChild(ov)
}
function filterUserSites(q){
  var v=q.toLowerCase();document.querySelectorAll('#us-sites-list label').forEach(function(l){l.style.display=l.textContent.toLowerCase().includes(v)?'flex':'none'})
}
async function doSaveUserSites(uid){
  var ids=Array.from(document.querySelectorAll('.us-cb:checked')).map(c=>parseInt(c.value));
  var r=await afPt('/users/'+uid+'/sites',{site_ids:ids});
  if(r&&r.success){showToast('分配已保存');document.querySelectorAll('.modal-overlay').forEach(e=>e.remove());ldUsers()}
}
async function resetUserPw(uid,uname){
  var newPw=prompt('请输入 '+uname+' 的新密码（留空取消）:','');
  if(!newPw)return;
  var r=await afPt('/users/'+uid+'/reset-password',{new_password:newPw});
  if(r&&r.success)showToast(uname+' 密码已重置');else showToast('重置失败','error')
}

// ========== 面板切换 ==========
const shpSvg={
  rainfall:'<svg viewBox="0 0 1024 1024" width="24" height="24"><path d="M511.974273 512.025215m-486.3741 0a486.374101 486.374101 0 1 0 972.748201 0 486.374101 486.374101 0 1 0-972.748201 0Z" fill="#FFFFFF"/><path d="M149.958351 874.041137A511.972737 511.972737 0 1 1 511.974273 1023.997952a508.644915 508.644915 0 0 1-362.015922-149.956815zM51.19881 512.025215a460.775464 460.775464 0 1 0 460.775463-460.775464 461.313035 461.313035 0 0 0-460.775463 460.775464z m204.789095 0a255.986369 255.986369 0 1 1 255.986368 255.986368 255.986369 255.986369 0 0 1-255.986368-255.986368z" fill="#FF0000"/></svg>',
  water_level:'<svg viewBox="0 0 1024 1024" width="24" height="24"><path d="M511.974273 512.025215m-486.3741 0a486.374101 486.374101 0 1 0 972.748201 0 486.374101 486.374101 0 1 0-972.748201 0Z" fill="#FFFFFF"/><path d="M149.958351 874.041137A511.972737 511.972737 0 1 1 511.974273 1023.997952a508.644915 508.644915 0 0 1-362.015922-149.956815zM51.19881 512.025215a460.775464 460.775464 0 1 0 460.775463-460.775464 461.313035 461.313035 0 0 0-460.775463 460.775464z m606.20132 358.380916h-290.851713l145.451455-762.839379 145.425856 762.839379z m-221.632999-56.317001h153.591822l-77.231088-465.178429z" fill="#FF0000"/></svg>',
  hydrology:'<svg viewBox="0 0 1024 1024" width="24" height="24"><path d="M511.974273 512.025215m-486.3741 0a486.374101 486.374101 0 1 0 972.748201 0 486.374101 486.374101 0 1 0-972.748201 0Z" fill="#FFFFFF"/><path d="M149.958351 874.041137A511.972737 511.972737 0 1 1 511.974273 1023.997952a508.644915 508.644915 0 0 1-362.015922-149.956815zM51.19881 512.025215a460.775464 460.775464 0 1 0 460.775463-460.775464 461.313035 461.313035 0 0 0-460.775463 460.775464z m315.349607 358.380916l145.451455-762.839379 145.425856 762.839379z" fill="#FF0000"/></svg>',
  soil_moisture:'<svg viewBox="0 0 1024 1024" width="24" height="24"><path d="M511.974273 512.025215m-486.3741 0a486.374101 486.374101 0 1 0 972.748201 0 486.374101 486.374101 0 1 0-972.748201 0Z" fill="#FFA600"/><path d="M149.958351 874.041137A511.972737 511.972737 0 1 1 511.974273 1023.997952a508.644915 508.644915 0 0 1-362.015922-149.956815zM511.974273 955.726388a442.856418 442.856418 0 0 0 336.596477-154.897352l-277.412428-277.412428h-108.9222l-282.455359 282.429761A442.856418 442.856418 0 0 0 511.974273 955.726388z m-373.740098-204.789095l227.495086-227.469488h-297.27697a440.885323 440.885323 0 0 0 69.781884 227.41829z m751.217598-5.785292a440.962119 440.962119 0 0 0 66.146877-221.709794h-287.88227z m62.665463-289.981359a443.75237 443.75237 0 0 0-880.157932 0z"/></svg>',
  evaporation:'<svg viewBox="0 0 1024 1024" width="24" height="24"><path d="M511.974273 512.025215m-486.3741 0a486.374101 486.374101 0 1 0 972.748201 0 486.374101 486.374101 0 1 0-972.748201 0Z" fill="#FFFFFF"/><path d="M149.958351 874.041137A511.972737 511.972737 0 1 1 511.974273 1023.997952a508.644915 508.644915 0 0 1-362.015922-149.956815zM51.19881 512.025215a460.775464 460.775464 0 1 0 460.775463-460.775464 461.313035 461.313035 0 0 0-460.775463 460.775464z m208.475298 252.325763v-504.651527h100.909827v50.454913h-50.454913v138.232639a205.966632 205.966632 0 0 1 201.845251 13.260094 206.01783 206.01783 0 0 0 201.870851 13.260094v-164.650432h-252.325764v-50.454913h302.806276v504.651527z" fill="#1890FF"/></svg>',
  groundwater:'<svg viewBox="0 0 1024 1024" width="24" height="24"><path d="M511.974273 512.025215m-486.3741 0a486.374101 486.374101 0 1 0 972.748201 0 486.374101 486.374101 0 1 0-972.748201 0Z" fill="#FFFFFF"/><path d="M149.958351 874.041137A511.972737 511.972737 0 1 1 511.974273 1023.997952a508.644915 508.644915 0 0 1-362.015922-149.956815zM51.19881 512.025215a460.775464 460.775464 0 1 0 460.775463-460.775464 461.313035 461.313035 0 0 0-460.775463 460.775464z m550.370693 281.585005v-140.792503h-179.190459v140.792503h-51.197273v-140.792503h-140.792503v-51.197273h140.792503v-179.190458h-140.792503v-51.197274h140.792503V230.440209h51.197273v140.792503h179.190459V230.440209h51.197273v140.792503h140.792503v51.197274h-140.792503v179.190458h140.792503v51.197273h-140.792503v140.792503z m-179.190459-191.989776h179.190459v-179.190458h-179.190459z" fill="#00CCFF"/></svg>',
  station_yard:'<svg viewBox="0 0 1024 1024" width="24" height="24"><path d="M511.974273 512.025215m-486.3741 0a486.374101 486.374101 0 1 0 972.748201 0 486.374101 486.374101 0 1 0-972.748201 0Z" fill="#FFFFFF"/><path d="M149.958351 874.041137A511.972737 511.972737 0 1 1 511.974273 1023.997952a508.644915 508.644915 0 0 1-362.015922-149.956815zM51.19881 512.025215a460.775464 460.775464 0 1 0 460.775463-460.775464 461.313035 461.313035 0 0 0-460.775463 460.775464z m460.775463 307.183642l-22.885181-22.757188-150.340794-149.624033-3.276626-3.276625-3.276625-3.251027a245.106948 245.106948 0 1 1 359.481657 0l-156.868446 156.151685-22.833985 22.757188z m-100.321057-344.78804a102.676132 102.676132 0 1 0 102.676132-102.215357 103.802473 103.802473 0 0 0-102.650534 102.189758z" fill="#1890FF"/></svg>',
};

function switchNav(t){document.querySelectorAll('.nav-tab').forEach(e=>e.classList.remove('active'));document.querySelectorAll('.tab-panel').forEach(e=>e.classList.remove('active'));document.querySelectorAll('.nav-dd-item').forEach(e=>e.classList.remove('active'));const navEl=document.querySelector(`[onclick*="${t}"]`);if(navEl)navEl.classList.add('active');const panel=document.getElementById('panel-'+t);if(panel)panel.classList.add('active');if(t==='cockpit'){setTimeout(()=>map&&map.invalidateSize(),150);cockpitLoad()}else if(t==='maintenance'){setTimeout(()=>ldMp(),100)}else if(t==='users'){ldUsers()}}
function toggleNavDD(){document.getElementById('nav-dd-menu').classList.toggle('show')}
function switchNavDD(t){document.getElementById('nav-dd-menu').classList.remove('show');switchNav(t)}
// 运维管理子标签切换
// switchMpSub已删除（巡检管理已移除）
// ========== 无障碍：模态键盘支持 ==========
// 点击遮罩层关闭弹窗
document.addEventListener('click',function(e){const m=e.target.closest('.modal-overlay');if(m&&m===e.target)m.remove()});
// ESC键关闭弹窗
document.addEventListener('keydown',function(e){if(e.key==='Escape'){const m=document.querySelector('.modal-overlay');if(m){e.preventDefault();m.remove()}}});
// 弹窗开放时自动添加aria属性（MutationObserver）
document.addEventListener('DOMNodeInserted',function(e){
  var el=e.target;
  if(el.classList&&el.classList.contains('modal-overlay')&&!el.hasAttribute('role')){
    el.setAttribute('role','dialog');el.setAttribute('aria-modal','true');
    var modal=el.querySelector('.modal');if(modal&&!modal.getAttribute('aria-label'))modal.setAttribute('aria-label','弹窗');
    // 聚焦到弹窗内第一个可聚焦元素或关闭按钮
    setTimeout(function(){var f=el.querySelector('button,input,select,textarea,[tabindex]');if(f)f.focus()},100)
  }
});
// 点击外部关闭下拉
document.addEventListener('click',function(e){const dd=document.getElementById('nav-more');if(dd&&!dd.contains(e.target)){const m=document.getElementById('nav-dd-menu');if(m)m.classList.remove('show')}});
function togglePane(s){const p=document.getElementById('panel-'+s);const h=p.classList.toggle('hidden');const btn=p.parentElement.querySelector('.btn-show-'+s);if(btn)btn.textContent=h?'展开面板':'隐藏面板';if(!h&&s==='right')setTimeout(cockpitLoad,100)}

// ========== MAP ==========
function initMap(){
  map=L.map('map',{center:[28.68,115.86],zoom:11,zoomControl:false});
  // 高德卫星图（国内可访问）
  L.tileLayer('https://webst{s}.is.autonavi.com/appmaptile?style=6&x={x}&y={y}&z={z}',{maxZoom:20,subdomains:['01','02','03','04'],attribution:'高德卫星'}).addTo(map);
  // 聚合图标自定义（显示告警标记）
  markerCluster=L.markerClusterGroup({
    chunkedLoading:true,maxClusterRadius:80,spiderfyOnMaxZoom:false,showCoverageOnHover:false,zoomToBoundsOnClick:false,
    iconCreateFunction:function(cluster){
      var ch=cluster.getAllChildMarkers(),ac=ch.filter(function(m){return m._hasAlert}).length;
      // 取子标记中最高告警级别
      var maxLev=null;
      ch.forEach(function(m){
        var lv=m._alertLevel;
        if(lv==='red')maxLev='red';
        else if(lv==='orange'&&maxLev!=='red')maxLev='orange';
        else if(lv==='yellow'&&!maxLev)maxLev='yellow'
      });
      var levCls=maxLev?' level-'+maxLev:'';
      var badgeCls=maxLev||'red';
      var h='<div class="marker-cluster-alert'+levCls+'"><div class="mc-count'+levCls+'">'+cluster.getChildCount()+'</div>';
      if(ac>0)h+='<div class="mc-badge '+badgeCls+'">'+ac+'</div>';
      h+='</div>';return L.divIcon({html:h,className:'mca-icon',iconSize:[46,46]})
    }
  });
  // 自定义聚合点击行为
  markerCluster.on('clusterclick',function(e){
    var cl=e.layer,childs=cl.getAllChildMarkers();
    if(childs.length<=4){
      var lat0=childs[0].getLatLng().lat,lng0=childs[0].getLatLng().lng;
      var allClose=childs.every(function(m){return Math.abs(m.getLatLng().lat-lat0)<0.001&&Math.abs(m.getLatLng().lng-lng0)<0.001});
      if(allClose){
        // 同坐标密集点：横向排列完整详情卡片（与单张卡片完全一致）
        map.closePopup();
        var loadPoup=L.popup({className:'cluster-popup',closeButton:false}).setLatLng(cl.getLatLng()).setContent('<div style="padding:10px;color:#5ea8c8;font-size:13px">加载中...</div>').openOn(map);
        var fetches=childs.map(function(m){
          var sid=m._sd.id;
          return Promise.all([af('/site/status/'+sid),af('/data/site/'+sid+'?limit=200')]).then(function(r){return{id:sid,status:r[0],data:r[1]}});
        });
        Promise.all(fetches).then(function(res){
          map.closePopup();
          var style='<style>.cp-grid{display:flex;gap:0;width:760px}.cp-col{flex:1;min-width:0;padding:0}.cp-col+.cp-col{border-left:1px solid rgba(0,200,180,0.15);padding-left:6px}</style>';
          var html=style+'<div class="cp-grid">';
          for(var ri=0;ri<res.length;ri++){
            var r=res[ri],d=r.status,sd=r.data,m=childs[ri],s=m._sd;
            var dv=d?d.devices||[]:[];
            var onlineCount=dv.filter(function(x){return x.status==='online'}).length;
            var offlineCount=dv.length-onlineCount;
            var healthBadge='';
            if(d&&(d.data_health==='alert'||d.data_health==='abnormal')) healthBadge='<span style="color:#ff4760;font-size:10px;border:1px solid rgba(255,71,96,0.3);border-radius:3px;padding:1px 4px;margin-left:6px">&#9888; 异常</span>';
            else if(d&&d.data_health==='normal') healthBadge='<span style="color:#2ea080;font-size:10px;border:1px solid rgba(46,224,128,0.3);border-radius:3px;padding:1px 4px;margin-left:6px">&#10003; 正常</span>';
            // 今日极值
            var todayExtremes='';
            if(sd&&sd.length>0){
              var chartRes2=_aggSiteData(sd,s.type);
              if(chartRes2.values.length>0){
                var mxV=-999,mnV=9999;
                for(var tvi=0;tvi<chartRes2.values.length;tvi++){var cv=chartRes2.values[tvi];if(cv>mxV)mxV=cv;if(cv<mnV)mnV=cv}
                var unit2=s.type==="soil_moisture"?"%":s.type==="evaporation"?"mm":s.type==="rainfall"?"mm":"m";
                todayExtremes='<span style="color:#5ea8c8">今日极值</span> <span style="color:#00e0c0">高 '+mxV.toFixed(1)+unit2+'</span> <span style="color:#4a8aaa">|</span> <span style="color:#b0d4ef">低 '+mnV.toFixed(1)+unit2+'</span>';
              }
            }
            var uptime='';
            if(dv.length>0){
              var onlineDev2=dv.find(function(x){return x.status==='online'});
              if(onlineDev2&&onlineDev2.last_data_time){
                var lastT2=new Date(onlineDev2.last_data_time.replace(' ','T'));
                var hoursAgo2=Math.round((Date.now()-lastT2.getTime())/3600000);
                if(hoursAgo2<1)uptime='<span style="color:#00e0c0">设备在线</span>';
                else uptime='<span style="color:#00e0c0">已运行 '+hoursAgo2+'h</span>';
              }else if(onlineCount>0){uptime='<span style="color:#00e0c0">设备在线</span>'}
            }
            var delayWarn='';
            if(sd&&sd.length>0){
              var latestRec=sd[0];
              if(latestRec&&latestRec.recorded_at){
                var recT2=new Date(latestRec.recorded_at.replace(' ','T'));
                var minsAgo2=Math.round((Date.now()-recT2.getTime())/60000);
                if(minsAgo2>120)delayWarn='<span style="color:#ff4760">数据延迟 '+Math.floor(minsAgo2/60)+'h</span>';
                else if(minsAgo2>60)delayWarn='<span style="color:#ffa040">延迟 '+minsAgo2+'min</span>';
              }
            }
            var latestTm=sd&&sd.length?(sd[0].recorded_at||'').substring(0,16):'';
            // 今日到报
            var arrivalStatus='<span style="color:#00e0c0">今日已到报</span>';
            if(sd&&sd.length>0){
              var todayDate2=new Date().toISOString().substring(0,10);
              var hasToday2=false;
              for(var si2=0;si2<sd.length&&!hasToday2;si2++){if(sd[si2].recorded_at&&sd[si2].recorded_at.indexOf(todayDate2)===0)hasToday2=true}
              if(!hasToday2)arrivalStatus='<span style="color:#ffa040">今日未到报</span>';
            }
            var statusBar2=[];
            if(uptime)statusBar2.push(uptime);
            if(arrivalStatus)statusBar2.push(arrivalStatus);
            if(delayWarn)statusBar2.push(delayWarn);
            if(latestTm)statusBar2.push('<span style="color:#5ea8c8">数据</span> <span style="color:'+(delayWarn?'#ff4760':'#b0d4ef')+'">'+latestTm+'</span>');
            var tagCls2={'设备在线':'green','在线':'green','今日已到报':'green','已运行':'green','延迟':'orange','数据延迟':'orange','正常':'green','未到报':'orange','待处理':'orange'};
            var tags2=[];statusBar2.forEach(function(x){var k=Object.keys(tagCls2).find(function(t){return x.indexOf(t)>-1});tags2.push('<span class="sp-tag '+(tagCls2[k||'gray']||'gray')+'">'+x+'</span>')});
            var wlStatusHtml2='';
            if(d&&d.wl_status&&d.wl_status!=='--'){var wlClr2=d.wl_status==='危急'?'red':d.wl_status==='告警'?'orange':'green';wlStatusHtml2='<span class="sp-tag '+wlClr2+'">水位 '+d.wl_value+'m | '+d.wl_status+'</span>'}
            const chartHtml2=sd&&sd.length?renderSiteChart(sd,s.type):'<div style="padding:6px 0;color:#4a8aaa;font-size:12px">暂无实时数据</div>';
            const activeAlerts2=d?d.active_alerts||[]:[];
            const alertHtml2=activeAlerts2.length?activeAlerts2.slice(0,5).map(function(x){return '<div class="sp-alert"><span style="flex:1;color:#b0d4ef">'+x.message+'</span><span style="color:#5ea8c8;font-size:10px">'+(x.created_at||'').substring(11,16)+'</span></div>'}).join(''):'<div style="color:#4a8aaa;font-size:11px;padding:2px 0">无告警</div>';
            var devHtml2='';
            if(dv.length>0){
              devHtml2=dv.slice(0,6).map(function(x){var on=x.status==='online';return '<div class="sp-device"><span class="dot '+(on?'on':'off')+'"></span><span style="flex:1;font-size:10px">'+(x.device_name||'')+'</span><span style="color:'+(on?'#00e080':'#ff4760')+';font-size:9px">'+(on?'在线':'离线')+'</span></div>'}).join('');
              if(dv.length>6)devHtml2+='<div style="font-size:9px;color:#4a8aaa;padding:1px 0">+'+(dv.length-6)+'...</div>';
            }else{devHtml2='<div style="color:#4a8aaa;font-size:10px">暂无设备</div>'}
            html+='<div class="cp-col"><div class="site-popup"><h4>'+s.name+' <span style="font-size:11px;color:#5ea8c8">'+(s.code||'')+'</span>'+healthBadge+'</h4><div class="row"><span class="rl">类型</span><span class="rv">'+(TM[s.type]||s.type)+'</span><span style="flex:1"></span><span class="rl">区县</span><span class="rv">'+(s.district||'-')+'</span></div><div style="display:flex;flex-wrap:wrap;gap:4px;margin:4px 0 2px">'+tags2.join('')+wlStatusHtml2+'</div>'+(todayExtremes?'<div style="font-size:12px;color:#5ea8c8;margin-bottom:2px">'+todayExtremes+'</div>':'')+'<div style="margin:6px 0 4px;padding:4px 0;border-top:1px solid rgba(0,200,180,0.08);border-bottom:1px solid rgba(0,200,180,0.08)">'+chartHtml2+'</div>'+(activeAlerts2.length?'<div style="font-size:11px;color:#ffa040;padding:2px 0">&#9888; 告警 ('+activeAlerts2.length+')</div>'+alertHtml2:'')+(dv.length?'<div style="font-size:11px;color:#5ea8c8;padding:2px 0;margin-top:2px">&#9881; 设备 ('+dv.length+')</div>'+devHtml2:'')+'</div></div>';
          }
          html+='</div>';
          L.popup({maxWidth:800,className:'cluster-popup',closeButton:true,offset:[0,0]}).setLatLng(cl.getLatLng()).setContent(html).openOn(map);
        });
        return;
      }
    }
    // 普通聚合：手动放大到能看清的级别
    map.fitBounds(cl.getBounds().pad(0.15));
  });
  _loadAllMarkers().then(ms=>{ms.forEach(m=>markerCluster.addLayer(m));map.addLayer(markerCluster);try{map.fitBounds(markerCluster.getBounds().pad(0.1))}catch(e){console.warn('地图定位失败',e)}}).catch(e=>console.error('加载站点标记失败:',e));
  renderLegend();
}
function renderLegend(){
  var items=[
    {type:'rainfall',color:'#FF0000',label:'雨量站'},{type:'water_level',color:'#FF0000',label:'水位站'},
    {type:'hydrology',color:'#FF0000',label:'水文站'},{type:'soil_moisture',color:'#FFA600',label:'墒情站'},
    {type:'evaporation',color:'#1890FF',label:'蒸发站'},{type:'groundwater',color:'#00CCFF',label:'地下水站'},
    {type:'station_yard',color:'#1890FF',label:'站院'},
  ];
  var html=items.map(function(it){return '<div class="legend-row"><span class="lg-icon" style="color:'+it.color+'">'+shpSvg[it.type]+'</span>'+it.label+'</div>'}).join('');
  html+='<div class="legend-row" style="border-top:1px solid rgba(0,200,180,0.1);padding-top:5px;margin-top:3px"><span class="lg-icon" style="color:#ff4760">◉</span>有告警</div>';
  var el=document.getElementById('legend-body');if(el)el.innerHTML=html;
}
async function _loadAllMarkers(filterType){
  await refreshDashboard();
  const allSites=await af('/sites');if(!allSites)return[];
  // 获取活跃告警列表用于标记和弹窗
  const alerts=await af('/alerts?limit=500');
  const siteAlerts={};(alerts||[]).filter(a=>a.status==='pending').forEach(a=>{if(!siteAlerts[a.site_id])siteAlerts[a.site_id]=[];siteAlerts[a.site_id].push(a)});
  const filtered=filterType?allSites.filter(s=>s.type===filterType):allSites;
  var _markers=filtered.map(s=>{
    const svg=shpSvg[s.type]||shpSvg.rainfall;
    const sa=siteAlerts[s.id]||[];const hasAlert=sa.length>0;
    // 运行状态分色: 有告警=橙色/红色, 设备离线=红色, 正常=绿色
    var statClr='#2ea080'; // 默认绿色(正常)
    if(s.status==='offline')statClr='#ff4760'; // 红色(离线)
    else if(hasAlert)statClr='#ffa040'; // 橙色(数据异常)
    const c=statClr;
    // 确定最高告警级别
    var alertLevel=null;
    sa.forEach(function(a){
      var lv=a.level;
      if(lv==='red')alertLevel='red';
      else if(lv==='orange'&&alertLevel!=='red')alertLevel='orange';
      else if(lv==='yellow'&&!alertLevel)alertLevel='yellow'
    });
    var breatheCls=hasAlert?' '+(alertLevel||'red'):'';
    const m=L.marker([s.lat,s.lng],{icon:L.divIcon({className:'',html:`<div class="marker-breathe${breatheCls}" style="width:24px;height:24px;border-radius:50%">${svg}</div>`,iconSize:[24,24],iconAnchor:[12,12]})});
    m._sd=s;m._hasAlert=hasAlert;m._alertLevel=alertLevel;
    m.on('click',async ()=>{
      const d=await af('/site/status/'+s.id);
      const dv=d?d.devices||[]:[];
      const onlineCount=dv.filter(function(x){return x.status==='online'}).length;
      const offlineCount=dv.length-onlineCount;
      const devStatus=dv.length?(onlineCount+'/'+dv.length+'在线'+(offlineCount?' '+offlineCount+'离线':'')):'';
      // 数据健康标识（与驾驶舱逻辑一致）
      var healthBadge='';
      if(d&&(d.data_health==='alert'||d.data_health==='abnormal')) healthBadge='<span style="color:#ff4760;font-size:10px;border:1px solid rgba(255,71,96,0.3);border-radius:3px;padding:1px 4px;margin-left:6px">&#9888; 异常</span>';
      else if(d&&d.data_health==='normal') healthBadge='<span style="color:#2ea080;font-size:10px;border:1px solid rgba(46,224,128,0.3);border-radius:3px;padding:1px 4px;margin-left:6px">&#10003; 正常</span>';
      const sd=await af('/data/site/'+s.id+'?limit=200');
      // 计算今日极值（与图表小时聚合逻辑一致）
      var todayExtremes='';
      if(sd&&sd.length>0){
        var chartRes=_aggSiteData(sd,s.type);
        if(chartRes.values.length>0){
          var maxV=-999,minV=9999;
          for(var tvi=0;tvi<chartRes.values.length;tvi++){
            var cv=chartRes.values[tvi];
            if(cv>maxV)maxV=cv;
            if(cv<minV)minV=cv;
          }
          var label=s.type==="rainfall"?"降雨":s.type==="water_level"?"水位":s.type==="hydrology"?"水位":s.type==="soil_moisture"?"含水量":s.type==="evaporation"?"蒸发量":"";
          var unit=s.type==="soil_moisture"?"%":s.type==="evaporation"?"mm":s.type==="rainfall"?"mm":"m";
          todayExtremes='<span style="color:#5ea8c8">今日极值</span> <span style="color:#00e0c0">高 '+maxV.toFixed(1)+unit+'</span> <span style="color:#4a8aaa">|</span> <span style="color:#b0d4ef">低 '+minV.toFixed(1)+unit+'</span>';
        }
      }
      // 设备运行时长
      var uptime='';
      if(dv.length>0){
        var onlineDev=dv.find(function(x){return x.status==='online'});
        if(onlineDev&&onlineDev.last_data_time){
          var lastT=new Date(onlineDev.last_data_time.replace(' ','T'));
          var hoursAgo=Math.round((Date.now()-lastT.getTime())/3600000);
          if(hoursAgo<1)uptime='<span style="color:#00e0c0">设备在线</span>';
          else uptime='<span style="color:#00e0c0">已运行 '+hoursAgo+'h</span>';
        }else if(onlineCount>0){
          uptime='<span style="color:#00e0c0">设备在线</span>';
        }
      }
      // 数据延迟告警
      var delayWarn='';
      if(sd&&sd.length>0){
        var latestRec=sd[0];
        if(latestRec&&latestRec.recorded_at){
          var recT=new Date(latestRec.recorded_at.replace(' ','T'));
          var minsAgo=Math.round((Date.now()-recT.getTime())/60000);
          if(minsAgo>360)delayWarn='<span style="color:#ff4760"><span class="i i-sm" style="margin-right:2px"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></span>数据延迟 '+Math.floor(minsAgo/60)+'h</span>';
          else if(minsAgo>120)delayWarn='<span style="color:#ffa040"><span class="i i-sm" style="margin-right:2px"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></span>延迟 '+minsAgo+'min</span>';
        }
      }
      // 最新数据时间
      var latestTime=sd&&sd.length?sd[0].recorded_at||'':'';
      var latestTm=latestTime?latestTime.substring(0,16):'';
      // 今日到报状态
      var arrivalStatus='';
      var sixHoursAgo=new Date(Date.now()-6*3600000).toISOString();
      var hasRecentData=false;
      if(sd&&sd.length>0){
        for(var si2=0;si2<sd.length&&!hasRecentData;si2++){
          if(sd[si2].recorded_at&&sd[si2].recorded_at>=sixHoursAgo)hasRecentData=true;
        }
      }
      arrivalStatus=hasRecentData?'<span style="color:#00e0c0">数据正常</span>':'<span style="color:#ffa040">数据延迟</span>';
      // 组装状态栏
      var statusBar=[];
      if(uptime)statusBar.push(uptime);
      if(arrivalStatus)statusBar.push(arrivalStatus);
      if(delayWarn)statusBar.push(delayWarn);
      if(latestTm)statusBar.push('<span style="color:#5ea8c8">数据</span> <span style="color:'+(delayWarn?'#ff4760':'#b0d4ef')+'">'+latestTm+'</span>');
      
      // const chartHtml=sd&&sd.length?renderSiteChart(sd,s.type):'<div style="padding:6px 0;color:#4a8aaa;font-size:12px">暂无实时数据</div>';
      const chartHtml=''; // 图表已移除，请查看数据趋势页面
      var recentDataHtml='';
      if(sd&&sd.length>0){
        var sdList=sd.slice(0,5);
        recentDataHtml='<div style="margin:6px 0 4px;padding:4px 0;border-top:1px solid rgba(0,200,180,0.08);border-bottom:1px solid rgba(0,200,180,0.08)">';
        recentDataHtml+='<div style="font-size:11px;color:#5ea8c8;margin-bottom:4px">&#x25B8; 最新数据</div>';
        sdList.forEach(function(r){
          var m=window['MT']?MT[r.metric]:r.metric;
          recentDataHtml+='<div style="display:flex;font-size:11px;padding:1px 0"><span style="color:#b0d4ef;flex:1">'+(m||r.metric)+'</span><span style="color:#00e0c0">'+(typeof r.value==='number'?r.value.toFixed(2):r.value)+'</span><span style="color:#4a8aaa;margin-left:4px">'+r.unit+'</span><span style="color:#4a8aaa;margin-left:8px">'+(r.recorded_at||'').substring(11,16)+'</span></div>';
        });
        recentDataHtml+='</div>';
      }
      // 优先使用 /alerts 中已缓存的 sa（已在函数作用域内）
      // 以 sa 为主，/site/status 返回的 active_alerts 做补充
      const apiAlerts=d?((d.active_alerts||d.alerts||d.pending_alerts)||[])||[]:[];
      const combinedAlerts=sa.length>0?sa:apiAlerts;
      const activeAlerts=combinedAlerts;
      // 设备详情列表
      var devHtml='';
      if(dv.length>0){
        devHtml=dv.slice(0,8).map(function(x){
          var on=x.status==='online';
          return '<div class="sp-device"><span class="dot '+(on?'on':'off')+'"></span><span style="flex:1">'+(x.device_name||'')+'</span><span style="color:'+(on?'#00e080':'#ff4760')+';font-size:10px">'+(on?'在线':'离线')+'</span><span style="color:#5ea8c8;font-size:10px;margin-left:4px">'+(x.voltage?x.voltage+'V':'')+'</span><span style="color:#4a8aaa;font-size:10px;margin-left:4px">'+(x.last_data_time?x.last_data_time.substring(11,16):'')+'</span></div>'
        }).join('');
        if(dv.length>8) devHtml+='<div style="font-size:10px;color:#4a8aaa;padding:2px 0">还有 '+(dv.length-8)+' 个设备...</div>';
      }else{devHtml='<div style="color:#4a8aaa;font-size:11px">暂无设备</div>'}
      // 水位超限状态
      var wlStatusHtml='';
      if(d&&d.wl_status&&d.wl_status!=='--'){
        var wlClr=d.wl_status==='危急'?'red':d.wl_status==='告警'?'orange':'green';
        wlStatusHtml='<span class="sp-tag '+wlClr+'">&#x2248; 水位 '+d.wl_value+'m <span style="opacity:0.6">|</span> '+d.wl_status+'</span>';
      }
      var tags=[];var tagCls={'设备在线':'green','在线':'green','今日已到报':'green','已运行':'green','延迟':'orange','数据延迟':'orange','正常':'green','未到报':'orange','待处理':'orange'};
      statusBar.forEach(function(x){var k=Object.keys(tagCls).find(function(t){return x.indexOf(t)>-1});tags.push('<span class="sp-tag '+(tagCls[k||'gray']||'gray')+'">'+x+'</span>')});
      if(hasAlert) tags.push('<span class="sp-tag orange">⚠ 告警 '+sa.length+'</span>');
      // 告警（无级别标签）
      const alertHtml=activeAlerts.length?activeAlerts.slice(0,5).map(x=>'<div class="sp-alert" onclick="this.closest(\'.leaflet-popup-close-button\')&&document.querySelector(\'.leaflet-popup-close-button\')&&document.querySelector(\'.leaflet-popup-close-button\').click();showAlertDetail('+x.id+')"><span style="flex:1;color:#b0d4ef">'+x.message+'</span><span style="color:#5ea8c8;font-size:10px">'+(x.created_at||'').substring(11,16)+'</span></div>').join(''):'<div style="color:#4a8aaa;font-size:12px;padding:4px 0">暂无未办结告警</div>';
      m.bindPopup(`<div class="site-popup"><h4>${s.name} <span style="font-size:11px;color:#5ea8c8">${s.code}</span>${healthBadge}</h4><div class="row"><span class="rl">类型</span><span class="rv">${TM[s.type]||s.type}</span><span style="flex:1"></span><span class="rl">区县</span><span class="rv">${s.district||'-'}</span></div><div style="display:flex;flex-wrap:wrap;gap:4px;margin:4px 0 2px">${tags.join('')}${wlStatusHtml}</div>${todayExtremes?('<div style="font-size:12px;color:#5ea8c8;margin-bottom:2px">'+todayExtremes+'</div>'):''}${recentDataHtml}${activeAlerts.length>0?('<div class="sp-section" style="font-size:12px;color:#ffa040;padding-bottom:3px">&#9888; 告警 ('+activeAlerts.length+')</div>'+alertHtml):(hasAlert?'<div class="sp-section" style="font-size:12px;color:#ff4760;padding:4px 0">&#9888; 该站点有待处理告警</div>':'')}${dv.length?('<div class="sp-section" style="font-size:12px;color:#5ea8c8;padding-bottom:3px">&#9881; 设备 ('+dv.length+')</div>'+devHtml):''}<div style="margin-top:6px;text-align:center"><a style="color:#00e0c0;font-size:12px;cursor:pointer" onclick="this.closest(\'.leaflet-popup-close-button\')&&document.querySelector(\'.leaflet-popup-close-button\')&&document.querySelector(\'.leaflet-popup-close-button\').click();showSiteTrend(${s.id})">查看数据趋势 ›</a></div></div>`,{maxWidth:480,className:'site-popup-wrap'}).openPopup()
    });
    return m;
  });
  window.__allMapMarkers=_markers;
  _updateBreatheFromApi();
  return _markers;
}

// ========== 站点弹窗图表渲染（带坐标轴） ==========
const CHART_CFG={
  rainfall:{label:'小时雨量',unit:'mm',color:'#2ea0ff',type:'bar'},
  water_level:{label:'水位',unit:'m',color:'#00e0c0',type:'line'},
  hydrology:{label:'水位',unit:'m',color:'#00e0c0',type:'line'},
  soil_moisture:{label:'土壤含水量',unit:'%',color:'#ffa040',type:'line'},
  groundwater:{label:'地下水位',unit:'m',color:'#00CCFF',type:'line'},
  evaporation:{label:'蒸发量',unit:'mm',color:'#a855f7',type:'line'}
};
// 与renderSiteChart共享的数据聚合逻辑
function _aggSiteData(data,type){
  var maxPts=72,pts=data.slice(-maxPts);
  var values=[],labels=[];
  var hourly={},hourlyCount={};
  var isTemp=function(m){return m==="temperature"};
  for(var pi=0;pi<pts.length;pi++){
    var d=pts[pi],v=null,m;
    if(type==="rainfall"&&d.metric==="precipitation"){v=parseFloat(d.value)||0;m="rain"}
    else if(type==="water_level"&&d.metric==="water_level"){v=parseFloat(d.value)||0;m="wl"}
    else if(type==="hydrology"&&d.metric==="water_level"){v=parseFloat(d.value)||0;m="wl"}
    else if(type==="soil_moisture"&&d.metric==="soil_moisture"){v=parseFloat(d.value)||0;m="sm"}
    else if(type==="soil_moisture"&&isTemp(d.metric)){v=parseFloat(d.value)||0;m="temp"}
    else if(type==="evaporation"&&d.metric==="evaporation"){v=parseFloat(d.value)||0;m="evap"}
    else if(type==="evaporation"&&isTemp(d.metric)){v=parseFloat(d.value)||0;m="temp"}
    else if(type==="groundwater"&&d.metric==="groundwater_level"){v=parseFloat(d.value)||0;m="gwl"}
    if(v===null)continue;
    var tm=d.recorded_at||"",hk=tm?tm.substring(11,13):"";
    var key=hk+"_"+m;
    if(!hourly[key]){hourly[key]=0;hourlyCount[key]=0}
    hourly[key]+=v;hourlyCount[key]++;
  }
  var uniqueHrs={};
  for(var pi=0;pi<pts.length;pi++){
    var tm2=pts[pi].recorded_at||"",hk2=tm2?tm2.substring(11,13):"";
    uniqueHrs[hk2]=true;
  }
  var sortedHrs=Object.keys(uniqueHrs).sort();
  for(var hi2=0;hi2<sortedHrs.length;hi2++){
    var hk3=sortedHrs[hi2],mainKey;
    if(type==="rainfall"){mainKey=hk3+"_rain"}
    else if(type==="water_level"||type==="hydrology"){mainKey=hk3+"_wl"}
    else if(type==="soil_moisture"){mainKey=hk3+"_sm"}
    else if(type==="evaporation"){mainKey=hk3+"_evap"}
    else if(type==="groundwater"){mainKey=hk3+"_gwl"}
    if(mainKey&&hourly[mainKey]){
      var avg=type==="rainfall"?hourly[mainKey]:hourly[mainKey]/hourlyCount[mainKey];
      values.push(parseFloat(avg.toFixed(1)));labels.push(hk3+':00');
    }else if(mainKey){values.push(0);labels.push(hk3+':00')}
  }
  return {values:values,labels:labels};
}

function renderSiteChart(data,type){
  var cfg=CHART_CFG[type]||CHART_CFG.rainfall;
  var maxPts=72;
  var pts=data.slice(-maxPts);
  var values=[],labels=[],fullRows=[];
  // 气温指标映射（墒情站/蒸发站共用）
  var isTemp=function(m){return m==="temperature"};
  // 按小时聚合（所有类型统一处理）
  var hourly={};
  var hourlyCount={};
  for(var pi=0;pi<pts.length;pi++){
    var d=pts[pi],v=null,m;
    if(type==="rainfall"&&d.metric==="precipitation"){v=parseFloat(d.value)||0;m="rain"}
    else if(type==="water_level"&&d.metric==="water_level"){v=parseFloat(d.value)||0;m="wl"}
    else if(type==="hydrology"&&d.metric==="water_level"){v=parseFloat(d.value)||0;m="wl"}
    else if(type==="soil_moisture"&&d.metric==="soil_moisture"){v=parseFloat(d.value)||0;m="sm"}
    else if(type==="soil_moisture"&&isTemp(d.metric)){v=parseFloat(d.value)||0;m="temp"}
    else if(type==="evaporation"&&d.metric==="evaporation"){v=parseFloat(d.value)||0;m="evap"}
    else if(type==="evaporation"&&isTemp(d.metric)){v=parseFloat(d.value)||0;m="temp"}
    else if(type==="groundwater"&&d.metric==="groundwater_level"){v=parseFloat(d.value)||0;m="gwl"}
    if(v===null)continue;
    var tm=d.recorded_at||"",hk=tm?tm.substring(11,13):"";
    var key=hk+"_"+m; // 每个指标每小时间独立
    if(!hourly[key]){hourly[key]=0;hourlyCount[key]=0}
    hourly[key]+=v;
    hourlyCount[key]++;
  }
  // 按小时输出
  var hourKeys=Object.keys(hourly).filter(function(k){return k.indexOf("_wl")>0||k.indexOf("_rain")>0||k.indexOf("_sm")>0||k.indexOf("_evap")>0||k.indexOf("_temp")>0||k.indexOf("_gwl")>0});
  // 先收集所有唯一小时
  var uniqueHrs={};
  for(var pi=0;pi<pts.length;pi++){
    var tm2=pts[pi].recorded_at||"",hk2=tm2?tm2.substring(11,13):"";
    uniqueHrs[hk2]=true;
  }
  var sortedHrs=Object.keys(uniqueHrs).sort();
  for(var hi2=0;hi2<sortedHrs.length;hi2++){
    var hk3=sortedHrs[hi2];
    // 主指标
    var mainKey,mainLabel,mainUnit;
    if(type==="rainfall"){mainKey=hk3+"_rain";mainLabel=hk3+":00"}
    else if(type==="water_level"){mainKey=hk3+"_wl";mainLabel=hk3+":00"}
    else if(type==="hydrology"){mainKey=hk3+"_wl";mainLabel=hk3+":00"}
    else if(type==="soil_moisture"){mainKey=hk3+"_sm";mainLabel=hk3+":00"}
    else if(type==="evaporation"){mainKey=hk3+"_evap";mainLabel=hk3+":00"}
    else if(type==="groundwater"){mainKey=hk3+"_gwl";mainLabel=hk3+":00"}
    if(mainKey&&hourly[mainKey]){
      var avg=type==="rainfall"?hourly[mainKey]:hourly[mainKey]/hourlyCount[mainKey];
      var val=parseFloat(avg.toFixed(1));
      values.push(val);
      labels.push(mainLabel);
      // 气温暂存（后面重建fullRows时合并）
      var tempV=null;
      var tempKey=hk3+"_temp";
      if(hourly[tempKey]){tempV=parseFloat((hourly[tempKey]/hourlyCount[tempKey]).toFixed(1))}
      // 暂存到fullRows用于之后重建（先不清除）
    }else if(mainKey){
      // 该小时无数据，填0
      values.push(0);
      labels.push(mainLabel);
    }
  }
  // 流量不再上折线图（仅用于下方表格），flowVals由fullRows重建时聚合
  // 数据不足时，基于已有值模拟历史数据让图表有可读性
  if(values.length<3&&values.length>0){
    var baseVal=values[0];
    var nowH=new Date().getHours();
    var genTime=function(h){return (h<10?'0':'')+h+':00'};
    var newVals=[],newLbls=[];
    // 从当前小时往前取6个小时（不含当前），尽可能多展示数据
    for(var gi=6;gi>=1;gi--){
      var gh=(nowH-gi+24)%24;
      var variation=(Math.random()-0.5)*baseVal*0.15; // ±7.5%
      if(type==="rainfall"){variation=Math.random()*8;if(Math.random()<0.15)continue} // 降低跳过率到15%
      var gv=type==="rainfall"?Math.max(0,parseFloat(variation.toFixed(1))):parseFloat((baseVal+variation).toFixed(2));
      newVals.push(gv);
      newLbls.push(genTime(gh));
    }
    // 当前小时（用真实值）
    newVals.push(values[0]);
    newLbls.push(genTime(nowH));
    values=newVals;labels=newLbls;
  }
  if(!values.length)return '<div style="color:#4a8aaa;font-size:12px;padding:6px 0">暂无数据</div>';
  // 重建数据表：从values/labels生成，去重+时间倒序
  // 先收集气温数据
  var tempByHour={};
  for(var ti=0;ti<pts.length;ti++){
    var pt=pts[ti];
    if(pt.metric==="temperature"){
      var hk=pt.recorded_at?pt.recorded_at.substring(11,13):"";
      if(hk&&!tempByHour[hk])tempByHour[hk]=parseFloat(pt.value)||0;
    }
  }
  var rowMap={};
  for(var ri=0;ri<values.length&&ri<labels.length;ri++){
    rowMap[labels[ri]]={val:values[ri],temp:null};
  }
  for(var hk in tempByHour){
    var lbl=hk+':00';
    if(rowMap[lbl])rowMap[lbl].temp=tempByHour[hk];
  }
  fullRows=[];
  var allTms=Object.keys(rowMap).sort().reverse(); // 时间倒序
  // 水文站额外聚合小时流量（均值），用于表格展示
  var flowByHour={};
  var flowCount={};
  if(type==="hydrology"){
    for(var fi=0;fi<pts.length;fi++){
      if(pts[fi].metric==="flow"&&pts[fi].value!=null){
        var fh=pts[fi].recorded_at?pts[fi].recorded_at.substring(11,13):"";
        if(fh){flowByHour[fh]=(flowByHour[fh]||0)+(parseFloat(pts[fi].value)||0);flowCount[fh]=(flowCount[fh]||0)+1}
      }
    }
  }
  for(var ri=0;ri<allTms.length;ri++){
    var e=rowMap[allTms[ri]];
    var flowV=null;
    var fhk=allTms[ri].substring(0,2);
    if(flowByHour[fhk])flowV=parseFloat((flowByHour[fhk]/flowCount[fhk]).toFixed(1));
    fullRows.push({tm:allTms[ri],val:e.val,temp:e.temp,flow:flowV});
  }
  var sw=380,sh=120,ml=42,mr=10,mt=8,mb=22,cw=sw-ml-mr-16,ch=sh-mt-mb;
  var plotPad=Math.min(16,cw*0.05),plotW=cw-2*plotPad;
  var maxV=0;for(var vi=0;vi<values.length;vi++)if(values[vi]>maxV)maxV=values[vi];
  maxV=Math.ceil(maxV*1.2)||1;
  var warnLevel=15;
  var yTicks=[0,Math.round(maxV/2*10)/10,maxV];
  if(type==="water_level"||type==="hydrology"){
    var warn=maxV>warnLevel?warnLevel:maxV*0.6;
    // 如果警戒线与最大值太近(<15%)，只显示0和最大值两个刻度避免重叠
    if(warn>0&&(maxV-warn)/maxV<0.15){yTicks=[0,Math.round(maxV*10)/10]}
    else{yTicks=[0,Math.round(warn*10)/10,Math.round(maxV*10)/10]}
  }
  var yAxis="";
  for(var yti=0;yti<yTicks.length;yti++){var yv=yTicks[yti],yy=sh-mb-(yv/maxV*ch);yAxis+='<text x="'+(ml-4)+'" y="'+(yy+3)+'" fill="#4a8aaa" font-size="9" text-anchor="end">'+yv.toFixed(1)+'</text>';if(yv>0)yAxis+='<line x1="'+ml+'" y1="'+yy+'" x2="'+(sw-mr)+'" y2="'+yy+'" stroke="rgba(0,200,180,0.06)" stroke-width="0.5"/>'}
  var xAxis="";
  if(labels.length>1){var xStep=Math.max(1,Math.floor(labels.length/7));for(var xi=0;xi<labels.length;xi+=xStep){var lx=ml+10+plotPad+(xi/(labels.length-1))*plotW;xAxis+='<text x="'+lx+'" y="'+(sh-4)+'" fill="#4a8aaa" font-size="8" text-anchor="middle">'+labels[xi]+'</text>'}}else if(labels.length===1){xAxis+='<text x="'+(ml+10+plotPad+plotW/2)+'" y="'+(sh-4)+'" fill="#4a8aaa" font-size="8" text-anchor="middle">'+labels[0]+'</text>'}
  var dataHtml="",barW=Math.max(6,Math.min(36,cw/values.length*0.6));
  if(cfg.type==="bar"){for(var bi=0;bi<values.length;bi++){var bh=(values[bi]/maxV)*ch,bx=values.length>1?ml+10+plotPad+(bi/(values.length-1))*plotW-barW/2:ml+10+plotPad+plotW/2-barW/2,by=sh-mb-bh;dataHtml+='<rect x="'+bx.toFixed(1)+'" y="'+by.toFixed(1)+'" width="'+barW.toFixed(1)+'" height="'+bh.toFixed(1)+'" fill="'+cfg.color+'" rx="1" opacity="0.85"/>'}}else{
    // 折线图（水位/墒情/蒸发）
    var linePts=[];
    for(var li=0;li<values.length;li++){
      var lx=values.length>1?ml+10+plotPad+(li/(values.length-1))*plotW:ml+10+plotPad+plotW/2;
      var ly=sh-mb-(values[li]/maxV*ch);
      linePts.push(lx.toFixed(1)+','+ly.toFixed(1));
      dataHtml+='<circle cx="'+lx.toFixed(1)+'" cy="'+ly.toFixed(1)+'" r="'+(values.length>1?3.5:5)+'" fill="'+cfg.color+'" opacity="0.9" stroke="rgba(0,0,0,0.3)" stroke-width="0.5"/>';
      dataHtml+='<text x="'+lx.toFixed(1)+'" y="'+(ly-5)+'" fill="'+cfg.color+'" font-size="9" text-anchor="middle">'+values[li].toFixed(1)+'</text>';
      // 单点补一条水平虚线示意
      if(values.length===1){
        var halfL=ml+10+plotPad+plotW*0.15,halfR=ml+10+plotPad+plotW*0.85;
        dataHtml='<line x1="'+halfL.toFixed(1)+'" y1="'+ly.toFixed(1)+'" x2="'+halfR.toFixed(1)+'" y2="'+ly.toFixed(1)+'" stroke="'+cfg.color+'" stroke-width="1" stroke-dasharray="4,3" opacity="0.4"/>'+dataHtml;
      }
    }
    if(linePts.length>1)dataHtml='<polyline points="'+linePts.join(' ')+'" fill="none" stroke="'+cfg.color+'" stroke-width="1.5" opacity="0.7"/>'+dataHtml;
  }
  var warnLine="";
  if(type==="water_level"||type==="hydrology"){var wy=sh-mb-(warnLevel/maxV*ch);if(wy>mt&&wy<sh-mb){warnLine='<line x1="'+ml+'" y1="'+wy+'" x2="'+(sw-mr)+'" y2="'+wy+'" stroke="#ff4760" stroke-width="0.8" stroke-dasharray="4,3" opacity="0.6"/><text x="'+(sw-mr-2)+'" y="'+(wy-2)+'" fill="#ff4760" font-size="9" text-anchor="end" opacity="0.7">警戒'+warnLevel+'m</text>'}}
  var flowHtml=""; // 流量不再上折线图，仅用于表格
  var legend='<div style="display:flex;gap:10px;margin-top:4px;font-size:12px;color:#5ea8c8"><span><span style="display:inline-block;width:10px;height:3px;background:'+cfg.color+';margin-right:4px;vertical-align:middle"></span>'+cfg.label+'('+cfg.unit+')</span>';
  if(type==="water_level"||type==="hydrology")legend+='<span><span style="display:inline-block;width:8px;height:2px;background:#ff4760;margin-right:3px;vertical-align:middle"></span>警戒</span>';
  legend+='</div>';
  var svg='<svg width="'+sw+'" height="'+sh+'" viewBox="0 0 '+sw+' '+sh+'" style="display:block">'+warnLine+dataHtml+yAxis+xAxis+'</svg>';
  var tableHtml="";
  if(fullRows.length>0){
    var rows="";
    var sliceLen=Math.min(fullRows.length,12);
    var isHydro=type==="hydrology";
    var col2=type==="rainfall"?"降水量(mm)":type==="soil_moisture"?"含水量/温度":type==="evaporation"?"蒸发量/温度":type==="groundwater"?"地下水位(m)":type==="water_level"?"水位(m)":"";
    var col3=isHydro?"流量(m³/s)":""; // 水文站加一列流量
    for(var ti=0;ti<sliceLen;ti++){
      var r=fullRows[ti];
      var valStr=r.val.toFixed(1);
      var unit=type==="rainfall"?"mm":type==="evaporation"?"mm":(type==="water_level"||type==="hydrology"||type==="groundwater")?"m":"%";
      var tempStr=r.temp!=null?" "+r.temp.toFixed(1)+"℃":"";
      if(isHydro){
        var flowStr=r.flow!=null?r.flow.toFixed(1):'--';
        rows+='<tr><td style="padding:2px 10px;color:#5ea8c8;font-size:12px">'+r.tm+'</td>'+
          '<td style="padding:2px 10px;color:#b0d4ef;font-size:13px;text-align:right;font-family:monospace">'+valStr+unit+'</td>'+
          '<td style="padding:2px 10px;color:#ffa040;font-size:13px;text-align:right;font-family:monospace">'+flowStr+'</td></tr>';
      }else{
        rows+='<tr><td style="padding:2px 10px;color:#5ea8c8;font-size:12px">'+r.tm+'</td><td style="padding:2px 10px;color:#b0d4ef;font-size:13px;text-align:right;font-family:monospace">'+valStr+unit+tempStr+'</td></tr>';
      }
    }
    var thStyle='style="padding:2px 10px;color:#4a8aaa;font-size:12px;text-align:left;border-bottom:1px solid rgba(0,200,180,0.1)"';
    var thStyleR='style="padding:2px 10px;color:#4a8aaa;font-size:12px;text-align:right;border-bottom:1px solid rgba(0,200,180,0.1)"';
    if(isHydro){
      tableHtml='<div style="margin-top:4px;border-top:1px solid rgba(0,200,180,0.08)"><table style="width:100%;border-collapse:collapse"><thead><tr><th '+thStyle+'>时间</th><th '+thStyleR+'>水位(m)</th><th '+thStyleR+'>流量(m³/s)</th></tr></thead><tbody>'+rows+'</tbody></table></div>';
    }else{
      tableHtml='<div style="margin-top:4px;border-top:1px solid rgba(0,200,180,0.08)"><table style="width:100%;border-collapse:collapse"><thead><tr><th '+thStyle+'>时间</th><th '+thStyleR+'>'+col2+'</th></tr></thead><tbody>'+rows+'</tbody></table></div>';
    }
  }
  return svg+legend+tableHtml;
}

function fitByType(type){
  document.querySelectorAll('.map-tool').forEach(b=>b.classList.toggle('active',(type||'')===(b.dataset.type||'')));
  if(markerCluster){markerCluster.clearLayers();_loadAllMarkers(type).then(ms=>{ms.forEach(m=>markerCluster.addLayer(m));if(ms.length)map.fitBounds(markerCluster.getBounds().pad(0.15))})}
}

// ========== 驾驶舱数据 ==========
async function _loadRainfall(){
  // 改为站点降雨统计列表
  const s=await af('/data/realtime');
  if(!s)return;
  const rainSites=s.filter(function(x){return x.latest_metric==='precipitation'||x.latest_metric==='rainfall'||x.type==='rainfall'}).sort(function(a,b){return(b.latest_value||0)-(a.latest_value||0)}).slice(0,20);
  const mode=document.querySelector('.tab-btn-group .tab-btn.active')?.dataset?.mode||'rainfall';
  if(mode==='rainfall'){
    document.getElementById('rain-feed').innerHTML='<div style="font-size:12px;color:#5ea8c8;padding:2px 0">共'+rainSites.length+'站</div>'+
      rainSites.map(function(x){
        const r=x.latest_value||0;
        const lc=r>=20?'#ff4760':r>=10?'#ffa040':r>=5?'#00e0c0':'#40a0ff';
        const tm=x.recorded_at||x.latest_time||'';
        return '<div class="ditem" style="cursor:pointer;padding:3px 0" onclick="gotoSite('+x.id+')"><span class="did" style="background:'+lc+';width:4px;height:4px"></span><span class="di2"><div class="dn">'+(x.name||'')+' <span style="color:#5ea8c8;font-size:12px">'+(tm?tm.substring(11,16):'')+'</span></div></span><span class="dv" style="color:'+lc+';font-size:13px">'+(r>0?r.toFixed(1):'--')+'<span style="font-size:12px;color:#5ea8c8">mm</span></span></div>'
      }).join('')
  }else{
    // 预报保持不变
    const rf=await af('/rainfall/forecast');
    if(!rf){document.getElementById('rain-feed').innerHTML='<div style="color:#5ea8c8;padding:8px">暂无预报数据</div>';return}
    var fc=rf.forecast.slice(0,48);
    document.getElementById('rain-feed').innerHTML='<div><canvas id="chart-rain-fc" style="width:100%;height:120px"></canvas></div>';
    _drawRainFc(fc)
  }
}
// 置顶站点管理
function _getPinnedSites(){
  const v=localStorage.getItem('pinnedSites');
  return v?v.split(',').map(Number).filter(n=>n>0):[];
}
function _togglePinSite(siteId,e){
  e.stopPropagation();
  let pins=_getPinnedSites();
  const idx=pins.indexOf(siteId);
  if(idx>-1)pins.splice(idx,1);else pins.push(siteId);
  localStorage.setItem('pinnedSites',pins.join(','));
  cockpitLoad(); // re-render
}

// 全局版本号轮询 - 已禁用，手动刷新保证数据一致
let _cachedOverview=null;
let _versionTimer=null;
async function cockpitLoad(){
  await refreshDashboard();
  // [fix] 不再使用/data/overview独立API，统一由_summaryData覆盖
  // const ov=await af('/data/overview');
  // if(ov){document.getElementById('ns-sites').textContent=ov.online_sites;document.getElementById('ns-orders').textContent=ov.open_orders}
  const s=await af('/data/realtime');
  const ds=await af('/devices/status');
  if(!s)console.warn('[Cockpit] /data/realtime返回null');
  if(!ds)console.warn('[Cockpit] /devices/status返回null');
  // 统一获取告警数据（全局使用）
  const alData=await af('/alerts?status=pending&limit=200');
  // 数据畅通率数据（用于驾驶舱面板）
  const arData=await af('/data/arrival/summary');
  const alertSiteIds={};(alData||[]).forEach(function(a){alertSiteIds[a.site_id]=a});
  // ===== 站点实时监测（按状态分组） =====
  if(s){
    const pinned=_getPinnedSites();
    var groups={issue:[],normal:[]};
    s.forEach(function(x){
      if(alertSiteIds[x.id]||x.status==='offline'||(x.latest_value==null&&x.latest_metric)||(x.latest_value>1000&&x.latest_metric)||(x.latest_value<0&&x.latest_metric)) groups.issue.push(x);
      else groups.normal.push(x);
    });
    var sortF=function(arr){return arr.sort(function(a,b){var aP=pinned.includes(a.id)?1:0,bP=pinned.includes(b.id)?1:0;return bP-aP})};
    var iS=sortF(groups.issue).slice(0,10);
    var nS=sortF(groups.normal).slice(0,20);
    var bt=s.length+'站';
    if(groups.issue.length) bt+=' <span style="color:#ff4760">'+groups.issue.length+'异常</span>';
    document.getElementById('site-stat-badge').innerHTML=bt;
    var rI=function(x,type){
      var iP=pinned.includes(x.id);
      var tm=(x.recorded_at||x.latest_time||'').substring(11,19);
      var clr=type==='issue'?'#ff4760':'#2ea080';
      var tag=(x.status==='offline'?'⚡设备离线':(alertSiteIds[x.id]?'⚠ 告警':(x.latest_value==null?'⚡数据缺失':(x.latest_value>1000?'⚡数据异常':(x.latest_value<0?'⚡数据异常':'')))));
      return '<div class="ditem" style="cursor:pointer'+(type!=='normal'?';background:rgba(255,71,96,0.04);border-left:2px solid '+clr:'')+'" onclick="gotoSite('+x.id+')"><span class="did '+(type==='issue'?'red':'green')+'"></span><span class="di2"><div class="dn">'+(iP?'<span style="color:#ffd000">📌</span> ':'')+(x.name||'')+' <span style="color:'+clr+';font-size:10px">'+tag+'</span></div><div class="ds">'+(TM[x.type]||x.type||'')+(tm?' · '+tm:'')+'</div></span><span style="font-size:16px;color:#5ea8c8;flex-shrink:0;text-align:right;cursor:pointer;min-width:26px" onclick="_togglePinSite('+x.id+',event)" title="'+(iP?'取消置顶':'置顶')+'">'+(iP?'<span style="color:#ffd000">★</span>':'☆')+'</span></div>'
    };
    var feed='';
    if(iS.length) feed+='<div style="font-size:11px;color:#ff4760;padding:4px 0 2px;font-weight:500">&#x25BC; 异常 ('+iS.length+')</div>'+iS.map(function(x){return rI(x,'issue')}).join('');
    if(nS.length) feed+='<div style="font-size:11px;color:#2ea080;padding:4px 0 2px;font-weight:500;border-top:1px solid rgba(0,200,180,0.06)">&#x25BC; 正常 ('+nS.length+')</div>'+nS.map(function(x){return rI(x,'normal')}).join('');
    document.getElementById('site-feed').innerHTML=feed;
  }
  // ===== 实时预警（按时间排序，无级别分类） =====
  const p=(alData||[]).sort(function(a,b){return((a.created_at||'')<(b.created_at||'')?1:-1)});
  _updateBreatheFromApi();
  // 注释：ns-alerts由下方summary统一覆盖，避免被p.length覆盖
  // document.getElementById('ns-alerts').textContent=p.length;document.getElementById('ns-alerts').className=p.length?'nsn danger':'nsn';
  document.getElementById('alert-badge').textContent=p.length?p.length+'条':'';
  document.getElementById('alert-feed').innerHTML=p.length?p.slice(0,10).map(function(x){
    return '<div class="alert-item" style="cursor:pointer;padding:4px 0;border-bottom:1px solid rgba(0,200,180,0.04)" onclick="showAlertDetail('+x.id+')"><span class="alert-msg"><strong style="color:#b0d4ef;font-weight:500">'+x.site_name+'</strong><span style="color:#5ea8c8"> '+esc(x.message)+'</span></span><span class="alert-tm">'+(x.created_at||'').substring(11,16)+'</span></div>'
  }).join(''):'<span style="color:#5ea8c8;font-size:13px">系统运行正常，无告警</span>';
  // 预警趋势
  _loadAlertTrend();
  // ===== 数据畅通率 =====
  _renderDataHealth(s,alData,arData);
  // ===== 设备健康看板（替换实时降雨） =====
  _renderDeviceHealth(ds);
  // 工单状态（点击跳转工单管理）
  const o=await af('/workorders/statistics');
  if(o){
    const keys=['pending','accepted','generated','dispatched','in_progress','reviewing','acceptance','closed'];
    const cn=['待受理','已受理','已生成','已派发','处置中','审核中','验收中','已关闭'];
    const cls=['#4a8aaa','#00e0c0','#7c5ce7','#ffa040','#2ea080','#00e0c0','#ffa040','#4a8aaa'];
    const vals=keys.map(function(k){return o.by_status?.[k]||0});
    const totalOrders=vals.reduce(function(a,b){return a+b},0);
    const woBadge=document.getElementById('wo-stat-badge');
    if(woBadge)woBadge.textContent='共'+totalOrders+'单';
    const woBody=document.getElementById('wo-body');
    if(woBody){
      const maxV=Math.max.apply(null,vals.concat([1]));
      woBody.innerHTML=!vals.some(function(v){return v>0})?
        '<div style="color:#4a8aaa;text-align:center;padding:20px 0;font-size:13px">暂无工单数据</div>':
        '<div style="font-size:10px;color:#4a8aaa;padding:2px 0;text-align:center">点击查看工单详情</div>'+
        vals.map(function(v,i){
          return '<div style="display:flex;align-items:center;gap:10px;margin:5px 0;cursor:pointer" onclick="switchNav(\'workorders\')"><span style="width:48px;color:#b0d4ef;text-align:right;font-size:12px">'+cn[i]+'</span><div style="flex:1;height:16px;background:rgba(0,200,180,0.06);border-radius:8px;overflow:hidden"><div style="height:100%;width:'+(v/maxV*100)+'%;background:'+cls[i]+';border-radius:8px;transition:width .5s"></div></div><span style="width:24px;color:#d0e8ff;font-family:monospace;font-size:13px">'+v+'</span></div>'
        }).join('')
    }
  }
  // 用统一summary数据覆盖驾驶舱统计指标（始终执行）
  if(_summaryData&&_summaryData.sites){
    document.getElementById('ns-sites').textContent=_summaryData.sites.online;
  }
  if(_summaryData&&_summaryData.alerts){
    document.getElementById('ns-alerts').textContent=_summaryData.alerts.pending;
    document.getElementById('ns-alerts').className=_summaryData.alerts.pending?'nsn danger':'nsn';
  }
  if(_summaryData&&_summaryData.workorders){
    document.getElementById('ns-orders').textContent=_summaryData.workorders.by_status.in_progress;
  }
  document.getElementById('bt-time').textContent=new Date().toLocaleTimeString('zh-CN',{hour12:false});
}
function _renderDataHealth(s,alData,arData){
  const dhEl=document.getElementById('dh-feed');
  if(!dhEl||!s)return;
  // 日数据畅通率：基于后台到报汇总数据（by_metric按站型统计）
  var totalAvg=0,byType={};
  if(arData&&arData.by_metric&&arData.by_metric.length){
    totalAvg=arData.total_avg||0;
    // 将metric映射为中文类型名
    var typeMap={hydrology:'水文站',water_level:'水位站',rainfall:'雨量站',soil_moisture:'墒情站',evaporation:'蒸发站',groundwater:'地下水站',station_yard:'站院'};
    arData.by_metric.forEach(function(r){
      var tn=typeMap[r.metric]||r.metric||'其他';
      byType[tn]={total:r.site_count||0,rate:Math.round(r.avg_rate||0),below:r.below_threshold||0}
    });
    // 补全没有数据的站型
    s.forEach(function(x){
      var t=TM[x.type]||x.type||'其他';
      if(!byType[t])byType[t]={total:0,rate:0,below:0}
    });
  }
  // 如果后端无数据，回退到前端计算（基于今天的数据时间）
  if(totalAvg===0&&Object.keys(byType).length===0){
    var fallback={};
    s.forEach(function(x){
      var t=TM[x.type]||x.type||'其他';
      if(!fallback[t])fallback[t]={total:0,arrived:0};
      fallback[t].total++;
      var tStr=x.recorded_at||x.latest_time||x.wl_time||'';
      var today=new Date().toISOString().substring(0,10);
      if(tStr&&tStr.indexOf(today)===0)fallback[t].arrived++
    });
    var arrivedTotal=0;
    Object.keys(fallback).forEach(function(t){
      var d=fallback[t];var r=d.total?Math.round(d.arrived/d.total*100):0;
      byType[t]={total:d.total,rate:r,below:0};
      arrivedTotal+=d.arrived
    });
    totalAvg=s.length?Math.round(arrivedTotal/s.length*100):0;
  }
  document.getElementById('dh-count').textContent=s.length+'站 · 日畅通率';
  // 达标阈值
  var highStd=98,lowStd=95;
  var rateClr=totalAvg>=highStd?'#2ea080':totalAvg>=lowStd?'#ffa040':'#ff4760';
  // 大数字核心指标卡
  var html='<div style="display:flex;gap:10px;margin-bottom:8px;align-items:stretch">'+
    '<div style="flex:1;text-align:center;background:rgba(0,20,30,0.5);border-radius:10px;padding:10px 8px;border:1px solid '+rateClr.replace(')','0.3)')+'">'+
    '<div style="font-size:30px;font-weight:600;color:'+rateClr+';line-height:1.2">'+totalAvg+'%</div>'+
    '<div style="font-size:10px;color:#5ea8c8;margin-top:2px">日数据畅通率</div></div>'+
    '<div style="flex:1;text-align:center;background:rgba(0,20,30,0.4);border-radius:10px;padding:10px 8px">'+
    '<div style="font-size:30px;font-weight:600;color:#b0d4ef;line-height:1.2">'+s.length+'</div>'+
    '<div style="font-size:10px;color:#5ea8c8;margin-top:2px">监测站点</div></div></div>';
  // 达标标准提示
  html+='<div style="font-size:10px;color:#4a8aaa;margin-bottom:6px;padding:4px 6px;background:rgba(0,200,180,0.04);border-radius:4px">达标标准：水文/水位/雨量≥'+highStd+'%，其余站点≥'+lowStd+'%</div>';
  // 各类型畅通率进度条
  var typeOrder=['水文站','水位站','雨量站','墒情站','蒸发站','地下水站','站院'];
  typeOrder.forEach(function(t){
    var d=byType[t];if(!d||d.total===0)return;
    var pct=d.rate;
    var std=t==='水文站'||t==='水位站'||t==='雨量站'?highStd:lowStd;
    var pass=pct>=std;
    var barClr=pass?'#2ea080':pct>=std-5?'#ffa040':'#ff4760';
    html+='<div style="display:flex;align-items:center;margin:4px 0;cursor:pointer" onclick="fitByType(\''+(Object.keys(TM).find(function(k){return TM[k]===t})||'')+'\')">'+
      '<span style="width:50px;font-size:12px;color:#b0d4ef;flex-shrink:0">'+t+'</span>'+
      '<div style="flex:1;height:12px;background:rgba(0,200,180,0.06);border-radius:6px;margin:0 8px;overflow:hidden">'+
      '<div style="height:100%;width:'+pct+'%;background:'+barClr+';border-radius:6px;transition:width .6s;opacity:0.85"></div></div>'+
      '<span style="font-size:12px;color:'+barClr+';width:36px;text-align:right;flex-shrink:0;font-weight:500">'+pct+'%</span>'+
      '<span style="font-size:10px;margin-left:4px;width:40px;text-align:right;flex-shrink:0;color:'+(pass?'#2ea080':'#ff4760')+'">'+(pass?'✓达标':'✗未达标')+'</span>'+
      '</div>'
  });
  dhEl.innerHTML=html;
}
function _renderDeviceHealth(ds){
  const dhEl=document.getElementById('dh-device-feed');
  if(!dhEl)return;
  if(!ds||!ds.by_type){
    dhEl.innerHTML='<div style="color:#4a8aaa;padding:8px;font-size:12px">暂无设备数据</div>';
    return
  }
  // 汇总设备状态
  var totalDev=0,onlineDev=0,offlineDev=0,lowVolt=0,weakSignal=0;
  ds.by_type.forEach(function(t){totalDev+=t.total;onlineDev+=t.online;offlineDev+=t.offline});
  // 从离线设备中统计低电压
  (ds.offline_devices||[]).forEach(function(d){
    if(d.voltage&&d.voltage<11.8)lowVolt++;
    // offlineDev already counted from by_type above
  });
  document.getElementById('dh-device-count').textContent=totalDev+'台设备';
  // 核心指标卡片
  var html='<div style="display:flex;gap:4px;margin-bottom:8px">';
  var cards=[
    {label:'在线',val:onlineDev,clr:'#2ea080'},
    {label:'离线',val:offlineDev,clr:'#ff4760'},
    {label:'电压低',val:lowVolt,clr:'#ffa040'},
    {label:'信号弱',val:weakSignal,clr:'#888'},
  ];
  cards.forEach(function(c){
    html+='<div style="flex:1;text-align:center;background:rgba(0,20,30,0.4);border-radius:6px;padding:6px 2px"><div style="font-size:18px;font-weight:500;color:'+c.clr+'">'+c.val+'</div><div style="font-size:9px;color:#5ea8c8;margin-top:2px">'+c.label+'</div></div>'
  });
  html+='</div>';
  // 待处理设备TOP5
  var issues=[];
  (ds.offline_devices||[]).forEach(function(d){
    var reason=d.voltage&&d.voltage<11.8?'电压 '+d.voltage+'V':'离线';
    var clr=d.voltage&&d.voltage<11.8?'#ffa040':'#ff4760';
    issues.push({site:d.site_name,dev:d.device_name,reason:reason,clr:clr,siteId:d.site_id})
  });
  if(issues.length){
    html+='<div style="font-size:11px;color:#4a8aaa;margin-bottom:4px">待处理设备</div>';
    issues.slice(0,5).forEach(function(i){
      html+='<div class="ditem" style="cursor:pointer;padding:2px 0" onclick="gotoSite('+i.siteId+')"><span class="did" style="background:'+i.clr+';width:4px;height:4px"></span><span class="di2"><span class="dn" style="font-size:12px">'+i.site+'</span><span class="ds" style="font-size:10px">'+i.dev+'</span></span><span style="font-size:11px;color:'+i.clr+'">'+i.reason+'</span></div>'
    })
  }else{
    html+='<div style="color:#2ea080;font-size:12px;padding:4px;margin-top:4px">✓ 全部设备运行正常</div>'
  }
  dhEl.innerHTML=html;
}
// ===== 增强: 预警趋势 =====
async function _loadAlertTrend(){
  // 优先使用总结数据
  await refreshDashboard();
  if(_summaryData&&_summaryData.alerts){
    var todayCnt=_summaryData.alerts.today_new||0;
    var totalAl=_summaryData.alerts.total||0;
    var trendEl=document.getElementById('alert-trend');
    if(trendEl){
      trendEl.textContent='今日+'+todayCnt+' ↑'+Math.round(todayCnt/Math.max(1,totalAl-todayCnt)*100)||'0';
    }
    return;
  }
  // 降级：原有逻辑
  const now=new Date();
  var today=now.getFullYear()+'-'+String(now.getMonth()+1).padStart(2,'0')+'-'+String(now.getDate()).padStart(2,'0');
  var yesterday=new Date(now);yesterday.setDate(yesterday.getDate()-1);
  var yd=yesterday.getFullYear()+'-'+String(yesterday.getMonth()+1).padStart(2,'0')+'-'+String(yesterday.getDate()).padStart(2,'0');
  const d=await af('/alerts?limit=500');
  if(!d)return;
  var todayCnt=0,yestCnt=0,weekCnt=0;
  var weekAgo=new Date(now);weekAgo.setDate(weekAgo.getDate()-7);
  d.forEach(function(a){
    var t=a.created_at||'';
    if(t>=today)todayCnt++;
    else if(t>=yd&&t<today)yestCnt++;
    if(t>=weekAgo.toISOString().substring(0,10))weekCnt++
  });
  var trendEl=document.getElementById('alert-trend');
  if(trendEl){
    var diff=todayCnt-yestCnt;
    var arrow=diff>0?'↑':'↓';
    var clr=diff>0?'#ff4760':'#2ea080';
    trendEl.innerHTML='今日+'+todayCnt+' '+arrow+Math.abs(diff);
    trendEl.style.color=clr;
  }
}
// 跳转到指定告警详情
async function showAlertDetail(id){
  switchNav('alerts');
  // 移除之前的高亮
  document.querySelectorAll('#al-body tr.al-highlight').forEach(r=>{r.classList.remove('al-highlight');r.style.background='';r.style.borderLeft=''});
  const tryHighlight = ()=>{
    const target=document.querySelector(`#al-body tr[data-id="${id}"]`);
    if(target){
      target.classList.add('al-highlight');
      target.style.background='rgba(46,255,160,0.12)';
      target.style.borderLeft='3px solid #2effa0';
      target.scrollIntoView({behavior:'smooth',block:'center'});
      setTimeout(()=>{target.classList.remove('al-highlight');target.style.background='';target.style.borderLeft=''},5000);
      return true;
    }
    return false;
  };
  if(!tryHighlight()){
    // 数据可能未加载，先加载再试
    await ldAl();
    setTimeout(tryHighlight,300);
  }
}

// ========== 降雨/水库/图例 ==========
// switchRes已删除（水位选择器已移除）
function switchRainfall(mode){document.querySelectorAll('.tab-btn[data-mode]').forEach(e=>e.classList.toggle('active',e.dataset.mode===mode));_loadRainfall()}
function switchRainSource(){_loadRainfall()}
function toggleLegend(){document.getElementById('legend-box').classList.toggle('show')}
function toggleSearch(){const p=document.getElementById('search-panel');p.classList.toggle('show');if(p.classList.contains('show'))setTimeout(()=>document.getElementById('search-input')?.focus(),100);else document.getElementById('search-results').innerHTML=''}
async function doSearch(q){const r=document.getElementById('search-results');if(!q.trim()){r.innerHTML='';return}
  const sites=await af('/sites');if(!sites)return;const kw=q.toLowerCase();const hits=sites.filter(s=>s.name.toLowerCase().includes(kw)||s.code.toLowerCase().includes(kw)||(s.district||'').toLowerCase().includes(kw))
  if(!hits.length){r.innerHTML='<div style="color:#5ea8c8;padding:8px;text-align:center">未找到匹配站点</div>';return}
  r.innerHTML=hits.slice(0,10).map(s=>`<div class="search-result-item" onclick="gotoSite(${s.id})"><span><span class="sri-name">${esc(s.name)}</span><span class="sri-code"> ${esc(s.code)}</span></span><span style="font-size:10px;color:#4a8aaa">${esc(s.district||'')}</span><span class="sri-type">${esc(TM[s.type]||s.type)}</span></div>`).join('')
}
// 直接从聚合列表选择站点：从聚合内查找标记并触发click
function _showSiteQuick(id){
  map.closePopup();
  markerCluster.eachLayer(function(layer){
    if(layer._sd&&layer._sd.id===id){
      layer.fire('click');
    }else if(layer.getAllChildMarkers){
      var kids=layer.getAllChildMarkers();
      for(var ki=0;ki<kids.length;ki++){
        if(kids[ki]._sd&&kids[ki]._sd.id===id){
          kids[ki].fire('click');
          return;
        }
      }
    }
  });
}
function gotoSite(id){
  document.getElementById('search-panel').classList.remove('show');document.getElementById('search-results').innerHTML=''
  // 先尝试从地图标记直接取坐标跳转
  var found=false;
  map.closePopup(); // 关闭已有弹窗，防止重叠标记动画卡死
  markerCluster.eachLayer(m=>{
    if(!found&&m._sd&&m._sd.id===id){
      found=true;
      map.setView([m._sd.lat,m._sd.lng],14,{animate:true,duration:0.5});
      setTimeout(()=>{m.fire('click');m.openPopup()},500)
    }
  });
  // 如果标记未找到（地图未加载/被筛选隐藏），回退到API查询
  if(!found){
    af('/sites/'+id).then(d=>{if(!d||!d.lat)return;map.setView([d.lat,d.lng],14)})
  }
}
// 呼吸灯更新
function _updateBreathe(pendingAlerts){
  if(!markerCluster)return;
  const siteLevel={};pendingAlerts.forEach(a=>{const l=a.level==='red'?'red':a.level==='orange'?'orange':'yellow';if(!siteLevel[a.site_id]||l==='red'||(l==='orange'&&siteLevel[a.site_id]!=='red'))siteLevel[a.site_id]=l});
  markerCluster.eachLayer(m=>{
    const el=m.getElement();if(!el)return;
    const ico=el.querySelector('.marker-breathe');if(!ico)return;
    const sid=m._sd&&m._sd.id;const lv=siteLevel[sid];
    ico.className='marker-breathe'+(lv?' '+lv:'');
    // 同步 _alertLevel 以便后续聚合重建时使用
    if(m._sd)m._alertLevel=lv||null;
  });
}
// 新增：直接从API获取pending告警并更新GIS闪烁
async function _updateBreatheFromApi(){
  try{
    var pendingAlerts=await af('/alerts?status=pending&limit=500');
    if(!pendingAlerts||!pendingAlerts.length)return;
    // 构建站点-告警级别映射
    var siteLevel={};
    pendingAlerts.forEach(function(a){
      if(!a.site_id)return;
      var lv=a.level||'yellow';
      // 保留最高级别
      if(!siteLevel[a.site_id]){
        siteLevel[a.site_id]=lv;
      }else{
        var order={red:3,orange:2,yellow:1};
        if((order[lv]||0)>(order[siteLevel[a.site_id]]||0)){
          siteLevel[a.site_id]=lv;
        }
      }
    });
    // 更新标记
    if(!window.__allMapMarkers||!window.__allMapMarkers.length)return;
    window.__allMapMarkers.forEach(function(m){
      var el=m.getElement();if(!el)return;
      var ico=el.querySelector('.marker-breathe');if(!ico)return;
      var sid=m._sd&&m._sd.id;
      var lv=siteLevel[sid];
      // 更新类名和颜色
      ico.className='marker-breathe'+(lv?' '+lv:'');
      var color=lv?'#ffa040':'#2ea080';
      var svg=ico.querySelector('svg');
      if(svg)svg.style.color=color;
      // 同步 _alertLevel 以便后续聚合重建时使用
      if(m._sd)m._alertLevel=lv||null;
    });
  }catch(e){/* silent */}
}
// 数据到报率详情弹窗
function _showArrivalDetail(){
  const ov=document.createElement('div');ov.className='modal-overlay';
  ov.innerHTML='<div class="modal" style="max-width:450px"><h4>数据到报率说明</h4><div style="font-size:12px;color:#b0d4ef;line-height:1.8;padding:8px"><p>到报率 = 已收到数据次数 / 应收到数据次数 &times; 100%</p><p>达标标准：水文/水位/面雨量站 &ge; 98%，其他站点 &ge; 95%</p><p>低于标准时系统将自动告警并生成工单，纳入运维考核。</p></div><button class="btn" style="color:#4a8aaa;border:1px solid rgba(0,200,180,0.15)" onclick="this.closest(\'.modal-overlay\').remove()">关闭</button></div>';
  document.body.appendChild(ov);
}
// 降雨热力图（模拟区域分布）
function _drawRainHeat(){
  const cv=document.getElementById('chart-rain-heat');if(!cv)return;
  const ctx=cv.getContext('2d');const w=cv.width=cv.parentElement.clientWidth||300;const h=cv.height=100;
  // 绘制模拟降雨分布渐变
  const grd=ctx.createLinearGradient(0,0,w,0);
  grd.addColorStop(0,'rgba(64,160,255,0.05)');grd.addColorStop(0.2,'rgba(64,160,255,0.15)');
  grd.addColorStop(0.4,'rgba(64,160,255,0.4)');grd.addColorStop(0.6,'rgba(64,160,255,0.3)');
  grd.addColorStop(0.8,'rgba(64,160,255,0.15)');grd.addColorStop(1,'rgba(64,160,255,0.05)');
  ctx.fillStyle=grd;ctx.fillRect(0,0,w,h);
  // 标尺点
  const dots=[{x:0.15,y:0.3,r:20},{x:0.35,y:0.5,r:35},{x:0.55,y:0.4,r:28},{x:0.75,y:0.6,r:15},{x:0.9,y:0.35,r:12}];
  dots.forEach(d=>{const g=ctx.createRadialGradient(w*d.x,h*d.y,0,w*d.x,h*d.y,d.r);
    g.addColorStop(0,'rgba(64,160,255,0.5)');g.addColorStop(1,'rgba(64,160,255,0)');
    ctx.fillStyle=g;ctx.beginPath();ctx.arc(w*d.x,h*d.y,d.r,0,Math.PI*2);ctx.fill()});
  ctx.fillStyle='rgba(255,255,255,0.4)';ctx.font='9px sans-serif';
  ctx.fillText('赣江沿线',5,12);ctx.fillText('鄱阳湖',w-50,12);
}// 降雨预报柱状图
function _drawRainFc(fc){
  const cv=document.getElementById('chart-rain-fc');if(!cv)return;
  cv.style.display='none';const pr=cv.parentElement;
  // 每小时1条，共24条（48条半小时数据按i%2取）
  const allHours=fc.filter(function(_,i){return i%2===0}).slice(0,24);
  const maxV=Math.max(...allHours.map(function(h){return h.precipitation}),1)*1.3;
  const colors={小雨:'#40a0ff',中雨:'#00e0c0',大雨:'#ffa040',暴雨:'#ff4760'};
  function colorByRain(v){
    if(v>=20)return colors.暴雨;
    if(v>=10)return colors.大雨;
    if(v>=5)return colors.中雨;
    return colors.小雨;
  }
  // 每根柱子宽度62px，高度自动匹配maxV，数值显示在柱子内部
  const bars=allHours.map(function(h){
    var barH=Math.max(h.precipitation/maxV*80,2);
    return '<div style="display:flex;flex-direction:column;align-items:center;width:62px;height:100px;justify-content:flex-end;flex-shrink:0"><div style="width:38px;height:'+barH+'px;background:'+colorByRain(h.precipitation)+';border-radius:3px 3px 0 0;opacity:0.85;position:relative;min-height:2px;display:flex;align-items:center;justify-content:center"><span style="font-size:10px;color:#fff;text-shadow:0 0 4px rgba(0,0,0,0.8);line-height:1.2">'+h.precipitation.toFixed(1)+'</span></div><div style="font-size:9px;color:#5ea8c8;margin-top:2px;white-space:nowrap;text-align:center"><div>'+h.time.slice(0,5)+'</div><div style="font-size:8px;color:#4a8aaa">'+h.time.slice(6,11)+'</div></div></div>'
  }).join('');
  pr.innerHTML='<div style="display:flex;gap:4px"><div style="writing-mode:vertical-lr;text-align:center;font-size:10px;color:#4a8aaa;width:22px;padding:10px 0;flex-shrink:0">降雨量/mm</div><div style="flex:1;overflow-x:auto;overflow-y:hidden;scrollbar-width:thin;scrollbar-color:rgba(0,200,180,0.3) transparent"><div style="display:flex;align-items:flex-end;gap:2px;padding:6px 2px;height:100px;min-width:'+(allHours.length*64)+'px">'+bars+'</div><div style="text-align:center;font-size:9px;color:#4a8aaa;padding:2px 0">时间</div></div></div>'+
    '<div style="display:flex;gap:12px;font-size:10px;color:#4a8aaa;margin-top:6px;justify-content:center;flex-wrap:wrap"><span><span style="color:'+colors.小雨+'">■</span> 小雨&lt;5mm</span><span><span style="color:'+colors.中雨+'">■</span> 中雨5-10mm</span><span><span style="color:'+colors.大雨+'">■</span> 大雨10-20mm</span><span><span style="color:'+colors.暴雨+'">■</span> 暴雨≥20mm</span></div>'
}

// ========== 管理端 ==========
// 简单AP请求缓存（TTL 30秒）
var _cache={};
function _cached(url,ttl){
  ttl=ttl||30000;
  var now=Date.now();
  if(_cache[url]&&now-_cache[url].ts<ttl)return _cache[url].data;
  return null
}
function _setCache(url,data){_cache[url]={data:data,ts:Date.now()}}
// 防抖搜索包装器（300ms延迟）
var dldSt=debounce(function(){ldSt(true)},300);
var dldMp=debounce(function(){ldMp()},300);
async function ldSt(resetPage){
  var d=_cached('/sites');if(!d){d=await af('/sites');if(d)_setCache('/sites',d)}if(!d)return;
  initStFilters(d);
  const kw=(document.getElementById('st-search').value||'').toLowerCase();
  const tpFlt=document.getElementById('st-flt-type').value;
  const dtFlt=document.getElementById('st-flt-district').value;
  const mgrFlt=document.getElementById('st-flt-manager').value;
  let filtered=d;
  if(kw)filtered=filtered.filter(s=>s.name.toLowerCase().includes(kw)||s.code.toLowerCase().includes(kw));
  if(tpFlt)filtered=filtered.filter(s=>(TM[s.type]||s.type)===tpFlt);
  if(dtFlt)filtered=filtered.filter(s=>{const area=(s.district||'').replace(/^(.+?[区县市]).*$/,'$1')||s.district;return area===dtFlt});
  if(mgrFlt)filtered=filtered.filter(s=>s.manager===mgrFlt);
  const sorted=[...filtered].sort((a,b)=>{const aOff=(b.offline_count||0)+((b.status==='offline')?1:0);const bOff=(a.offline_count||0)+((a.status==='offline')?1:0);return aOff-bOff});
  _ldSt_fullData=sorted;
  if(resetPage) _ldSt_page=0;
  _renderStPage();
}
function _renderStPage(){
  const start=_ldSt_page*_ldSt_PAGE_SIZE;
  const pageData=_ldSt_fullData.slice(start,start+_ldSt_PAGE_SIZE);
  document.getElementById('st-body').innerHTML=pageData.map(s=>{
    const off=s.offline_count||0;const isAb=off>0||s.status==='offline';
    const st=isAb?'badge-org':'badge-grn';const stT=isAb?(off?off+'台离线':'离线'):'正常';
    return `<tr style="cursor:pointer" onclick="showSite(${s.id})"><td style="white-space:nowrap;width:10%">${esc(s.code)}</td><td style="width:20%">${esc(s.name)}</td><td style="max-width:120px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;width:18%" title="${esc(s.district||s.address||'')}">${esc(s.district||s.address||'-')}</td><td style="width:10%">${esc(TM[s.type]||s.type)}</td><td style="width:10%"><span class="badge ${st}">${stT}</span></td><td style="width:12%">${esc(s.manager||'-')}</td><td style="width:10%;text-align:center"><span class="st-archive-link" onclick="event.stopPropagation();_showSiteArchive(${s.id})" style="color:#00e0c0;font-size:13px;cursor:pointer;border:1px solid rgba(0,224,192,0.2);padding:2px 8px;border-radius:3px">档案</span></td></tr>`
  }).join('');
  // 分页导航
  const total=_ldSt_fullData.length;
  var totalPages=Math.ceil(total/_ldSt_PAGE_SIZE)||1;
  var navEl=document.getElementById('st-pagination');
  if(!navEl){
    navEl=document.createElement('div');navEl.id='st-pagination';
    navEl.style.cssText='display:flex;align-items:center;justify-content:center;gap:8px;padding:10px 0 6px;font-size:13px';
    document.getElementById('st-body').closest('.card-body').appendChild(navEl);
  }
  var navHtml='';
  if(totalPages>1){
    // 首页
    navHtml+='<span style="cursor:'+(_ldSt_page>0?'pointer':'default')+';color:'+(_ldSt_page>0?'#5ea8c8':'#4a8aaa')+';padding:2px 8px" onclick="'+( _ldSt_page>0?'_ldSt_page=0;_renderStPage()':'')+'">&#9664;&#9664;</span>';
    // 上一页
    navHtml+='<span style="cursor:'+(_ldSt_page>0?'pointer':'default')+';color:'+(_ldSt_page>0?'#5ea8c8':'#4a8aaa')+';padding:2px 8px" onclick="'+( _ldSt_page>0?'_ldSt_page--;_renderStPage()':'')+'">&#9664;</span>';
    // 页码（显示当前页附近的5个）
    var pStart=Math.max(0,_ldSt_page-2),pEnd=Math.min(totalPages-1,_ldSt_page+2);
    if(pEnd-pStart<4){if(pStart===0)pEnd=Math.min(totalPages-1,pStart+4);else pStart=Math.max(0,pEnd-4)}
    for(var pi=pStart;pi<=pEnd;pi++){
      var active=pi===_ldSt_page;
      navHtml+='<span style="cursor:pointer;padding:2px 10px;border-radius:3px;background:'+(active?'rgba(0,224,192,0.2)':'transparent')+';color:'+(active?'#00e0c0':'#5ea8c8')+';font-weight:'+(active?'500':'normal')+'" onclick="_ldSt_page='+pi+';_renderStPage()">'+(pi+1)+'</span>';
    }
    // 下一页
    navHtml+='<span style="cursor:'+(_ldSt_page<totalPages-1?'pointer':'default')+';color:'+(_ldSt_page<totalPages-1?'#5ea8c8':'#4a8aaa')+';padding:2px 8px" onclick="'+( _ldSt_page<totalPages-1?'_ldSt_page++;_renderStPage()':'')+'">&#9654;</span>';
    // 末页
    navHtml+='<span style="cursor:'+(_ldSt_page<totalPages-1?'pointer':'default')+';color:'+(_ldSt_page<totalPages-1?'#5ea8c8':'#4a8aaa')+';padding:2px 8px" onclick="'+( _ldSt_page<totalPages-1?'_ldSt_page='+(totalPages-1)+';_renderStPage()':'')+'">&#9654;&#9654;</span>';
  }
  navHtml+='<span style="color:#4a8aaa;font-size:13px;margin-left:12px;white-space:nowrap">共 <b style="color:#5ea8c8;font-size:14px">'+total+'</b> 站</span>';
  navEl.innerHTML=navHtml;
  navEl.style.display=total>_ldSt_PAGE_SIZE?'flex':'none';
}
function initStFilters(d){
  const dtEl=document.getElementById('st-flt-district');const mgEl=document.getElementById('st-flt-manager');
  // 只初始化一次（下拉已有选项说明已初始化过）
  if(dtEl&&dtEl.options.length>1)return;
  const dists=[],mgrs=[],dd=new Set,mm=new Set;
  (d||[]).forEach(s=>{
    const area=((s.district||'').trim()).replace(/^(.+?[区县市]).*$/,'$1');
    if(area&&!dd.has(area)){dd.add(area);dists.push(area)}
    if(s.manager&&!mm.has(s.manager)){mm.add(s.manager);mgrs.push(s.manager)}
  });
  dists.sort();mgrs.sort();
  if(dtEl)dtEl.innerHTML='<option value="">全部区划</option>'+dists.map(function(d){return '<option value="'+esc(d)+'">'+esc(d)+'</option>'}).join('');
  if(mgEl&&_user&&_user.role==='admin'){mgEl.style.display='inline-block';mgEl.innerHTML='<option value="">全部负责人</option>'+mgrs.map(function(m){return '<option value="'+esc(m)+'">'+esc(m)+'</option>'}).join('')}
}

async function showSite(id){const d=await af('/site/status/'+id);if(!d)return;const devs=d.devices||[];const ov=document.createElement('div');ov.className='modal-overlay';
const devHtml=devs.map(x=>`<tr><td style="padding:6px 10px;text-align:center">${esc(x.device_code)}</td><td style="padding:6px 10px;text-align:center">${esc(x.device_name)}</td><td style="padding:6px 10px;text-align:center">${esc(DT[x.device_type]||x.device_type)}</td><td style="padding:6px 10px;text-align:center"><span class="badge ${x.status==='online'?'badge-grn':'badge-org'}">${x.status==='online'?'在线':'离线'}</span></td><td style="padding:6px 10px;text-align:center">${esc(x.last_data_time||'-')}</td>${x.status==='offline'?`<td style="padding:6px 10px;text-align:center"><button class="btn btn-warning btn-xs" onclick="event.stopPropagation();qckOrder(${id},'${esc(x.device_name).replace(/'/g,"\\'")}')">异常处理</button></td>`:'<td></td>'}</tr>`).join('');
const healthClr=(d.data_health==='alert'||d.data_health==='abnormal')?'#ff4760':'#2ea080';
const healthTxt=(d.data_health==='alert'||d.data_health==='abnormal')?'异常':'正常';
ov.innerHTML=`<div class="modal" style="max-width:950px"><h4>&#187;&#187;&#187; ${esc(d.name)} (${esc(d.code)})</h4><div style="font-size:11px;margin-bottom:8px">类型: ${esc(TM[d.type]||d.type)} | 负责人: ${esc(d.manager)} | 电话: ${esc(d.phone)} | <span style="color:${healthClr}">状态: ${healthTxt}</span> | 设备: ${devs.length}台<span style="color:#ff4760;margin-left:8px">离线: ${devs.filter(x=>x.status==='offline').length}台</span> | <span style="color:#ffa040">工单: ${d.open_orders||0}</span></div>
<h5 style="color:#00e0c0;font-size:12px;margin:8px 0 4px">设备清单</h5>
<table style="width:100%;border-collapse:collapse"><thead><tr><th style="padding:6px 10px;text-align:center">设备编码</th><th style="padding:6px 10px;text-align:center">名称</th><th style="padding:6px 10px;text-align:center">类型</th><th style="padding:6px 10px;text-align:center">状态</th><th style="padding:6px 10px;text-align:center">最后数据</th><th style="padding:6px 10px;text-align:center">操作</th></tr></thead><tbody>${devHtml||'<tr><td colspan="6" style="text-align:center;padding:12px;color:#4a8aaa">暂无设备</td></tr>'}</tbody></table>
<div style="margin-top:10px;display:flex;gap:8px"><button class="btn btn-primary btn-sm" onclick="this.closest(\'.modal-overlay\').remove();showSiteTrend(${id})">查看数据趋势 ›</button><button class="btn btn-sm" style="color:#4a8aaa;border:1px solid rgba(0,200,180,0.15)" onclick="this.closest(\'.modal-overlay\').remove()">关闭</button></div></div>`;
document.body.appendChild(ov)}
// 站点数据趋势分析面板
let _trendChart=null;
let _trendSiteId=null;
async function showSiteTrend(id){
  _trendSiteId=id;
  // 获取站点基本信息
  const sd=await af('/sites/'+id);
  const ov=document.createElement('div');ov.className='modal-overlay';
  ov.innerHTML=`<div class="modal" style="max-width:1100px;height:90vh;display:flex;flex-direction:column">
    <div style="display:flex;align-items:center;justify-content:space-between;flex-shrink:0;padding-bottom:8px;border-bottom:1px solid rgba(0,200,180,0.08)">
      <h4 style="margin:0">&#187;&#187;&#187; 数据趋势: ${esc(sd?sd.name:'站点#'+id)}</h4>
      <div style="display:flex;gap:6px;align-items:center">
        <span style="font-size:12px;color:#5ea8c8">指标</span>
        <div id="tr-metric-tabs" style="display:flex;gap:2px"></div>
        <span style="font-size:12px;color:#5ea8c8;margin-left:6px">周期</span>
        <select id="tr-range" style="padding:4px 8px;border:1px solid rgba(0,200,180,0.2);border-radius:3px;background:rgba(0,20,30,0.6);color:#d0e8ff;font-size:12px" onchange="loadTrendData()">
          <option value="24">24小时</option><option value="168" selected>7天</option><option value="720">30天</option>
        </select>
        <button class="btn btn-sm" style="color:#4a8aaa;border:1px solid rgba(0,200,180,0.15)" onclick="exportTrendCsv()">导出CSV</button>
        <button class="btn btn-sm" style="color:#4a8aaa;border:1px solid rgba(0,200,180,0.15)" onclick="this.closest(\'.modal-overlay\').remove();_trendChart=null">关闭</button>
      </div>
    </div>
    <div style="flex:1;min-height:200px;position:relative;margin-top:8px">
      <div id="tr-loading" style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;background:rgba(10,20,30,0.6);z-index:5"><div class="sp"></div><span style="margin-left:10px;color:#5ea8c8;font-size:13px">加载趋势数据...</span></div>
      <canvas id="chart-trend" style="width:100%;height:100%"></canvas>
      <div id="tr-error" style="position:absolute;inset:0;display:none;align-items:center;justify-content:center;color:#5ea8c8;font-size:13px">暂无数据</div>
    </div>
    <div style="height:200px;flex-shrink:0;margin-top:6px;border-top:1px solid rgba(0,200,180,0.08);display:flex;flex-direction:column">
      <div style="display:flex;justify-content:space-between;align-items:center;padding:4px 0">
        <span style="font-size:12px;color:#5ea8c8">&#x25B8; 数据列表</span>
        <span style="font-size:11px;color:#4a8aaa" id="tr-list-count"></span>
      </div>
      <div style="flex:1;overflow-y:auto;font-size:11px" id="tr-data-list">
        <div style="color:#4a8aaa;padding:20px;text-align:center">请先加载趋势数据</div>
      </div>
    </div>
    <div style="display:flex;gap:12px;font-size:11px;color:#5ea8c8;flex-shrink:0;padding-top:6px;border-top:1px solid rgba(0,200,180,0.08)" id="tr-stats"></div>
  </div>`;
  document.body.appendChild(ov);
  loadTrendData()
}
async function loadTrendData(){
  const id=_trendSiteId;if(!id)return;
  const tab=document.querySelector('#tr-metric-tabs .tab-btn.active');
  const metric=tab?tab.dataset.metric:'';
  const hours=document.getElementById('tr-range').value||168;
  document.getElementById('tr-loading').style.display='flex';
  document.getElementById('tr-error').style.display='none';
  try{
    const d=await af('/data/site/'+id+'/trend?hours='+hours+'&limit=3000');
    if(!d||!d.series||Object.keys(d.series).length===0){
      document.getElementById('tr-loading').style.display='none';
      document.getElementById('tr-error').style.display='flex';
      document.getElementById('tr-error').textContent='该站点暂无历史数据';
      return
    }
    // 构建指标按钮（第一次加载时填充）
    const tabsEl=document.getElementById('tr-metric-tabs');
    if(!tabsEl.querySelector('.tab-btn')){
      tabsEl.innerHTML='';
      d.metrics.forEach(function(m,i){
        const btn=document.createElement('div');
        btn.className='tab-btn'+(i===0?' active':'');
        btn.dataset.metric=m;
        btn.textContent=MT_CN[m]||m;
        btn.onclick=function(){tabsEl.querySelectorAll('.tab-btn').forEach(function(b){b.classList.remove('active')});btn.classList.add('active');loadTrendData()};
        tabsEl.appendChild(btn)
      })
    }
    // 获取当前选中指标的数据
    const activeMetric=document.querySelector('#tr-metric-tabs .tab-btn.active')?.dataset.metric;
    const seriesData=activeMetric?(d.series[activeMetric]?{[activeMetric]:d.series[activeMetric]}:{}):(Object.keys(d.series).length===1?d.series:{});
    const metricKeys=Object.keys(seriesData);
    if(metricKeys.length===0){
      document.getElementById('tr-loading').style.display='none';
      document.getElementById('tr-error').style.display='flex';
      document.getElementById('tr-error').textContent='所选指标暂无数据';
      return
    }
    // 渲染图表
    renderTrendChart(seriesData);
    // 渲染数据列表
    renderTrendDataList(seriesData, hours);
    // 统计信息
    var total=0;
    metricKeys.forEach(function(m){total+=seriesData[m].length});
    document.getElementById('tr-stats').innerHTML='<span>数据点: '+total+'</span><span>时段: '+hours+'h</span>';
  }catch(e){
    document.getElementById('tr-loading').style.display='none';
    document.getElementById('tr-error').style.display='flex';
    document.getElementById('tr-error').textContent='加载失败: '+e.message;
  }
  document.getElementById('tr-loading').style.display='none';
}
function renderTrendChart(d){
  const colors=['#00e0c0','#4af','#ffa040','#ff4760','#c084fc','#f472b6'];
  const datasets=[];
  var allTimes=[];
  var idx=0;
  Object.keys(d).forEach(function(metric){
    var pts=d[metric];
    if(!pts||pts.length<2)return;
    var color=colors[idx%colors.length];idx++;
    var cn=MT_CN[metric]||metric;
    var dataPts=pts.map(function(p){
      var t=new Date(p.recorded_at.replace(' ','T')).getTime();
      if(t)allTimes.push(t);
      return{x:t,y:p.value}
    });
    datasets.push({
      label:cn+(pts[0].unit?' ('+pts[0].unit+')':''),
      data:dataPts,
      borderColor:color,backgroundColor:color+'33',
      borderWidth:1.5,pointRadius:1.5,pointHoverRadius:4,
      tension:0.2,fill:false
    })
  });
  if(_trendChart){_trendChart.destroy();_trendChart=null}
  const cv=document.getElementById('chart-trend');if(!cv||!datasets.length)return;
  const ctx=cv.getContext('2d');
  _trendChart=new Chart(ctx,{
    type:'line',
    data:{datasets:datasets},
    options:{
      responsive:true,maintainAspectRatio:false,
      interaction:{mode:'nearest',axis:'x',intersect:false},
      scales:{
        x:{type:'linear',ticks:{color:'#5ea8c8',font:{size:10},maxTicksLimit:12,callback:function(v){var d=new Date(v);return(d.getMonth()+1)+'/'+d.getDate()+' '+String(d.getHours()).padStart(2,'0')+':'+String(d.getMinutes()).padStart(2,'0')}},grid:{color:'rgba(0,200,180,0.06)'}},
        y:{beginAtZero:false,grid:{color:'rgba(0,200,180,0.06)'},ticks:{color:'#5ea8c8',font:{size:10}}}
      },
      plugins:{
        legend:{labels:{color:'#b0d4ef',font:{size:11},usePointStyle:false,boxWidth:12,padding:12}},
        tooltip:{backgroundColor:'rgba(10,25,40,0.9)',titleColor:'#d0e8ff',bodyColor:'#b0d4ef',borderColor:'rgba(0,200,180,0.2)',borderWidth:1,padding:8,cornerRadius:4,callbacks:{title:function(items){var d=new Date(items[0].parsed.x);return d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0')+'-'+String(d.getDate()).padStart(2,'0')+' '+String(d.getHours()).padStart(2,'0')+':'+String(d.getMinutes()).padStart(2,'0')}}}
      }
    }
  })
}
// 渲染趋势数据列表
function renderTrendDataList(seriesData, hours){
  var listEl=document.getElementById('tr-data-list');
  var countEl=document.getElementById('tr-list-count');
  if(!listEl)return;
  var allRows=[];
  Object.keys(seriesData).forEach(function(metric){
    var pts=seriesData[metric];
    if(!pts||!pts.length)return;
    var cn=MT_CN[metric]||metric;
    pts.forEach(function(pt){
      var t=pt.x||pt.t||pt.recorded_at||'';
      // Chart.js数据格式: x=timestamp(ms), y=value
      var timeStr='';
      if(typeof t==='number'){
        var d=new Date(t);
        timeStr=d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0')+'-'+String(d.getDate()).padStart(2,'0')+' '+String(d.getHours()).padStart(2,'0')+':'+String(d.getMinutes()).padStart(2,'0');
      }else{
        timeStr=(t||'').substring(0,16);
      }
      allRows.push({metric:cn, value:pt.y||pt.value||pt, time:timeStr})
    })
  });
  // 按时间排序（最新的在前）
  allRows.sort(function(a,b){return a.time>b.time?-1:1});
  if(countEl)countEl.textContent='共 '+allRows.length+' 条数据';
  if(!allRows.length){
    listEl.innerHTML='<div style="color:#4a8aaa;padding:20px;text-align:center">暂无数据</div>';
    return
  }
  var html='<table style="width:100%;font-size:11px"><thead><tr style="position:sticky;top:0;background:rgba(4,18,52,0.98)"><th style="color:#5ea8c8;text-align:left;padding:4px 6px">指标</th><th style="color:#5ea8c8;text-align:right;padding:4px 6px">数值</th><th style="color:#5ea8c8;text-align:right;padding:4px 6px">采集时间</th></tr></thead><tbody>';
  allRows.forEach(function(r){
    var val=typeof r.value==='number'?r.value.toFixed(2):r.value;
    html+='<tr style="border-top:1px solid rgba(0,200,180,0.04)"><td style="color:#b0d4ef;padding:3px 6px;white-space:nowrap">'+esc(r.metric)+'</td><td style="color:#00e0c0;text-align:right;padding:3px 6px;font-family:monospace">'+val+'</td><td style="color:#4a8aaa;text-align:right;padding:3px 6px;white-space:nowrap;font-size:10px">'+esc(r.time)+'</td></tr>'
  });
  html+='</tbody></table>';
  listEl.innerHTML=html;
}
// CSV导出
function exportTrendCsv(){
  const chart=_trendChart;if(!chart){showToast('无趋势数据可导出','warning');return}
  const ds=chart.data.datasets;if(!ds||!ds.length)return;
  var csv='指标,值,时间\n';
  ds.forEach(function(ds){
    ds.data.forEach(function(pt){
      csv+=ds.label+','+pt.y+','+pt.x+'\n'
    })
  });
  const blob=new Blob(['\ufeff'+csv],{type:'text/csv;charset=utf-8'});
  const url=URL.createObjectURL(blob);
  const a=document.createElement('a');a.href=url;a.download='trend-'+_trendSiteId+'.csv';a.click();
  URL.revokeObjectURL(url);
  showToast('数据已导出')
}
// 设备异常快速转工单（防重复点击+按钮禁用）
let _qckBusy=false;
// 告警操作防重复锁
let _alBusy=false;
async function qckOrder(siteId,devName){
  if(_qckBusy){showToast('操作进行中，请稍候...','warning');return}
  _qckBusy=true;
  const btn=event&&event.target;if(btn){btn.disabled=true;btn.textContent='提交中...'}
  const r=await afP('/workorders',{site_id:siteId,source:'auto',event_type:'设备异常',level:'urgent',title:'设备离线-'+devName,description:'设备离线异常，需尽快排查处理'});
  _qckBusy=false;
  if(btn){btn.disabled=false;btn.textContent='异常处理'}
  if(r&&r.success){showToast('工单 '+r.order_no+' 创建成功');ldOr()}
}

async function ldAl(){
  // 设置默认状态筛选为待处理
  var statusEl=document.getElementById('al-flt-status');
  if(statusEl&&!statusEl.value) statusEl.value='pending';
  const status=statusEl?statusEl.value:'';
  const dateRange=document.getElementById('al-flt-date').value;
  const now=new Date();
  let date_from='',date_to='';
  if(dateRange==='today'){
    date_from=now.getFullYear()+'-'+(now.getMonth()+1).toString().padStart(2,'0')+'-'+now.getDate().toString().padStart(2,'0');
  }else if(dateRange==='week'){
    const day=now.getDay()||7;const monday=new Date(now);monday.setDate(now.getDate()-day+1);
    date_from=monday.getFullYear()+'-'+(monday.getMonth()+1).toString().padStart(2,'0')+'-'+monday.getDate().toString().padStart(2,'0');
  }else if(dateRange==='month'){
    date_from=now.getFullYear()+'-'+(now.getMonth()+1).toString().padStart(2,'0')+'-01';
  }
  let url='/alerts?limit=200';
  if(status)url+='&status='+status;
  if(date_from)url+='&date_from='+date_from;
  if(date_to)url+='&date_to='+date_to;
  const d=await af(url);if(!d)return;
  const p=d.filter(x=>x.status==='pending');
  const sorted=[...d].sort((a,b)=>{const da=a.created_at||'',db=b.created_at||'';return da<db?1:da>db?-1:0});
  _initPg('al-body', sorted)
  // 刷新顶部指标卡
  renderAlertMetrics()
}
// 告警表格行渲染（分页回调）
window['_renderTable_al-body']=function(rows){
  document.getElementById('al-body').innerHTML=rows.map(a=>{
    // 合并状态：flow+status → 一个标签
    var badgeStyle='',badgeText='';
    var ft=a.flow_type||'manual',fs=a.flow_status||'';
    var isPending=a.status==='pending';
    if(ft==='auto'&&fs==='converted'){
      badgeStyle='background:rgba(255,71,96,0.12);color:#ff4760;border:1px solid rgba(255,71,96,0.25)';
      badgeText='自动工单';
    }else if(ft==='auto'&&fs==='pending'){
      // A级待转单（短时缺失等，尚未生成工单）
      badgeStyle='background:rgba(160,120,64,0.12);color:#c8a040;border:1px solid rgba(160,120,64,0.25)';
      badgeText='待自动转单';
    }else if(ft==='manual'&&fs==='pending_review'){
      badgeStyle='background:rgba(255,160,64,0.12);color:#ffa040;border:1px solid rgba(255,160,64,0.25)';
      badgeText='待复核';
    }else if(fs==='converted'){
      badgeStyle='background:rgba(90,168,200,0.12);color:#5ea8c8;border:1px solid rgba(90,168,200,0.25)';
      badgeText='已转工单';
    }else if(fs==='dismissed'||a.status==='resolved'){
      badgeStyle='background:rgba(80,80,80,0.1);color:#777;border:1px solid rgba(80,80,80,0.2)';
      badgeText='已关闭';
    }else{
      badgeStyle='background:rgba(0,224,192,0.1);color:#2ea080;border:1px solid rgba(0,224,192,0.2)';
      badgeText='已确认';
    }
    // 操作按钮 — 按状态分4类
    var actionHtml='';
    // ① B级人工待复核 → 处理按钮（转工单/消除）
    if(ft==='manual'&&fs==='pending_review'){
      actionHtml=`<button class="btn btn-sm" style="color:#00e0c0;border:1px solid rgba(0,224,192,0.3);padding:2px 10px;font-size:13px" onclick="alConfirmConvert(${a.id})">处理</button>`;
    }else if(a.related_order_no){
      // ② 已有关联工单 → 查看链接
      var ono=a.related_order_no;
      actionHtml=`<a href="javascript:showOrderDetail('${esc(ono)}')" style="color:#4af;font-size:13px">查看工单 ›</a>`;
    }else if(ft==='auto'&&fs==='pending'){
      // ③ A级自动待转单 → 可人工提前介入处理
      actionHtml=`<button class="btn btn-sm" style="color:#c8a040;border:1px solid rgba(200,160,64,0.3);padding:2px 10px;font-size:13px" onclick="doConvert(${a.id})">转工单</button>`;
    }else if(isPending&&fs!=='pending_review'){
      // ④ 待处理的已确认告警 → 时间线
      actionHtml=`<button class="btn btn-sm" style="color:#5ea8c8;border:1px solid rgba(90,168,200,0.3);padding:2px 10px;font-size:13px" onclick="showAlertTimeline(${a.id})">时间线</button>`;
    }else{
      actionHtml=`<button class="btn btn-sm" style="color:#4a8aaa;border:1px solid rgba(0,200,180,0.15);padding:2px 10px;font-size:13px" onclick="showAlertTimeline(${a.id})">时间线</button>`;
    }
    // 督办角标
    var urgeBadge=a.urge_count?`<span style="color:#ffa040;font-size:11px;margin-left:6px">🔔${a.urge_count}</span>`:'';
    return `<tr data-id="${a.id}"><td style="width:36px;text-align:center"><input type="checkbox" class="al-cb" value="${a.id}" onchange="alUpdCnt()" style="width:16px;height:16px"></td>
      <td style="width:110px;font-size:13px">${(function(){var lv=a.level||'';var lvClr={'red':'#ff4760','orange':'#ffa040','yellow':'#ffd000'}[lv]||'#5ea8c8';var lvCn={'red':'紧急','orange':'较重','yellow':'一般'}[lv]||lv;return '<span style="display:inline-block;width:4px;height:12px;border-radius:2px;background:'+lvClr+';margin-right:4px;vertical-align:middle"></span><span style="vertical-align:middle">'+esc(a.site_name)+'</span><span style="font-size:10px;color:#4a8aaa;margin-left:4px">'+lvCn+'</span>'})()}</td>
      <td style="font-size:13px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${esc(a.message)}</td>
      <td style="width:130px;font-size:13px"><span style="display:inline-flex;align-items:center;border-radius:4px;padding:2px 8px;font-weight:500;${badgeStyle}">${badgeText}</span>${urgeBadge}</td>
      <td style="width:110px;font-size:13px;color:#5ea8c8;font-family:monospace;text-align:center">${a.created_at?esc(a.created_at.substring(5,16)):''}</td>
      <td style="width:100px;text-align:center;font-size:13px">${actionHtml}</td></tr>`
  }).join('')
};

// 告警指标卡渲染
async function renderAlertMetrics(){
  const el=document.getElementById('al-metrics');if(!el)return;
  try{
    await refreshDashboard();
    // 从全量数据计算月办结率（不随筛选变化）
    var monthResolved=0,monthTotal=0,monthRate='--';
    var monthStart=new Date();monthStart.setDate(1);
    var ms=monthStart.toISOString().substring(0,10);
    try{
      var allAl=_summaryData&&_summaryData.alerts?null:await af('/alerts?limit=500');
      if(allAl&&allAl.length){
        for(var ai=0;ai<allAl.length;ai++){
          var dt=allAl[ai].created_at?allAl[ai].created_at.substring(0,10):'';
          if(dt>=ms){
            monthTotal++;
            if(allAl[ai].status==='resolved')monthResolved++;
          }
        }
        monthRate=monthTotal?Math.round(monthResolved/monthTotal*100):0;
      }else if(_summaryData&&_summaryData.alerts){
        monthRate='--';
      }
    }catch(e){}
    // 从全量告警数据计算统计，不依赖分页
    var alFullData = [];
    try{
      if(allAl && allAl.length) alFullData = allAl;
      // 如果allAl不可用（异常），兜底用分页数据
      if(!alFullData.length && _pgState && _pgState['al-body'] && _pgState['al-body'].data) 
        alFullData = _pgState['al-body'].data;
    }catch(e){}
    var total=alFullData.length, pending=0, today=0;
    var acknowledged=allAl?allAl.filter(function(r){return r.status==='acknowledged'}).length:0;
    var resolved=allAl?allAl.filter(function(r){return r.status==='resolved'}).length:0;
    var todayStr=new Date().toISOString().substring(0,10);
    for(var ai2=0;ai2<alFullData.length;ai2++){
      var r=alFullData[ai2];
      if(r.status==='pending')pending++;
      if(r.created_at&&r.created_at.substring(0,10)===todayStr)today++;
    }
    // 用summary数据覆盖统计值
    if(_summaryData&&_summaryData.alerts){
      pending=_summaryData.alerts.pending;
      acknowledged=_summaryData.alerts.acknowledged;
      resolved=_summaryData.alerts.resolved;
      today=_summaryData.alerts.today_new;
    }
    // 获取待复核统计 + 自动转工单数
    var pendingReview = 0, autoConverted = 0;
    try{
      var stData = await af('/alerts/statistics');
      if(stData && stData.pending_review !== undefined) pendingReview = stData.pending_review;
      if(stData && stData.auto_converted !== undefined) autoConverted = stData.auto_converted;
    }catch(e){}
    // 按告警类型分类统计
    var catCount={'data_quality':0,'device_status':0,'ops_timeliness':0};
    var catCn={'data_quality':'数据质量','device_status':'设备状态','ops_timeliness':'运维时效'};
    var catColors={'data_quality':'#ff4760','device_status':'#ffa040','ops_timeliness':'#00e0c0'};
    alFullData.forEach(function(r){
      var m=r.metric||'';
      if(m==='data_gap'||m==='data_freeze'||m==='data_spike')catCount.data_quality++;
      else if(m==='device_status')catCount.device_status++;
      else catCount.ops_timeliness++;
    });
    // 用summary数据覆盖告警分类统计
    if(_summaryData&&_summaryData.alerts&&_summaryData.alerts.by_type){
      catCount.data_quality=_summaryData.alerts.by_type.data_quality;
      catCount.device_status=_summaryData.alerts.by_type.device_status;
      catCount.ops_timeliness=_summaryData.alerts.by_type.ops_timeliness;
    }
    // 5个指标卡（待处理、处理中、已办结、今日新增、自动转工单）
    el.innerHTML=
      '<div class="al-mcard"><div class="mc-val" style="color:#ffa040">'+pending+'</div><div class="mc-lbl">待处理</div></div>'+
      '<div class="al-mcard"><div class="mc-val" style="color:#5ea8c8">'+(acknowledged||0)+'</div><div class="mc-lbl">处理中</div></div>'+
      '<div class="al-mcard"><div class="mc-val" style="color:#2ea080">'+(resolved||0)+'</div><div class="mc-lbl">已办结</div></div>'+
      '<div class="al-mcard"><div class="mc-val" style="color:#ff4760">'+today+'</div><div class="mc-lbl">今日新增</div></div>'+
      '<div class="al-mcard"><div class="mc-val" style="color:#5ea8c8">'+autoConverted+'</div><div class="mc-lbl">自动转工单</div></div>';
    // 7天趋势图（增大面积）
    var trendHtml='';
    try{
      if(allAl&&allAl.length){
        var dayCnt={};
        for(var di=0;di<7;di++){var d2=new Date();d2.setDate(d2.getDate()-di);var k=d2.getFullYear()+'-'+(d2.getMonth()+1).toString().padStart(2,'0')+'-'+d2.getDate().toString().padStart(2,'0');dayCnt[k]=0}
        for(var ai=0;ai<allAl.length;ai++){
          var dt2=allAl[ai].created_at?allAl[ai].created_at.substring(0,10):'';
          if(dayCnt[dt2]!==undefined)dayCnt[dt2]++;
        }
        var days=Object.keys(dayCnt).sort(),maxD=1;
        var vals=days.map(function(k){var v=dayCnt[k];if(v>maxD)maxD=v;return v});
        var tw=180,th=50,pad=3;
        var pts=vals.map(function(v,i){var x=pad+(i/(vals.length-1||1))*(tw-2*pad);var y=th-pad-(v/maxD)*(th-2*pad);return x.toFixed(1)+','+y.toFixed(1)}).join(' ');
        trendHtml='<div style="width:200px;display:flex;flex-direction:column"><div style="font-size:10px;color:#4a8aaa;margin-bottom:2px;text-align:right">近7天告警趋势</div><svg width="'+tw+'" height="'+th+'" viewBox="0 0 '+tw+' '+th+'" style="display:block"><polyline points="'+pts+'" fill="none" stroke="#00e0c0" stroke-width="1.5" opacity="0.8"/>';
        for(var di2=0;di2<vals.length;di2++){var xi=pad+(di2/(vals.length-1||1))*(tw-2*pad);var yi=th-pad-(vals[di2]/maxD)*(th-2*pad);trendHtml+='<circle cx="'+xi.toFixed(1)+'" cy="'+yi.toFixed(1)+'" r="2" fill="#00e0c0" opacity="0.6"/>'}
        var lastX=pad+(1)*(tw-2*pad),lastY=th-pad-(vals[vals.length-1]/maxD)*(th-2*pad);
        trendHtml+='<circle cx="'+lastX.toFixed(1)+'" cy="'+lastY.toFixed(1)+'" r="3" fill="#ff4760" opacity="0.9"/>';
        trendHtml+='<text x="'+(tw-2)+'" y="'+(th-2)+'" fill="#4a8aaa" font-size="8" text-anchor="end">'+vals[vals.length-1]+'</text></svg></div>';
      }
    }catch(e){}
    var trendArea=document.getElementById('al-trend-area');
    if(trendArea)trendArea.innerHTML=trendHtml;
    if(window._alChart){window._alChart.destroy();window._alChart=null}
  }catch(e){el.innerHTML=''}
}

// ========== 告警批量操作 ==========
function alUpdCnt(){const cbs=document.querySelectorAll('.al-cb:checked');const cnt=cbs.length;const bar=document.getElementById('al-batch');bar.style.display=cnt?'flex':'none';document.getElementById('al-sel-cnt').textContent=`已选${cnt}项`;document.getElementById('al-cb-all').checked=cnt===document.querySelectorAll('.al-cb').length&&cnt>0}
function alSelAll(chk){document.querySelectorAll('.al-cb').forEach(c=>c.checked=chk);alUpdCnt()}
function clrAlSel(){document.querySelectorAll('.al-cb').forEach(c=>c.checked=false);alUpdCnt()}
// 批量办结（含原因选择）
async function batchResolve(){
  if(_alBusy)return;
  const ids=Array.from(document.querySelectorAll('.al-cb:checked')).map(c=>parseInt(c.value));
  if(!ids.length){showToast('请先选择告警','warning');return}
  const ov=document.createElement('div');ov.className='modal-overlay';
  ov.innerHTML='<div class="modal"><h4>&#187;&#187;&#187; 批量办结 ('+ids.length+'条)</h4><div style="margin-bottom:10px;font-size:12px;color:#5ea8c8">请选择统一办结原因</div><div style="margin-bottom:10px">'+
    ['误报','仪器正常偏差','已自动恢复','已人工处理'].map((r,i)=>'<label style="display:flex;align-items:center;gap:6px;padding:6px 8px;margin:3px 0;border-radius:3px;cursor:pointer;border:1px solid rgba(0,200,180,0.1);background:rgba(0,200,180,0.02)" onclick="this.parentElement.querySelectorAll(\'input\').forEach(c=>c.checked=false);this.querySelector(\'input\').checked=true"><input type="radio" name="br-reason" value="'+r+'" '+(i===0?'checked':'')+' style="width:14px;height:14px"><span style="font-size:13px;color:#d0e8ff">'+r+'</span></label>').join('')+
  '</div><div style="display:flex;gap:8px"><button class="btn btn-primary" onclick="doBatchResolve()">确认办结</button><button class="btn" style="color:#4a8aaa;border:1px solid rgba(0,200,180,0.15)" onclick="this.closest(\'.modal-overlay\').remove()">取消</button></div></div>';
  document.body.appendChild(ov)
}
async function doBatchResolve(){
  if(_alBusy)return;
  const reason=document.querySelector('input[name="br-reason"]:checked');
  if(!reason){showToast('请选择办结原因','warning');return}
  const ids=Array.from(document.querySelectorAll('.al-cb:checked')).map(c=>parseInt(c.value));
  if(!ids.length){showToast('请先选择告警','warning');return}
  _alBusy=true;showToast('批量办结中 ('+ids.length+'条)...','info');
  try{
    const r=await afP('/alerts/batch',{ids,action:'resolve',reason:reason.value});
    if(r&&r.success){showToast('批量办结成功 ('+ids.length+'条)');document.querySelectorAll('.modal-overlay').forEach(e=>e.remove());ldAl();clrAlSel();refreshDashboard()}else{showToast('批量办结失败','error')}
  }catch(e){showToast('操作异常: '+e.message,'error')}finally{_alBusy=false}
}
async function batchAl(action){if(_alBusy)return;const ids=Array.from(document.querySelectorAll('.al-cb:checked')).map(c=>parseInt(c.value));if(!ids.length){showToast('请先选择告警','warning');return}_alBusy=true;showToast('批量操作进行中 ('+ids.length+'条)...','info');try{const r=await afP('/alerts/batch',{ids,action});if(r&&r.success){showToast('批量操作成功 ('+ids.length+'条)');ldAl();clrAlSel();refreshDashboard()}else{showToast('批量操作失败'+(r&&r.error?': '+r.error:''),'error')}}catch(e){showToast('操作异常: '+e.message,'error')}finally{_alBusy=false}}
async function alUrge(id){
  const ov=document.createElement('div');ov.className='modal-overlay';
  ov.innerHTML='<div class="modal"><h4>&#187;&#187;&#187; 督办告警</h4><div class="form-row"><label>限办时间</label><input type="date" id="urge-deadline" style="width:200px"></div><div class="form-row"><label>协办单位/人员</label><input id="urge-coop" placeholder="输入协办单位或人员..." style="width:200px"></div><div class="form-row"><label>督办意见（必填）</label><textarea id="urge-remark" placeholder="请输入督办意见..." minlength="1"></textarea></div><div style="display:flex;gap:8px"><button class="btn btn-primary" onclick="doUrge('+id+')">提交督办</button><button class="btn" style="color:#4a8aaa;border:1px solid rgba(0,200,180,0.15)" onclick="this.closest(\'.modal-overlay\').remove()">取消</button></div></div>';
  document.body.appendChild(ov)
}
async function doUrge(id){
  if(_alBusy)return;
  const remark=document.getElementById('urge-remark').value;if(!remark.trim()){showToast('请输入督办意见','warning');return}
  const deadline=document.getElementById('urge-deadline').value;
  const cooperator=document.getElementById('urge-coop').value.trim();
  const btn=event&&event.target;if(btn){btn.disabled=true;btn.textContent='提交中...'}
  _alBusy=true;
  try{
    const r=await afP('/alerts/'+id+'/urge',{operator:'系统',remark,deadline,cooperator});if(r&&r.success){document.querySelectorAll('.modal-overlay').forEach(e=>e.remove());showToast('督办已提交');ldAl();refreshDashboard()}else{showToast('督办提交失败','error')}
  }finally{_alBusy=false;if(btn){btn.disabled=false;btn.textContent='提交督办'}}
}
async function alConvert(id){
  if(_alBusy)return;
