  ov.innerHTML='<div class="modal"><h4>&#187;&#187;&#187; 告警转工单</h4><div class="form-row"><label>负责人</label><input id="cv-asgn" placeholder="输入负责人名称..." style="width:200px"></div><div style="display:flex;gap:8px"><button class="btn btn-primary" onclick="doConvert('+id+')">确认转单</button><button class="btn" style="color:#4a8aaa;border:1px solid rgba(0,200,180,0.15)" onclick="this.closest(\'.modal-overlay\').remove()">取消</button></div></div>';
