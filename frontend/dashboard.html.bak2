  _alBusy=true;showToast('处理中...','info');
  try{
    const r=await afP('/alerts/'+id+'/convert-order',{assignee});
    if(r&&r.success){showToast('已转工单: '+r.order_no);document.querySelectorAll('.modal-overlay').forEach(e=>e.remove());updateAlertRow(id,'acknowledged');updateAlertCounters();cockpitAlertRefresh();ldOr();refreshDashboard()}else{showToast('转单失败','error')}
  }finally{_alBusy=false;if(btn){btn.disabled=false;btn.textContent='确认转单'}}
}
// B级告警复核：确认转工单 或 关闭
async function alConfirmConvert(id){
  if(_alBusy)return;
  // 获取可用负责人列表
  let assignees=[];
  try{
    const as=await af('/assignees');
    if(as&&as.length)assignees=as;
  }catch(e){}
  // 先准备HTML，如果获取负责人失败则用默认选项
  const asOpts=assignees.length?assignees.map(a=>'<option value="'+esc(a.name)+'">'+esc(a.name)+' ('+esc(a.role)+')</option>').join(''):'<option value="">手动输入</option>';
  const ov=document.createElement('div');ov.className='modal-overlay';
  ov.innerHTML='<div class="modal" style="max-width:480px"><h4>&#187;&#187;&#187; 告警复核 #'+id+'</h4>'
    // 转工单区
    +'<div style="margin-bottom:12px;padding:10px;border:1px solid rgba(0,224,192,0.15);border-radius:4px"><div style="color:#00e0c0;font-size:13px;margin-bottom:8px">▸ 转工单处置</div>'
    +'<div class="form-row"><label>负责人</label><select id="cv-asgn" style="flex:1;padding:6px 8px;border:1px solid rgba(0,200,180,0.2);border-radius:3px;background:rgba(0,20,30,0.6);color:#d0e8ff;font-size:13px">'+asOpts+'</select></div>'
    +(!assignees.length?'<div style="font-size:11px;color:#5ea8c8;margin-top:4px">提示：如列表为空，请直接输入负责人名称</div>':'')
    +'<div style="display:flex;gap:8px;margin-top:10px"><button class="btn btn-primary" onclick="doConfirmConvert('+id+')">确认转工单</button></div></div>'
    // 消除告警区
    +'<div style="padding:10px;border:1px solid rgba(255,71,96,0.15);border-radius:4px"><div style="color:#ff4760;font-size:13px;margin-bottom:8px">▸ 消除告警（误报/已恢复）</div>'
    +'<div class="form-row"><label>消除理由</label><textarea id="cv-reason" placeholder="请说明消除原因（必填）..." style="flex:1;min-height:60px;padding:6px 8px;border:1px solid rgba(0,200,180,0.2);border-radius:3px;background:rgba(0,20,30,0.6);color:#d0e8ff;font-size:13px"></textarea></div>'
    +'<div style="display:flex;gap:8px;margin-top:10px"><button class="btn" style="color:#ff4760;border:1px solid rgba(255,71,96,0.3);background:rgba(255,71,96,0.06)" onclick="doDismissAlert('+id+')">确认消除告警</button></div></div>'
    // 取消按钮
    +'<button class="btn btn-sm" style="color:#4a8aaa;border:1px solid rgba(0,200,180,0.15);margin-top:12px" onclick="this.closest(\'.modal-overlay\').remove()">取消</button>'
    +'</div>';
  document.body.appendChild(ov)
}
