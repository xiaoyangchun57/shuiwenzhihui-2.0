  const ov=document.createElement('div');ov.className='modal-overlay';
  ov.innerHTML='<div class="modal"><h4>&#187;&#187;&#187; 告警办结</h4><div style="margin-bottom:10px;font-size:12px;color:#5ea8c8">请选择办结原因</div><div style="margin-bottom:10px">'+
    ['误报','仪器正常偏差','已自动恢复','已人工处理'].map((r,i)=>'<label style="display:flex;align-items:center;gap:6px;padding:6px 8px;margin:3px 0;border-radius:3px;cursor:pointer;border:1px solid rgba(0,200,180,0.1);background:rgba(0,200,180,0.02)" onclick="document.querySelectorAll(\'.rs-cb\').forEach(c=>c.checked=false);this.querySelector(\'.rs-cb\').checked=true"><input type="radio" class="rs-cb" name="rs-reason" value="'+r+'" '+(i===0?'checked':'')+' style="width:14px;height:14px"><span style="font-size:13px;color:#d0e8ff">'+r+'</span></label>').join('')+
  '</div><div class="form-row"><label>备注（可选）</label><textarea id="rs-remark" placeholder="补充说明..." style="height:50px"></textarea></div><div style="display:flex;gap:8px"><button class="btn btn-primary" onclick="doResolve('+id+')">确认办结</button><button class="btn" style="color:#4a8aaa;border:1px solid rgba(0,200,180,0.15)" onclick="this.closest(\'.modal-overlay\').remove()">取消</button></div></div>';
  document.body.appendChild(ov)
}
async function doResolve(id){
  if(_alBusy)return;
  const reason=document.querySelector('.rs-cb:checked');
  if(!reason){showToast('请选择办结原因','warning');return}
  const remark=document.getElementById('rs-remark').value.trim();
  const btn=event&&event.target;if(btn){btn.disabled=true;btn.textContent='办结中...'}
  _alBusy=true;
  try{
    const r=await afP('/alerts/'+id+'/resolve',{operator:'系统',reason:reason.value,remark});
    if(r&&r.success){document.querySelectorAll('.modal-overlay').forEach(e=>e.remove());updateAlertRow(id,'resolved');updateAlertCounters();cockpitAlertRefresh();showToast('告警已办结');refreshDashboard()}else{showToast('操作失败，请重试','error')}
  }finally{_alBusy=false;if(btn){btn.disabled=false;btn.textContent='确认办结'}}
}
